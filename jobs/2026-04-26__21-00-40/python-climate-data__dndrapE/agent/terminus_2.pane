[?2004hroot@89d4e656df83:/app/workspace# cat > /app/workspace/src/analyzer.py << 'SCRIPT'
[?2004l[?2004h> import csv
[?2004l[?2004h> import json
[?2004l[?2004h> import os
[?2004l[?2004h> from collections import defaultdict
[?2004l[?2004h> 
[?2004l[?2004h> # Paths
[?2004l[?2004h> CSV_PATH = "/app/workspace/data/climate.csv"
[?2004l[?2004h> META_PATH = "/app/workspace/data/metadata.json"
[?2004l[?2004h> CLEANED_PATH = "/app/workspace/data/cleaned.json"
[?2004l[?2004h> TRENDS_PATH = "/app/workspace/data/trends.json"
[?2004l[?2004h> GV_PATH = "/app/workspace/output/climate_graph.gv"
[?2004l[?2004h> PNG_PATH = "/app/workspace/output/climate_graph.png"
[?2004l[?2004h> 
[?2004l[?2004h> # Ensure output dirs exist
[?2004l[?2004h> os.makedirs(os.path.dirname(CLEANED_PATH), exist_ok=True)
[?2004l[?2004h> os.makedirs(os.path.dirname(GV_PATH), exist_ok=True)
[?2004l[?2004h> 
[?2004l[?2004h> # Load metadata (region_id -> region_name mapping)
[?2004l[?2004h> with open(META_PATH, "r") as f:
[?2004l[?2004h>     metadata = json.load(f)
[?2004l[?2004h> 
[?2004l[?2004h> # Read CSV and filter to post-2020 rows
[?2004l[?2004h> cleaned = []
[?2004l[?2004h> with open(CSV_PATH, "r") as f:
[?2004l[?2004h>     reader = csv.DictReader(f)
[?2004l[?2004h>     for row in reader:
[?2004l[?2004h>         year = int(row["year"])
[?2004l[?2004h>         if year <= 2020:
[?2004l[?2004h>             continue
[?2004l[?2004h>         region_id = str(row["region_id"])
[?2004l[?2004h>         region_name = metadata[region_id]
[?2004l[?2004h>         temperature = float(row["temperature"])
[?2004l[?2004h>         cleaned.append({
[?2004l[?2004h>             "region": region_name,
[?2004l[?2004h>             "temperature": temperature,
[?2004l[?2004h>             "year": year
[?2004l[?2004h>         })
[?2004l[?2004h> 
[?2004l[?2004h> # Phase 1: Write cleaned.json
[?2004l[?2004h> with open(CLEANED_PATH, "w") as f:
[?2004l[?2004h>     json.dump(cleaned, f, indent=2)
[?2004l[?2004h> print(f"Phase 1: Wrote {len(cleaned)} records to {CLEANED_PATH}")
[?2004l[?2004h> 
[?2004l[?2004h> # Phase 2: Compute mean temperature per region and write trends.json
[?2004l[?2004h> region_temps = defaultdict(list)
[?2004l[?2004h> for record in cleaned:
[?2004l[?2004h>     region_temps[record["region"]].append(record["temperature"])
[?2004l[?2004h> 
[?2004l[?2004h> trends = {}
[?2004l[?2004h> for region, temps in region_temps.items():
[?2004l[?2004h>     trends[region] = sum(temps) / len(temps)
[?2004l[?2004h> 
[?2004l[?2004h> with open(TRENDS_PATH, "w") as f:
[?2004l[?2004h>     json.dump(trends, f, indent=2)
[?2004l[?2004h> print(f"Phase 2: Wrote trends for {len(trends)} regions to {TRENDS_PATH}")
[?2004l[?2004h> 
[?2004l[?2004h> # Phase 3: Generate Graphviz directed graph
[?2004l[?2004h> lines = ["digraph climate {"]
[?2004l[?2004h> for region, mean_temp in trends.items():
[?2004l[?2004h>     # Quote both region name and mean temp so decimal values survive verbatim
[?2004l[?2004h>     temp_str = str(mean_temp)
[?2004l[?2004h>     lines.append(f'    "{region}" -> "{temp_str}";')
[?2004l[?2004h> lines.append("}")
[?2004l[?2004h> gv_content = "\n".join(lines) + "\n"
[?2004l[?2004h> 
[?2004l[?2004h> with open(GV_PATH, "w") as f:
[?2004l[?2004h>     f.write(gv_content)
[?2004l[?2004h> print(f"Phase 3: Wrote {GV_PATH}")
[?2004l[?2004h> 
[?2004l[?2004h> # Render PNG
[?2004l[?2004h> import subprocess
[?2004l[?2004h> result = subprocess.run(["dot", "-Tpng", GV_PATH, "-o", PNG_PATH], capture_output=True, text=True)
[?2004l[?2004h> if result.returncode == 0:
[?2004l[?2004h>     print(f"Phase 3: Wrote {PNG_PATH}")
[?2004l[?2004h> else:
[?2004l[?2004h>     print(f"Phase 3 ERROR: {result.stderr}")
[?2004l[?2004h> 
[?2004l[?2004h> print("Done.")
[?2004l[?2004h> SCRIPT
