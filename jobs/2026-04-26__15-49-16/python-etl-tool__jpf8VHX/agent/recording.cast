[24.594414, "i", "cat > /app/workspace/src/templates/index.html <<'HTML'\n<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n    <title>ETL Dashboard</title>\n    <style>\n      body { font-family: Arial, sans-serif; margin: 24px; }\n      #triggerBtn { padding: 10px 16px; }\n      pre { background: #111; color: #eee; padding: 12px; overflow: auto; max-height: 50vh; }\n      .row { margin: 12px 0; }\n    </style>\n  </head>\n  <body>\n    <h1>ETL Dashboard</h1>\n\n    <div class=\"row\">\n      <button id=\"triggerBtn\" type=\"button\">Trigger ETL</button>\n      <a href=\"/download\" style=\"margin-left: 12px;\">Download output.json</a>\n    </div>\n\n    <h2>Logs</h2>\n    <pre id=\"logBox\"></pre>\n\n    <script>\n      async function loadLogs() {\n        const res = await fetch('/logs');\n        const txt = await res.text();\n        document.getElementById('logBox').textContent = txt;\n      }\n\n      window.addEventListener('DOMContentLoaded', () => {\n        loa"]
[24.594548, "i", "dLogs();\n\n        const btn = document.getElementById('triggerBtn');\n        btn.addEventListener('click', async () => {\n          btn.disabled = true;\n          try {\n            const res = await fetch('/trigger', { method: 'POST' });\n            await res.json().catch(() => null);\n            await loadLogs();\n          } finally {\n            btn.disabled = false;\n          }\n        });\n      });\n    </script>\n  </body>\n</html>\nHTML\n"]
