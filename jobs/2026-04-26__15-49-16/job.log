(data) VALUES (?)", (json.dumps(obj),))\n        conn.commit()\n    finally:\n        conn.close()\n\n    return {"inserted": len(records)}\n\n\n@app.get("/")\ndef index():\n    return render_template("index.html")\n\n\n@app.post("/trigger")\ndef trigger():\n    try:\n        result = run_etl()\n        _append_log(f"SUCCESS inserted={result.get(\'inserted\', 0)}")\n        return jsonify({"status": "ok", **result})\n    except Exception as e:\n        _append_log(f"ERROR {type(e).__name__}: {e}")\n        _append_log(traceback.format_exc().rstrip())\n        return jsonify({"status": "error", "error": str(e)}), 500\n\n\n@app.get("/logs")\ndef logs():\n    os.makedirs(DATA_DIR, exist_ok=True)\n    if not os.path.exists(LOG_PATH):\n        return Response("", mimetype="text/plain")\n    with open(LOG_PATH, "r", encoding="utf-8") as f:\n        return Response(f.read(), mimetype="text/plain")\n\n\n@app.get("/download")\ndef download():\n    # Serve output.json (even if empty/nonexistent, return 404)\n    return send_file(OUTPUT_JSON, mimetype="application/json", as_attachment=True, download_name="output.json")\n\n\nif __name__ == "__main__":\n    # Run on required host/port\n    app.run(host="0.0.0.0", port=5000)\nPY\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
