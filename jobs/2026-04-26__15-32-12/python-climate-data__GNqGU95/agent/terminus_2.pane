[?2004l[?2004h> import graphviz
[?2004l[?2004h> 
[?2004l[?2004h> # Paths
[?2004l[?2004h> BASE = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
[?2004l[?2004h> CSV_PATH = os.path.join(BASE, "data", "climate.csv")
[?2004l[?2004h> META_PATH = os.path.join(BASE, "data", "metadata.json")
[?2004l[?2004h> CLEANED_PATH = os.path.join(BASE, "data", "cleaned.json")
[?2004l[?2004h> TRENDS_PATH = os.path.join(BASE, "data", "trends.json")
[?2004l[?2004h> OUTPUT_DIR = os.path.join(BASE, "output")
[?2004l[?2004h> 
[?2004l[?2004h> # Load metadata (region_id -> region name mapping)
[?2004l[?2004h> with open(META_PATH, "r") as f:
[?2004l[?2004h>     metadata = json.load(f)
[?2004l[?2004h> 
[?2004l[?2004h> # Read and filter CSV (exclude anything before 2021)
[?2004l[?2004h> records = []
[?2004l[?2004h> with open(CSV_PATH, "r") as f:
[?2004l[?2004h>     reader = csv.DictReader(f)
[?2004l[?2004h>     for row in reader:
[?2004l[?2004h>         year = int(row["year"])
[?2004l[?2004h>         if year < 2021:
[?2004l[?2004h>             continue
[?2004l[?2004h>         region_id = str(row["region_id"])
[?2004l[?2004h>         region_name = metadata[region_id]
[?2004l[?2004h>         temperature = float(row["temperature"])
[?2004l[?2004h>         records.append({
[?2004l[?2004h>             "region": region_name,
[?2004l[?2004h>             "temperature": temperature,
[?2004l[?2004h>             "year": year
[?2004l[?2004h>         })
[?2004l[?2004h> 
[?2004l[?2004h> # Write cleaned.json
[?2004l[?2004h> with open(CLEANED_PATH, "w") as f:
[?2004l[?2004h>     json.dump(records, f, indent=2)
[?2004l[?2004h> print(f"Wrote {CLEANED_PATH} ({len(records)} records)")
[?2004l[?2004h> 
[?2004l[?2004h> # Compute average temperatures per region
[?2004l[?2004h> from collections import defaultdict
[?2004l[?2004h> temp_sums = defaultdict(float)
[?2004l[?2004h> temp_counts = defaultdict(int)
[?2004l[?2004h> for rec in records:
[?2004l[?2004h>     temp_sums[rec["region"]] += rec["temperature"]
[?2004l[?2004h>     temp_counts[rec["region"]] += 1
[?2004l[?2004h> 
[?2004l[?2004h> trends = {}
[?2004l[?2004h> for region in temp_sums:
[?2004l[?2004h>     trends[region] = temp_sums[region] / temp_counts[region]
[?2004l[?2004h> 
[?2004l[?2004h> # Write trends.json
[?2004l[?2004h> with open(TRENDS_PATH, "w") as f:
[?2004l[?2004h>     json.dump(trends, f, indent=2)
[?2004l[?2004h> print(f"Wrote {TRENDS_PATH}")
[?2004l[?2004h> 
[?2004l[?2004h> # Generate Graphviz directed graph
[?2004l[?2004h> os.makedirs(OUTPUT_DIR, exist_ok=True)
[?2004l[?2004h> dot = graphviz.Digraph("climate_graph", format="png")
[?2004l[?2004h> dot.attr(rankdir="LR")
[?2004l[?2004h> 
[?2004l[?2004h> for region, avg_temp in trends.items():
[?2004l[?2004h>     avg_label = f"{avg_temp:.1f}°C"
[?2004l[?2004h>     dot.node(region, region)
[?2004l[?2004h>     dot.node(avg_label, avg_label)
[?2004l[?2004h>     dot.edge(region, avg_label)
[?2004l[?2004h> 
