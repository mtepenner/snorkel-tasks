[90.745729, "o", "\u001b[?2004h> "]
[90.745817, "o", "        if year < 2021:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.745868, "o", "            continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.746149, "o", "        region_id = str(row[\"region_id\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.746276, "o", "        region_name = metadata[region_id]\r\n\u001b[?2004l\r\u001b[?2004h>         temperature = float(row[\"temperature\"])\r\n\u001b[?2004l\r\u001b[?2004h>         records.append({\r\n\u001b[?2004l\r\u001b[?2004h>             \"region\": region_name,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.746336, "o", "            \"temperature\": temperature,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.74639, "o", "            \"year\": year\r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.74659, "o", "        })\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Write cleaned.json\r\n\u001b[?2004l\r\u001b[?2004h> with open(CLEANED_PATH, \"w\") as f:\r\n\u001b[?2004l\r"]
[90.746721, "o", "\u001b[?2004h>     json.dump(records, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h"]
[90.746925, "o", "> print(f\"Wrote {CLEANED_PATH} ({len(records)} records)\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[90.747099, "o", "\u001b[?2004h> # Compute average temperatures per region\r\n\u001b[?2004l\r\u001b[?2004h> temp_sums = defaultdict(float)\r\n\u001b[?2004l\r\u001b[?2004h> temp_counts = defaultdict(int)\r\n\u001b[?2004l\r\u001b[?2004h> for rec in records:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.747176, "o", "    temp_sums[rec[\"region\"]] += rec[\"temperature\"]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.747201, "o", "    temp_counts[rec[\"region\"]] += 1\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.747363, "o", "trends = {}\r\n\u001b[?2004l\r\u001b[?2004h> for region in temp_sums:\r\n\u001b[?2004l\r\u001b[?2004h>     trends[region] = temp_sums[region] / temp_counts[region]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[90.747532, "o", "\u001b[?2004h> # Write trends.json\r\n\u001b[?2004l\r\u001b[?2004h> with open(TRENDS_PATH, \"w\") as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.747585, "o", "    json.dump(trends, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.747825, "o", "print(f\"Wrote {TRENDS_PATH}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.748065, "o", "# Generate Graphviz directed graph\r\n\u001b[?2004l\r\u001b[?2004h> os.makedirs(OUTPUT_DIR, exist_ok=True)\r\n\u001b[?2004l\r\u001b[?2004h> dot = graphviz.Digraph(\"climate_graph\", format=\"png\")\r\n\u001b[?2004l\r\u001b[?2004h> dot.attr(rankdir=\"LR\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.748124, "o", "for region, avg_temp in trends.items():\r\n\u001b[?2004l\r\u001b[?2004h>     avg_label = f\"{avg_temp:.1f}\\u00b0C\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.748293, "o", "    dot.node(region, region)\r\n\u001b[?2004l\r\u001b[?2004h>     dot.node(avg_label, avg_label)\r\n\u001b[?2004l\r\u001b[?2004h>     dot.edge(region, avg_label)\r\n\u001b[?2004l\r\u001b[?2004h"]
[90.748552, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> # Save the .gv source file explicitly\r\n\u001b[?2004l\r\u001b[?2004h> gv_path = os.path.join(OUTPUT_DIR, \"climate_graph.gv\")\r\n\u001b[?2004l\r\u001b[?2004h> dot.save(gv_path)\r\n\u001b[?2004l\r\u001b[?2004h"]
[90.748731, "o", "> print(f\"Wrote {gv_path}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Render to output/climate_graph.png\r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.748943, "o", "png_path = dot.render(filename=os.path.join(OUTPUT_DIR, \"climate_graph.gv\"), cleanup=False)\r\n\u001b[?2004l\r"]
[90.749078, "o", "\u001b[?2004h> print(f\"Wrote {png_path}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.749147, "o", "# Rename rendered file from climate_graph.gv.png to climate_graph.png\r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.749382, "o", "final_png = os.path.join(OUTPUT_DIR, \"climate_graph.png\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.749471, "o", "if png_path != final_png:\r\n\u001b[?2004l\r\u001b[?2004h>     os.replace(png_path, final_png)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> print(\"Done!\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.749513, "o", "PYEOF\r\n\u001b[?2004l\r"]
[90.750932, "o", "\u001b[?2004hroot@ab385bf0f4c5:/app/workspace# "]
[91.281053, "i", "python3 /app/workspace/src/analyzer.py\n"]
[91.281481, "o", "python3 /app/workspace/src/analyzer.py\r\n\u001b[?2004l\r"]
[91.321599, "o", "Wrote /app/workspace/data/cleaned.json (2 records)\r\nWrote /app/workspace/data/trends.json\r\n"]
[91.32185, "o", "Wrote /app/workspace/output/climate_graph.gv\r\n"]
[91.335041, "o", "Wrote /app/workspace/output/climate_graph.gv.png\r\n"]
[91.335191, "o", "Done!\r\n"]
[91.340747, "o", "\u001b[?2004hroot@ab385bf0f4c5:/app/workspace# "]
