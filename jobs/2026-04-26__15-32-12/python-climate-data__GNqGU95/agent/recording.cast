[57.952878, "i", "cat > /app/workspace/src/analyzer.py << 'PYEOF'\nimport csv\nimport json\nimport os\nimport graphviz\n\n# Paths\nBASE = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))\nCSV_PATH = os.path.join(BASE, \"data\", \"climate.csv\")\nMETA_PATH = os.path.join(BASE, \"data\", \"metadata.json\")\nCLEANED_PATH = os.path.join(BASE, \"data\", \"cleaned.json\")\nTRENDS_PATH = os.path.join(BASE, \"data\", \"trends.json\")\nOUTPUT_DIR = os.path.join(BASE, \"output\")\n\n# Load metadata (region_id -> region name mapping)\nwith open(META_PATH, \"r\") as f:\n    metadata = json.load(f)\n\n# Read and filter CSV (exclude anything before 2021)\nrecords = []\nwith open(CSV_PATH, \"r\") as f:\n    reader = csv.DictReader(f)\n    for row in reader:\n        year = int(row[\"year\"])\n        if year < 2021:\n            continue\n        region_id = str(row[\"region_id\"])\n        region_name = metadata[region_id]\n        temperature = float(row[\"temperature\"])\n        records.append({\n            \"region\": region_name,\n            \"temperature\": temperature,\n            \"year\": year\n        })\n\n# Write cleaned.json\nwith open(CLEANED_PATH, \"w\") as f:\n    json.dump(records, f, indent=2)\nprint(f\"Wrote {CLEANED_PATH} ({len(records)} records)\")\n\n# Compute average temperatures per region\nfrom collections import defaultdict\ntemp_sums = defaultdict(float)\ntemp_counts = defaultdict(int)\nfor rec in records:\n    temp_sums[rec[\"region\"]] += rec[\"temperature\"]\n    temp_counts[rec[\"region\"]] += 1\n\ntrends = {}\nfor region in temp_sums:\n    trends[region] = temp_sums[region] / temp_counts[region]\n\n# Write trends.json\nwith open(TRENDS_PATH, \"w\") as f:\n    json.dump(trends, f, indent=2)\nprint(f\"Wrote {TRENDS_PATH}\")\n\n# Generate Graphviz directed graph\nos.makedirs(OUTPUT_DIR, exist_ok=True)\ndot = graphviz.Digraph(\"climate_graph\", format=\"png\")\ndot.attr(rankdir=\"LR\")\n\nfor region, avg_temp in trends.items():\n    avg_label = f\"{avg_temp:.1f}°C\"\n    dot.node(region, region)\n    dot.node(avg_label, avg_label)\n    dot.edge(region, avg_label)\n\n# Render to output/climate_graph.png (also saves .gv source)\ngv_path = os.path.join(OUTPUT_DIR, \"climate_graph\")\ndot.render(gv_path, cleanup=False)\nprint(f\"Wrote {gv_path}.gv and {gv_path}.png\")\n\nprint(\"Done!\")\nPYEOF\n"]
