[45.773586, "i", "yle citations like [1], [42]\n      const m = (text || \"\").match(/\\[\\d+\\]/g);\n      return m ? m.length : 0;\n    }\n\n    function tokenizeWords(text) {\n      // Keep it simple + consistent: words are A-Z sequences with optional apostrophes\n      const m = (text || \"\").toLowerCase().match(/[a-z]+(?:'[a-z]+)?/g);\n      return m || [];\n    }\n\n    function keywordStats(text) {\n      const words = tokenizeWords(text);\n      const totalWords = words.length;\n      const counts = { quantum: 0, entanglement: 0 };\n      for (const w of words) {\n        if (w === \"quantum\") counts.quantum++;\n        if (w === \"entanglement\") counts.entanglement++;\n      }\n      const density = (count) => {\n        if (!totalWords) return 0;\n        return Number((count / totalWords).toFixed(3));\n      };\n      return {\n        totalWords,\n        keywordDensity: {\n          quantum: { count: counts.quantum, density: density(counts.quantum) },\n          entanglement: { count: counts.entanglement, density: density(counts.entanglement) }\n   "]
