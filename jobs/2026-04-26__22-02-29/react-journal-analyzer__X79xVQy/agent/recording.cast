[45.773926, "i", "     }\n      };\n    }\n\n    function splitIntoSentences(block) {\n      // Lightweight sentence splitting: end punctuation followed by whitespace/newline.\n      const cleaned = (block || \"\").replace(/\\s+/g, \" \").trim();\n      if (!cleaned) return [];\n      // Preserve the punctuation.\n      const parts = cleaned.split(/(?<=[.!?])\\s+/);\n      return parts.map(s => s.trim()).filter(Boolean);\n    }\n\n    function summarizeMarkdown(mdText) {\n      const text = normalizeWhitespace(mdText);\n      const lines = text.split(\"\\n\");\n\n      const sections = [];\n      let current = null;\n\n      const pushCurrent = () => {\n        if (current) sections.push(current);\n      };\n\n      for (let i = 0; i < lines.length; i++) {\n        const line = lines[i];\n        const headerMatch = line.match(/^\\s*#+\\s+(.*)\\s*$/);\n        if (headerMatch) {\n          pushCurrent();\n          current = { title: headerMatch[1].trim(), bodyLines: [] };\n        } else {\n          if (!current) {\n            // content before any header goes into a"]
