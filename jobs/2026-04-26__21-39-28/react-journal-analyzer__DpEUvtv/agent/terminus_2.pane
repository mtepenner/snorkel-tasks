[?2004l[?2004h>     async function extractPdfText(arrayBuffer) {
[?2004l[?2004h>       const pdf = await window.pdfjsLib.getDocument({ data: arrayBuffer }).promise;
[?2004l[?2004h>       const pageTexts = [];
[?2004l[?2004h>       for (let p = 1; p <= pdf.numPages; p++) {
[?2004l[?2004h>         const page = await pdf.getPage(p);
[?2004l[?2004h>         const content = await page.getTextContent();
[?2004l[?2004h>         // Join items with spaces; also add newlines when Y position decreases significantly.
[?2004l[?2004h>         // Simple approach: keep in reading order as provided.
[?2004l[?2004h>         const strings = content.items.map(it => (it.str || "").trim()).filter(Boolean);
[?2004l[?2004h>         pageTexts.push(strings.join(" "));
[?2004l[?2004h>       }
[?2004l[?2004h>       return pageTexts.join("\n\n");
[?2004l[?2004h>     }
