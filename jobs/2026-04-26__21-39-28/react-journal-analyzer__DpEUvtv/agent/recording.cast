[47.589112, "o", "\u001b[?2004h> "]
[47.589144, "i", "\"secBody\">{s.summary || \"(no summary found)\"}</div>\n                    </div>\n                  ))\n                ) : (\n                  <div className=\"small\">No summaries yet. Upload a file to generate section summaries.</div>\n                )}\n              </div>\n            </div>\n\n            <div className=\"card\" style={{gridColumn: \"1 / -1\"}}>\n              <h2>Machine-readable analysis (for tests)</h2>\n              <pre id=\"analysis-output\">{analysisJson}</pre>\n              <div className=\"hint\">The JSON above mirrors the dashboard data.</div>\n            </div>\n          </div>\n        </div>\n      );\n    }\n\n    ReactDOM.createRoot(document.getElementById('root')).render(<App />);\n  </script>\n</body>\n</html>\nHTML\n"]
