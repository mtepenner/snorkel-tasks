[47.587678, "i", "ut[type=file] { color: var(--muted); }\n    .grid { display:grid; grid-template-columns: 1fr 1fr; gap:12px; }\n    @media (max-width: 900px){ .grid{ grid-template-columns: 1fr; } }\n    .kpi { display:flex; gap:14px; flex-wrap:wrap; }\n    .kpi > div { min-width: 170px; }\n    .big { font-size: 22px; font-weight: 700; color: var(--text); }\n    .small { font-size: 12px; color: var(--muted); }\n    .list { display:flex; flex-direction:column; gap:10px; }\n    .sec { border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; padding: 10px; background: rgba(255,255,255,0.02); }\n    .secTitle { font-weight: 700; margin-bottom: 6px; }\n    .secBody { color: var(--muted); font-size: 13px; white-space: pre-wrap; }\n    pre { margin:0; background: #070b14; color: #d7e2ff; border-radius: 10px; padding: 12px; overflow:auto; border: 1px solid rgba(255,255,255,0.08); }\n    .hint { font-size: 12px; color: var(--muted); margin-top: 6px; }\n    .err { color: var(--danger); }\n    a { color: var(--accent); }\n  </style>\n</head>\n<body"]
[47.587687, "i", ">\n  <div id=\"root\"></div>\n\n  <!-- React + Babel (no build pipeline) -->\n  <script crossorigin src=\"https://unpkg.com/react@18/umd/react.development.js\"></script>\n  <script crossorigin src=\"https://unpkg.com/react-dom@18/umd/react-dom.development.js\"></script>\n  <script src=\"https://unpkg.com/@babel/standalone/babel.min.js\"></script>\n\n  <!-- PDF.js for client-side PDF text extraction -->\n  <script src=\"https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.2.67/pdf.min.js\"></script>\n\n  <script type=\"text/babel\">\n    const { useEffect, useMemo, useState } = React;\n\n    // pdf.js worker setup\n    if (window.pdfjsLib) {\n      // Use a matching worker from CDN\n      window.pdfjsLib.GlobalWorkerOptions.workerSrc = \"https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.2.67/pdf.worker.min.js\";\n    }\n\n    function safeLower(s){ return (s || \"\").toLowerCase(); }\n\n    function countBracketCitations(text) {\n      // Bracket style citations: [1], [42] etc. (digits only inside brackets)\n      const m = (text || \"\").match(/\\[(\\d+)\\]/g)"]
[47.587691, "i", ";\n      return m ? m.length : 0;\n    }\n\n    function tokenizeWords(text) {\n      // Keep it simple & robust: letters/numbers/apostrophes; split on non-word.\n      // Counts total words for density.\n      const normalized = (text || \"\").replace(/\\u00A0/g, \" \");\n      const tokens = normalized.match(/[A-Za-z0-9']+/g);\n      return tokens ? tokens : [];\n    }\n\n    function countKeyword(tokens, keyword) {\n      const k = safeLower(keyword);\n      let c = 0;\n      for (const t of tokens) {\n        if (safeLower(t) === k) c++;\n      }\n      return c;\n    }\n\n    function round3(x) {\n      return Math.round(x * 1000) / 1000;\n    }\n\n    function firstNonEmptySentence(text) {\n      const t = (text || \"\").replace(/\\s+/g, \" \").trim();\n      if (!t) return \"\";\n      // Try to pick first sentence end. If none, return whole line chunk.\n      const m = t.match(/^(.+?[\\.\\!\\?])(\\s|$)/);\n      return m ? m[1].trim() : t;\n    }\n\n    function analyzeCommon(text) {\n      const citations = countBracketCitations(text);\n      const t"]
[47.587702, "i", "okens = tokenizeWords(text);\n      const totalWords = tokens.length;\n      const quantumCount = countKeyword(tokens, \"quantum\");\n      const entanglementCount = countKeyword(tokens, \"entanglement\");\n      const quantumDensity = totalWords ? round3(quantumCount / totalWords) : 0;\n      const entanglementDensity = totalWords ? round3(entanglementCount / totalWords) : 0;\n\n      return {\n        citations,\n        totalWords,\n        keywords: {\n          quantum: { count: quantumCount, density: quantumDensity },\n          entanglement: { count: entanglementCount, density: entanglementDensity },\n        }\n      };\n    }\n\n    function analyzeMarkdown(mdText) {\n      const lines = (mdText || \"\").split(/\\r?\\n/);\n      const sections = [];\n      let currentTitle = \"(untitled)\";\n      let buffer = [];\n\n      function flush() {\n        const body = buffer.join(\"\\n\");\n        const summary = firstNonEmptySentence(body);\n        if (currentTitle || summary) {\n          sections.push({ title: currentTitle || \"(untitled)\","]
[47.587822, "i", " summary: summary || \"\" });\n        }\n        buffer = [];\n      }\n\n      let sawAnyHeader = false;\n\n      for (const line of lines) {\n        const headerMatch = line.match(/^\\s*#+\\s*(.+?)\\s*$/);\n        if (headerMatch) {\n          if (sawAnyHeader || buffer.join(\"\\n\").trim()) flush();\n          sawAnyHeader = true;\n          currentTitle = headerMatch[1];\n          buffer = [];\n        } else {\n          buffer.push(line);\n        }\n      }\n      // flush last\n      if (sawAnyHeader || buffer.join(\"\\n\").trim()) flush();\n\n      const common = analyzeCommon(mdText);\n      return {\n        fileType: \"markdown\",\n        ...common,\n        summaries: sections\n      };\n    }\n\n    function isLikelyHeadingLine(line) {\n      const t = (line || \"\").trim();\n      if (!t) return false;\n      // Heuristics for PDF extracted text: headings often short and mostly Title Case/Upper.\n      const words = t.split(/\\s+/);\n      if (words.length > 12) return false;\n      if (t.length < 3) return false;\n      const letters = (t"]
