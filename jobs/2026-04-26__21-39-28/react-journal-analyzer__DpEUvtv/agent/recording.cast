[61.341475, "i", "python3 - <<'PY'\nfrom pathlib import Path\np=Path('/app/index.html')\ntext=p.read_text(encoding='utf-8', errors='replace')\nprint('lines', text.count('\\n')+1)\n# quick sanity checks\nchecks = {\n  'has_root_div': '<div id=\"root\"></div>' in text,\n  'has_babel': 'babel.min.js' in text,\n  'has_react': 'react@18' in text,\n  'has_reactdom': 'react-dom@18' in text,\n  'has_pdfjs': 'pdf.min.js' in text,\n  'has_analysis_pre': 'id=\"analysis-output\"' in text,\n}\nprint(checks)\n# look for heredoc/prompt artifacts that sometimes get inserted\nsuspects = ['ntum>', 's>', 'if (sa>', 'y tiny s>', 'ty sum>', 'rn {', '.>', '.</>']\nfound = {s: (s in text) for s in suspects}\nprint('suspects_found', {k:v for k,v in found.items() if v})\nPY\n"]
[61.34172, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r"]
[61.341894, "o", "\u001b[?2004h> from pathlib import Path\r\n\u001b[?2004l\r\u001b[?2004h> p=Path('/app/index.html')\r\n\u001b[?2004l\r\u001b[?2004h> text=p.read_text(encoding='utf-8', errors='replace')\r\n\u001b[?2004l\r\u001b[?2004h> print('lines', text.count('\\n')+1)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.342036, "o", "# quick sanity checks\r\n\u001b[?2004l\r\u001b[?2004h> checks = {\r\n\u001b[?2004l\r\u001b[?2004h>   'has_root_div': '<div id=\"root\"></div>' in text,\r\n\u001b[?2004l\r\u001b[?2004h> "]
