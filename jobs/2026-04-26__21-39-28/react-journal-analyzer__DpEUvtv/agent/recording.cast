[47.588025, "i", ".match(/[A-Za-z]/g) || []).length;\n      if (letters < 3) return false;\n      // No ending punctuation typical of body.\n      if (/[\\.!\\?]\\s*$/.test(t)) return false;\n      // Contains many uppercase letters relative to letters.\n      const upp = (t.match(/[A-Z]/g) || []).length;\n      const ratio = letters ? (upp / letters) : 0;\n      // Or looks like numbered section\n      const numbered = /^\\s*(\\d+|\\d+\\.\\d+|[IVX]+)\\.?\\s+\\S+/.test(t);\n      return numbered || ratio > 0.55;\n    }\n\n    function analyzePdfText(extractedText) {\n      const text = extractedText || \"\";\n      const lines = text.split(/\\r?\\n/).map(l => l.replace(/\\s+$/g, \"\"));\n\n      const sections = [];\n      let currentTitle = \"(document)\";\n      let buffer = [];\n\n      function flush() {\n        const body = buffer.join(\"\\n\");\n        const summary = firstNonEmptySentence(body);\n        sections.push({ title: currentTitle || \"(untitled)\", summary: summary || \"\" });\n        buffer = [];\n      }\n\n      let sawHeading = false;\n\n      for (let i = 0"]
