[61.621677, "o", "<!doctype html>\r\n<html lang=\"en\">\r\n<head>\r\n  <meta charset=\"UTF-8\" />\r\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\r\n  <title>Client-Side Journal Analyzer</title>\r\n  <style>\r\n    :root { --bg:#0b1220; --panel:#101a33; --text:#e7ecff; --muted:#a9b4d6; --accent:#6aa6ff; --danger:#ff6a6a; }\r\n    body { margin:0; font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif; background: var(--bg); color: var(--text); }\r\n    .wrap { max-width: 1100px; margin: 0 auto; padding: 18px; }\r\n    h1 { font-size: 18px; margin: 0 0 10px; }\r\n    .row { display:flex; gap:12px; flex-wrap:wrap; }\r\n    .card { background: var(--panel); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; padding: 12px; }\r\n    .card h2 { font-size: 14px; margin: 0 0 8px; color: var(--muted); font-weight: 600; }\r\n    .top { align-items:center; justify-content:space-between; }\r\n    .status { color: var(--muted); font-size: 13px; }\r\n    .status strong { color: var(--text); }\r\n    input[type=file] "]
[61.621823, "o", "{ color: var(--muted); }\r\n    .grid { display:grid; grid-template-columns: 1fr 1fr; gap:12px; }\r\n    @media (max-width: 900px){ .grid{ grid-template-columns: 1fr; } }\r\n"]
