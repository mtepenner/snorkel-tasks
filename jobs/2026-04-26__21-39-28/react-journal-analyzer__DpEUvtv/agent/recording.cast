[47.588422, "i", "function extractPdfText(arrayBuffer) {\n      const pdf = await window.pdfjsLib.getDocument({ data: arrayBuffer }).promise;\n      const pageTexts = [];\n      for (let p = 1; p <= pdf.numPages; p++) {\n        const page = await pdf.getPage(p);\n        const content = await page.getTextContent();\n        // Join items with spaces; also add newlines when Y position decreases significantly.\n        // Simple approach: keep in reading order as provided.\n        const strings = content.items.map(it => (it.str || \"\").trim()).filter(Boolean);\n        pageTexts.push(strings.join(\" \"));\n      }\n      return pageTexts.join(\"\\n\\n\");\n    }\n\n    function App() {\n      const [status, setStatus] = useState(\"Select a .md/.markdown/.pdf file to analyze.\");\n      const [error, setError] = useState(\"\");\n      const [analysis, setAnalysis] = useState({\n        fileType: null,\n        citations: 0,\n        totalWords: 0,\n        keywords: {\n          quantum: { count: 0, density: 0 },\n          entanglement: { count: 0, density: 0 "]
[47.588467, "i", "}\n        },\n        summaries: []\n      });\n\n      const analysisJson = useMemo(() => {\n        // Keep machine-readable JSON always valid.\n        return JSON.stringify(analysis, null, 2);\n      }, [analysis]);\n\n      async function onPickFile(e) {\n        setError(\"\");\n        const file = e.target.files && e.target.files[0];\n        if (!file) return;\n\n        const name = file.name || \"\";\n        const lower = name.toLowerCase();\n        const isMd = lower.endsWith(\".md\") || lower.endsWith(\".markdown\");\n        const isPdf = lower.endsWith(\".pdf\");\n\n        if (!isMd && !isPdf) {\n          setError(\"Unsupported file type. Please select a .md, .markdown, or .pdf file.\");\n          setStatus(\"Idle\");\n          return;\n        }\n\n        try {\n          setStatus(`Loading: ${name}`);\n          if (isMd) {\n            const text = await file.text();\n            const a = analyzeMarkdown(text);\n            setAnalysis(a);\n            setStatus(`Analyzed Markdown: ${name}`);\n          } else {\n            if ("]
[47.588553, "i", "!window.pdfjsLib) {\n              throw new Error(\"pdf.js failed to load.\");\n            }\n            const buf = await file.arrayBuffer();\n            setStatus(`Extracting PDF text: ${name}`);\n            const text = await extractPdfText(buf);\n            const a = analyzePdfText(text);\n            setAnalysis(a);\n            setStatus(`Analyzed PDF: ${name}`);\n          }\n        } catch (err) {\n          setError(err && err.message ? err.message : String(err));\n          setStatus(\"Error\");\n        }\n      }\n\n      return (\n        <div className=\"wrap\">\n          <div className=\"row top\" style={{marginBottom: 12}}>\n            <div>\n              <h1>React Client-Side Journal Analyzer</h1>\n              <div className=\"status\">\n                <strong>Status:</strong> {status}{error ? <span className=\"err\"> — {error}</span> : null}\n              </div>\n            </div>\n            <div className=\"card\" style={{minWidth: 360}}>\n              <h2>Upload</h2>\n              <input\n                type="]
[47.588735, "i", "\"file\"\n                accept=\".md,.markdown,.pdf,application/pdf,text/markdown\"\n                onChange={onPickFile}\n              />\n              <div className=\"hint\">Analyzes immediately after load; runs entirely in-browser.</div>\n            </div>\n          </div>\n\n          <div className=\"grid\">\n            <div className=\"card\">\n              <h2>Citations</h2>\n              <div className=\"kpi\">\n                <div>\n                  <div className=\"big\">{analysis.citations}</div>\n                  <div className=\"small\">Bracket citations like [1], [42]</div>\n                </div>\n                <div>\n                  <div className=\"big\">{analysis.totalWords}</div>\n                  <div className=\"small\">Total words</div>\n                </div>\n                <div>\n                  <div className=\"big\">{analysis.fileType || \"—\"}</div>\n                  <div className=\"small\">File type</div>\n                </div>\n              </div>\n            </div>\n\n            <div className=\"card\">"]
[47.588885, "o", "  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\r\n\u001b[?2004l\r"]
