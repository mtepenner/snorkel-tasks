[47.630653, "o", "      const pageTexts = [];\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.6309, "o", "      for (let p = 1; p <= pdf.numPages; p++) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.631062, "o", "        const page = await pdf.getPage(p);\r\n\u001b[?2004l\r"]
[47.631107, "o", "\u001b[?2004h> "]
[47.631355, "o", "        const content = await page.getTextContent();\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.631729, "o", "        // Join items with spaces; also add newlines when Y position decreases significantly.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.631905, "o", "        // Simple approach: keep in reading order as provided.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.632281, "o", "        const strings = content.items.map(it => (it.str || \"\").trim()).filter(Boolean);\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.632313, "o", "> "]
[47.632498, "o", "        pageTexts.push(strings.join(\" \"));\r\n\u001b[?2004l\r\u001b[?2004h>       }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.632593, "o", "      return pageTexts.join(\"\\n\\n\");\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.632669, "o", "> "]
[47.632702, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.632708, "o", "> \r\n\u001b[?2004l\rr"]
[47.632789, "o", "\u001b[?2004h>     function App() {\r\n\u001b[?2004l\r"]
[47.632862, "o", "\u001b[?2004h> "]
[47.633635, "o", "      const [status, setStatus] = useState(\"Select a .md/.markdown/.pdf file to analyze.\");\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.633727, "o", "> "]
[47.633835, "o", "      const [error, setError] = useState(\"\");\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.633955, "o", "      const [analysis, setAnalysis] = useState({\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.634163, "o", "        fileType: null,\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.634198, "o", "> "]
[47.634397, "o", "        citations: 0,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.634491, "o", "        totalWords: 0,\r\n"]
[47.634559, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[47.634703, "o", "        keywords: {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.634879, "o", "          quantum: { count: 0, density: 0 },\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.635044, "o", "          entanglement: { count: 0, density: 0 }\r\n\u001b[?2004l\r\u001b[?2004h>         },\r\n\u001b[?2004l\r"]
[47.635219, "o", "\u001b[?2004h>         summaries: []\r\n\u001b[?2004l\r\u001b[?2004h>       });\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.635304, "o", "      const analysisJson = useMemo(() => {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.635422, "o", "        // Keep machine-readable JSON always valid.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.635588, "o", "        return JSON.stringify(analysis, null, 2);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.635701, "o", "      }, [analysis]);\r\n\u001b[?2004l\r"]
[47.635806, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.635904, "o", "      async function onPickFile(e) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.636, "o", "        setError(\"\");\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.636238, "o", "        const file = e.target.files && e.target.files[0];\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.636343, "o", "        if (!file) return;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.636363, "o", "\r\n\u001b[?2004l\r\r\n"]
[47.636429, "o", "\u001b[?2004h> "]
[47.636484, "o", "        const name = file.name || \"\";\r\n\u001b[?2004l\r"]
[47.63655, "o", "\u001b[?2004h> "]
[47.636589, "o", "        const lower = name.toLowerCase();\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.636981, "o", "        const isMd = lower.endsWith(\".md\") || lower.endsWith(\".markdown\");\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.637058, "o", "> "]
[47.637144, "o", "        const isPdf = lower.endsWith(\".pdf\");\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r.</\u001b[?2004h> "]
[47.637212, "o", "        if (!isMd && !isPdf) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.63739, "o", "          setError(\"Unsupported file type. Please select a .md, .markdown, or .pdf file.\");\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.637539, "o", "          setStatus(\"Idle\");\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.637567, "o", ">           return;\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.637715, "o", ">         }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.637847, "o", "\u001b[?2004h>         try {\r\n\u001b[?2004l\r\u001b[?2004h>           setStatus(`Loading: ${name}`);\r\n\u001b[?2004l\r\u001b[?2004h>           if (isMd) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.637912, "o", "            const text = await file.text();"]
[47.637952, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.638059, "o", "            const a = analyzeMarkdown(text);\r\n\u001b[?2004l\r\u001b[?2004h>             setAnalysis(a);\r\n\u001b[?2004l\r"]
[47.638143, "o", "\u001b[?2004h>             setStatus(`Analyzed Markdown: ${name}`);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.638173, "o", "          } else {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.638235, "o", "            if (!window.pdfjsLib) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.638337, "o", "              throw new Error(\"pdf.js failed to load.\");\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.638363, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.638518, "o", ">             const buf = await file.arrayBuffer();\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.638525, "o", "            setStatus(`Extracting PDF text: ${name}`);\r\n\u001b[?2004l\r"]
[47.638574, "o", "\u001b[?2004h> "]
[47.638605, "o", "            const text = await extractPdfText(buf);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.63869, "o", "            const a = analyzePdfText(text);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.638761, "o", "            setAnalysis(a);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.638842, "o", "            setStatus(`Analyzed PDF: ${name}`);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.638893, "o", "          }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.63896, "o", "        } catch (err) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.639035, "o", "          setError(err && err.message ? err.message : String(err));\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.639062, "o", "> "]
[47.639159, "o", "          setStatus(\"Error\");\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.639215, "o", "      }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.639268, "o", "\u001b[?2004h>       return (\r\n\u001b[?2004l\r\u001b[?2004h> "]
