[47.588285, "i", "; i < lines.length; i++) {\n        const line = (lines[i] || \"\").trim();\n        if (!line) {\n          buffer.push(\"\");\n          continue;\n        }\n        if (isLikelyHeadingLine(line)) {\n          if (sawHeading || buffer.join(\"\\n\").trim()) {\n            flush();\n          }\n          sawHeading = true;\n          currentTitle = line;\n          buffer = [];\n        } else {\n          buffer.push(line);\n        }\n      }\n\n      if (sawHeading || buffer.join(\"\\n\").trim()) flush();\n\n      // If heuristic produced too many tiny sections with empty summaries, collapse fallback.\n      const nonEmptySummaries = sections.filter(s => (s.summary || \"\").trim()).length;\n      let finalSections = sections;\n      if (sections.length > 25 && nonEmptySummaries < 3) {\n        finalSections = [{ title: \"(document)\", summary: firstNonEmptySentence(text) }];\n      }\n\n      const common = analyzeCommon(text);\n      return {\n        fileType: \"pdf\",\n        ...common,\n        summaries: finalSections\n      };\n    }\n\n    async "]
