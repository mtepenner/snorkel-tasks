Sending keys: ['cat > /app/index.html <<\'HTML\'\n<!doctype html>\n<html lang="en">\n<head>\n  <meta charset="UTF-8" />\n  <meta name="viewport" content="width=device-width, initial-scale=1.0" />\n  <title>Client-Side Journal Analyzer</title>\n  <style>\n    :root { --bg:#0b1220; --panel:#101a33; --text:#e7ecff; --muted:#a9b4d6; --accent:#6aa6ff; --danger:#ff6a6a; }\n    body { margin:0; font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif; background: var(--bg); color: var(--text); }\n    .wrap { max-width: 1100px; margin: 0 auto; padding: 18px; }\n    h1 { font-size: 18px; margin: 0 0 10px; }\n    .row { display:flex; gap:12px; flex-wrap:wrap; }\n    .card { background: var(--panel); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; padding: 12px; }\n    .card h2 { font-size: 14px; margin: 0 0 8px; color: var(--muted); font-weight: 600; }\n    .top { align-items:center; justify-content:space-between; }\n    .status { color: var(--muted); font-size: 13px; }\n    .status strong { color: var(--text); }\n    input[type=file] { color: var(--muted); }\n    .grid { display:grid; grid-template-columns: 1fr 1fr; gap:12px; }\n    @media (max-width: 900px){ .grid{ grid-template-columns: 1fr; } }\n    .kpi { display:flex; gap:14px; flex-wrap:wrap; }\n    .kpi > div { min-width: 170px; }\n    .big { font-size: 22px; font-weight: 700; color: var(--text); }\n    .small { font-size: 12px; color: var(--muted); }\n    .list { display:flex; flex-direction:column; gap:10px; }\n    .sec { border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; padding: 10px; background: rgba(255,255,255,0.02); }\n    .secTitle { font-weight: 700; margin-bottom: 6px; }\n    .secBody { color: var(--muted); font-size: 13px; white-space: pre-wrap; }\n    pre { margin:0; background: #070b14; color: #d7e2ff; border-radius: 10px; padding: 12px; overflow:auto; border: 1px solid rgba(255,255,255,0.08); }\n    .hint { font-size: 12px; color: var(--muted); margin-top: 6px; }\n    .err { color: var(--danger); }\n    a { color: var(--accent); }\n  </style>\n</head>\n<body>\n  <div id="root"></div>\n\n  <!-- React + Babel (no build pipeline) -->\n  <script crossorigin src="https://unpkg.com/react@18/umd/react.development.js"></script>\n  <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>\n  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>\n\n  <!-- PDF.js for client-side PDF text extraction -->\n  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.2.67/pdf.min.js"></script>\n\n  <script type="text/babel">\n    const { useEffect, useMemo, useState } = React;\n\n    // pdf.js worker setup\n    if (window.pdfjsLib) {\n      // Use a matching worker from CDN\n      window.pdfjsLib.GlobalWorkerOptions.workerSrc = "https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.2.67/pdf.worker.min.js";\n    }\n\n    function safeLower(s){ return (s || "").toLowerCase(); }\n\n    function countBracketCitations(text) {\n      // Bracket style citations: [1], [42] etc. (digits only inside brackets)\n      const m = (text || "").match(/\\[(\\d+)\\]/g);\n      return m ? m.length : 0;\n    }\n\n    function tokenizeWords(text) {\n      // Keep it simple & robust: letters/numbers/apostrophes; split on non-word.\n      // Counts total words for density.\n      const normalized = (text || "").replace(/\\u00A0/g, " ");\n      const tokens = normalized.match(/[A-Za-z0-9\']+/g);\n      return tokens ? tokens : [];\n    }\n\n    function countKeyword(tokens, keyword) {\n      const k = safeLower(keyword);\n      let c = 0;\n      for (const t of tokens) {\n        if (safeLower(t) === k) c++;\n      }\n      return c;\n    }\n\n    function round3(x) {\n      return Math.round(x * 1000) / 1000;\n    }\n\n    function firstNonEmptySentence(text) {\n      const t = (text || "").replace(/\\s+/g, " ").trim();\n      if (!t) return "";\n      // Try to pick first sentence end. If none, return whole line chunk.\n      const m = t.match(/^(.+?[\\.\\!\\?])(\\s|$)/);\n      return m ? m[1].trim() : t;\n    }\n\n    function analyzeCommon(text) {\n      const citations = countBracketCitations(text);\n      const tokens = tokenizeWords(text);\n      const totalWords = tokens.length;\n      const quantumCount = countKeyword(tokens, "quantum");\n      const entanglementCount = countKeyword(tokens, "entanglement");\n      const quantumDensity = totalWords ? round3(quantumCount / totalWords) : 0;\n      const entanglementDensity = totalWords ? round3(entanglementCount / totalWords) : 0;\n\n      return {\n        citations,\n        totalWords,\n        keywords: {\n          quantum: { count: quantumCount, density: quantumDensity },\n          entanglement: { count: entanglementCount, density: entanglementDensity },\n        }\n      };\n    }\n\n    function analyzeMarkdown(mdText) {\n      const lines = (mdText || "").split(/\\r?\\n/);\n      const sections = [];\n      let currentTitle = "(untitled)";\n      let buffer = [];\n\n      function flush() {\n        const body = buffer.join("\\n");\n        const summary = firstNonEmptySentence(body);\n        if (currentTitle || summary) {\n          sections.push({ title: currentTitle || "(untitled)", summary: summary || "" });\n        }\n        buffer = [];\n      }\n\n      let sawAnyHeader = false;\n\n      for (const line of lines) {\n        const headerMatch = line.match(/^\\s*#+\\s*(.+?)\\s*$/);\n        if (headerMatch) {\n          if (sawAnyHeader || buffer.join("\\n").trim()) flush();\n          sawAnyHeader = true;\n          currentTitle = headerMatch[1];\n          buffer = [];\n        } else {\n          buffer.push(line);\n        }\n      }\n      // flush last\n      if (sawAnyHeader || buffer.join("\\n").trim()) flush();\n\n      const common = analyzeCommon(mdText);\n      return {\n        fileType: "markdown",\n        ...common,\n        summaries: sections\n      };\n    }\n\n    function isLikelyHeadingLine(line) {\n      const t = (line || "").trim();\n      if (!t) return false;\n      // Heuristics for PDF extracted text: headings often short and mostly Title Case/Upper.\n      const words = t.split(/\\s+/);\n      if (words.length > 12) return false;\n      if (t.length < 3) return false;\n      const letters = (t.match(/[A-Za-z]/g) || []).length;\n      if (letters < 3) return false;\n      // No ending punctuation typical of body.\n      if (/[\\.!\\?]\\s*$/.test(t)) return false;\n      // Contains many uppercase letters relative to letters.\n      const upp = (t.match(/[A-Z]/g) || []).length;\n      const ratio = letters ? (upp / letters) : 0;\n      // Or looks like numbered section\n      const numbered = /^\\s*(\\d+|\\d+\\.\\d+|[IVX]+)\\.?\\s+\\S+/.test(t);\n      return numbered || ratio > 0.55;\n    }\n\n    function analyzePdfText(extractedText) {\n      const text = extractedText || "";\n      const lines = text.split(/\\r?\\n/).map(l => l.replace(/\\s+$/g, ""));\n\n      const sections = [];\n      let currentTitle = "(document)";\n      let buffer = [];\n\n      function flush() {\n        const body = buffer.join("\\n");\n        const summary = firstNonEmptySentence(body);\n        sections.push({ title: currentTitle || "(untitled)", summary: summary || "" });\n        buffer = [];\n      }\n\n      let sawHeading = false;\n\n      for (let i = 0; i < lines.length; i++) {\n        const line = (lines[i] || "").trim();\n        if (!line) {\n          buffer.push("");\n          continue;\n        }\n        if (isLikelyHeadingLine(line)) {\n          if (sawHeading || buffer.join("\\n").trim()) {\n            flush();\n          }\n          sawHeading = true;\n          currentTitle = line;\n          buffer = [];\n        } else {\n          buffer.push(line);\n        }\n      }\n\n      if (sawHeading || buffer.join("\\n").trim()) flush();\n\n      // If heuristic produced too many tiny sections with empty summaries, collapse fallback.\n      const nonEmptySummaries = sections.filter(s => (s.summary || "").trim()).length;\n      let finalSections = sections;\n      if (sections.length > 25 && nonEmptySummaries < 3) {\n        finalSections = [{ title: "(document)", summary: firstNonEmptySentence(text) }];\n      }\n\n      const common = analyzeCommon(text);\n      return {\n        fileType: "pdf",\n        ...common,\n        summaries: finalSections\n      };\n    }\n\n    async function extractPdfText(arrayBuffer) {\n      const pdf = await window.pdfjsLib.getDocument({ data: arrayBuffer }).promise;\n      const pageTexts = [];\n      for (let p = 1; p <= pdf.numPages; p++) {\n        const page = await pdf.getPage(p);\n        const content = await page.getTextContent();\n        // Join items with spaces; also add newlines when Y position decreases significantly.\n        // Simple approach: keep in reading order as provided.\n        const strings = content.items.map(it => (it.str || "").trim()).filter(Boolean);\n        pageTexts.push(strings.join(" "));\n      }\n      return pageTexts.join("\\n\\n");\n    }\n\n    function App() {\n      const [status, setStatus] = useState("Select a .md/.markdown/.pdf file to analyze.");\n      const [error, setError] = useState("");\n      const [analysis, setAnalysis] = useState({\n        fileType: null,\n        citations: 0,\n        totalWords: 0,\n        keywords: {\n          quantum: { count: 0, density: 0 },\n          entanglement: { count: 0, density: 0 }\n        },\n        summaries: []\n      });\n\n      const analysisJson = useMemo(() => {\n        // Keep machine-readable JSON always valid.\n        return JSON.stringify(analysis, null, 2);\n      }, [analysis]);\n\n      async function onPickFile(e) {\n        setError("");\n        const file = e.target.files && e.target.files[0];\n        if (!file) return;\n\n        const name = file.name || "";\n        const lower = name.toLowerCase();\n        const isMd = lower.endsWith(".md") || lower.endsWith(".markdown");\n        const isPdf = lower.endsWith(".pdf");\n\n        if (!isMd && !isPdf) {\n          setError("Unsupported file type. Please select a .md, .markdown, or .pdf file.");\n          setStatus("Idle");\n          return;\n        }\n\n        try {\n          setStatus(`Loading: ${name}`);\n          if (isMd) {\n            const text = await file.text();\n            const a = analyzeMarkdown(text);\n            setAnalysis(a);\n            setStatus(`Analyzed Markdown: ${name}`);\n          } else {\n            if (!window.pdfjsLib) {\n              throw new Error("pdf.js failed to load.");\n            }\n            const buf = await file.arrayBuffer();\n            setStatus(`Extracting PDF text: ${name}`);\n            const text = await extractPdfText(buf);\n            const a = analyzePdfText(text);\n            setAnalysis(a);\n            setStatus(`Analyzed PDF: ${name}`);\n          }\n        } catch (err) {\n          setError(err && err.message ? err.message : String(err));\n          setStatus("Error");\n        }\n      }\n\n      return (\n        <div className="wrap">\n          <div className="row top" style={{marginBottom: 12}}>\n            <div>\n              <h1>React Client-Side Journal Analyzer</h1>\n              <div className="status">\n                <strong>Status:</strong> {status}{error ? <span className="err"> — {error}</span> : null}\n              </div>\n            </div>\n            <div className="card" style={{minWidth: 360}}>\n              <h2>Upload</h2>\n              <input\n                type="file"\n                accept=".md,.markdown,.pdf,application/pdf,text/markdown"\n                onChange={onPickFile}\n              />\n              <div className="hint">Analyzes immediately after load; runs entirely in-browser.</div>\n            </div>\n          </div>\n\n          <div className="grid">\n            <div className="card">\n              <h2>Citations</h2>\n              <div className="kpi">\n                <div>\n                  <div className="big">{analysis.citations}</div>\n                  <div className="small">Bracket citations like [1], [42]</div>\n                </div>\n                <div>\n                  <div className="big">{analysis.totalWords}</div>\n                  <div className="small">Total words</div>\n                </div>\n                <div>\n                  <div className="big">{analysis.fileType || "—"}</div>\n                  <div className="small">File type</div>\n                </div>\n              </div>\n            </div>\n\n            <div className="card">\n              <h2>Keywords (frequency &amp; density)</h2>\n              <div className="kpi">\n                <div>\n                  <div className="big">{analysis.keywords.quantum.count}</div>\n                  <div className="small">"quantum" density: {analysis.keywords.quantum.density}</div>\n                </div>\n                <div>\n                  <div className="big">{analysis.keywords.entanglement.count}</div>\n                  <div className="small">"entanglement" density: {analysis.keywords.entanglement.density}</div>\n                </div>\n              </div>\n            </div>\n\n            <div className="card" style={{gridColumn: "1 / -1"}}>\n              <h2>Section summaries</h2>\n              <div className="list">\n                {analysis.summaries && analysis.summaries.length ? (\n                  analysis.summaries.map((s, idx) => (\n                    <div className="sec" key={idx}>\n                      <div className="secTitle">{s.title}</div>\n                      <div className="secBody">{s.summary || "(no summary found)"}</div>\n                    </div>\n                  ))\n                ) : (\n                  <div className="small">No summaries yet. Upload a file to generate section summaries.</div>\n                )}\n              </div>\n            </div>\n\n            <div className="card" style={{gridColumn: "1 / -1"}}>\n              <h2>Machine-readable analysis (for tests)</h2>\n              <pre id="analysis-output">{analysisJson}</pre>\n              <div className="hint">The JSON above mirrors the dashboard data.</div>\n            </div>\n          </div>\n        </div>\n      );\n    }\n\n    ReactDOM.createRoot(document.getElementById(\'root\')).render(<App />);\n  </script>\n</body>\n</html>\nHTML\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
