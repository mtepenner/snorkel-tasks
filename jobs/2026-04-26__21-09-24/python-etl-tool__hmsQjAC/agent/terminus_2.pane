[?2004l[?2004h>         try:
[?2004l[?2004h>             cur = conn.cursor()
[?2004l[?2004h>             cur.execute("CREATE TABLE IF NOT EXISTS records (id INTEGER PRIMARY KEY, data TEXT)")
[?2004l[?2004h>             cur.execute("DELETE FROM records")
[?2004l[?2004h>             for rec in records:
[?2004l[?2004h>                 cur.execute("INSERT INTO records (data) VALUES (?)", (json.dumps(rec),))
