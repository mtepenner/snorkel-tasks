[?2004l[?2004h> 
[?2004l[?2004h> def run_etl() -> None:
[?2004l[?2004h>     try:
[?2004l[?2004h>         os.makedirs(os.path.dirname(OUTPUT_JSON), exist_ok=True)
[?2004l[?2004h> 
