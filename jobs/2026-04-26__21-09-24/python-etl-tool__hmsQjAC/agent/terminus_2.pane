[?2004l[?2004h>                 with open(path, newline="", encoding="utf-8") as f:
[?2004l[?2004h>                     reader = csv.DictReader(f)
[?2004l[?2004h>                     for row in reader:
[?2004l[?2004h>                         # Preserve all columns; ensure every value is a string
