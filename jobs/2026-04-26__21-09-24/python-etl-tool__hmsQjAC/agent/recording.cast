[22.423788, "i", "cat > /app/workspace/src/templates/index.html <<'HTML'\n<!doctype html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>ETL Dashboard</title>\n</head>\n<body>\n  <h1>ETL Dashboard</h1>\n\n  <button id=\"triggerBtn\" type=\"button\">Trigger ETL</button>\n\n  <p>\n    <a href=\"/download\">Download output.json</a>\n  </p>\n\n  <h2>Logs</h2>\n  <pre id=\"logs\" style=\"white-space: pre-wrap;\"></pre>\n\n  <script>\n    async function fetchLogs() {\n      const res = await fetch('/logs');\n      const text = await res.text();\n      document.getElementById('logs').textContent = text;\n    }\n\n    async function triggerETL() {\n      const btn = document.getElementById('triggerBtn');\n      btn.disabled = true;\n      try {\n        await fetch('/trigger', { method: 'POST' });\n      } finally {\n        btn.disabled = false;\n        await fetchLogs();\n      }\n    }\n\n    window.addEventListener('DOMContentLoaded', () => {\n      document.getElementById('triggerBtn').a"]
[22.4239, "i", "ddEventListener('click', triggerETL);\n      fetchLogs();\n    });\n  </script>\n</body>\n</html>\nHTML\n"]
