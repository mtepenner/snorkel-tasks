Sending keys: ['cat > /app/index.html <<\'EOF\'\n<!doctype html>\n<html lang="en">\n<head>\n  <meta charset="UTF-8" />\n  <meta name="viewport" content="width=device-width, initial-scale=1.0" />\n  <title>Journal Analyzer</title>\n  <style>\n    body { font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif; margin: 24px; color: #111; }\n    .container { max-width: 980px; margin: 0 auto; }\n    h1 { margin: 0 0 16px; font-size: 22px; }\n    .panel { border: 1px solid #ddd; border-radius: 10px; padding: 16px; margin: 14px 0; }\n    .row { display: flex; gap: 16px; flex-wrap: wrap; }\n    .col { flex: 1 1 280px; }\n    label { display: inline-block; font-weight: 600; margin-bottom: 6px; }\n    input[type=file] { width: 100%; }\n    .status { margin-top: 8px; color: #333; }\n    .muted { color: #666; }\n    .kpi { font-size: 26px; font-weight: 700; }\n    .kpi-sub { font-size: 12px; color: #555; }\n    .summary-item { padding: 10px 0; border-bottom: 1px solid #eee; }\n    .summary-item:last-child { border-bottom: none; }\n    .summary-title { font-weight: 700; }\n    pre { background: #0b1020; color: #e6edf3; padding: 12px; border-radius: 10px; overflow: auto; }\n    code { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace; }\n  </style>\n</head>\n<body>\n  <div class="container">\n    <h1>Client-Side Journal Analyzer</h1>\n    <div id="root"></div>\n  </div>\n\n  <!-- React + Babel (no build pipeline) -->\n  <script crossorigin src="https://unpkg.com/react@18/umd/react.development.js"></script>\n  <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>\n  <script src="https://unpkg.com/babel-standalone@6/babel.min.js"></script>\n\n  <!-- PDF.js (for PDF text extraction) -->\n  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.2.67/pdf.min.js"></script>\n\n  <script type="text/babel">\n    const { useEffect, useMemo, useState } = React;\n\n    function round3(n) {\n      return Math.round(n * 1000) / 1000;\n    }\n\n    function normalizeWhitespace(s) {\n      return (s || "").replace(/\\r\\n/g, "\\n").replace(/\\t/g, " ");\n    }\n\n    function tokenizeWords(text) {\n      // Words: sequences of letters/numbers incl apostrophes; keeps it simple and deterministic.\n      const matches = (text || "").match(/[A-Za-z0-9\']+/g);\n      return matches ? matches : [];\n    }\n\n    function countRegexMatches(text, re) {\n      if (!text) return 0;\n      const m = text.match(re);\n      return m ? m.length : 0;\n    }\n\n    function countKeyword(words, keywordLower) {\n      let c = 0;\n      for (const w of words) {\n        if (w.toLowerCase() === keywordLower) c++;\n      }\n      return c;\n    }\n\n    function firstSentence(text) {\n      const t = (text || "").trim();\n      if (!t) return "";\n      // First sentence split on . ! ? followed by whitespace/newline/end.\n      const m = t.match(/^[\\s\\S]*?[.!?](?:\\s|$)/);\n      if (m) return m[0].trim();\n      // Fallback: first non-empty line\n      const line = t.split(/\\n+/).map(s => s.trim()).find(Boolean);\n      return (line || t).trim();\n    }\n\n    function summarizeFromMarkdown(mdText) {\n      const text = normalizeWhitespace(mdText);\n      const lines = text.split("\\n");\n\n      const sections = [];\n      let current = null;\n      let buffer = [];\n\n      function flush() {\n        if (!current) return;\n        const body = buffer.join("\\n").trim();\n        const summary = firstSentence(body.replace(/\\n+/g, "\\n"));\n        sections.push({ title: current, summary: summary || "" });\n      }\n\n      for (let i = 0; i < lines.length; i++) {\n        const line = lines[i];\n        const headerMatch = line.match(/^\\s*#+\\s+(.*)\\s*$/);\n        if (headerMatch) {\n          flush();\n          current = headerMatch[1].trim() || "(Untitled)";\n          buffer = [];\n        } else {\n          if (current) buffer.push(line);\n        }\n      }\n      flush();\n\n      // If no markdown headers exist, make a single section.\n      if (sections.length === 0) {\n        const summary = firstSentence(text);\n        return [{ title: "Document", summary: summary || "" }];\n      }\n      return sections;\n    }\n\n    function recoverHeadingsFromPdfText(rawText) {\n      // Heuristic: treat short ALL-CAPS lines or lines ending with \':\' as headings.\n      const text = normalizeWhitespace(rawText);\n      const lines = text.split(/\\n+/).map(l => l.trim()).filter(Boolean);\n\n      const out = [];\n      let currentTitle = null;\n      let buffer = [];\n\n      function isLikelyHeading(line) {\n        if (!line) return false;\n        if (line.length > 80) return false;\n        const hasLetters = /[A-Za-z]/.test(line);\n        if (!hasLetters) return false;\n        const lettersOnly = line.replace(/[^A-Za-z]/g, "");\n        const upperRatio = lettersOnly ? (lettersOnly.replace(/[^A-Z]/g, "").length / lettersOnly.length) : 0;\n        if (upperRatio >= 0.85 && lettersOnly.length >= 4) return true;\n        if (/:$/.test(line) && line.length <= 80) return true;\n        return false;\n      }\n\n      function flush() {\n        if (!currentTitle) return;\n        const body = buffer.join("\\n").trim();\n        out.push({ title: currentTitle, body });\n      }\n\n      for (const line of lines) {\n        if (isLikelyHeading(line)) {\n          flush();\n          currentTitle = line.replace(/:$/, "").trim();\n          buffer = [];\n        } else {\n          if (!currentTitle) {\n            currentTitle = "Document";\n          }\n          buffer.push(line);\n        }\n      }\n      flush();\n\n      // Convert to {title, summary}\n      const summaries = out.map(s => ({ title: s.title, summary: firstSentence(s.body) || "" }));\n      return summaries.length ? summaries : [{ title: "Document", summary: firstSentence(text) || "" }];\n    }\n\n    async function extractTextFromPdf(arrayBuffer) {\n      if (!window.pdfjsLib) throw new Error("pdf.js failed to load");\n      // Configure worker\n      window.pdfjsLib.GlobalWorkerOptions.workerSrc = "https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.2.67/pdf.worker.min.js";\n\n      const loadingTask = window.pdfjsLib.getDocument({ data: arrayBuffer });\n      const pdf = await loadingTask.promise;\n\n      let fullText = "";\n      for (let pageNum = 1; pageNum <= pdf.numPages; pageNum++) {\n        const page = await pdf.getPage(pageNum);\n        const content = await page.getTextContent();\n        const strings = content.items.map(it => (it.str || "").trim()).filter(Boolean);\n        // Join with spaces; add a newline per page to help heading recovery.\n        fullText += strings.join(" ") + "\\n";\n      }\n      return fullText;\n    }\n\n    function analyzeText({ fileType, text }) {\n      const raw = normalizeWhitespace(text || "");\n\n      const citations = countRegexMatches(raw, /\\[(\\d+)\\]/g);\n\n      const words = tokenizeWords(raw);\n      const totalWords = words.length;\n\n      const quantumCount = countKeyword(words, "quantum");\n      const entCount = countKeyword(words, "entanglement");\n\n      const keywordDensity = {\n        quantum: {\n          count: quantumCount,\n          density: round3(totalWords ? quantumCount / totalWords : 0)\n        },\n        entanglement: {\n          count: entCount,\n          density: round3(totalWords ? entCount / totalWords : 0)\n        }\n      };\n\n      let sectionSummaries = [];\n      if (fileType === "markdown") {\n        sectionSummaries = summarizeFromMarkdown(raw);\n      } else if (fileType === "pdf") {\n        sectionSummaries = recoverHeadingsFromPdfText(raw);\n      } else {\n        sectionSummaries = [{ title: "Document", summary: firstSentence(raw) || "" }];\n      }\n\n      return {\n        fileType,\n        citations,\n        totalWords,\n        keywordDensity,\n        sectionSummaries\n      };\n    }\n\n    function App() {\n      const [status, setStatus] = useState("No file loaded.");\n      const [analysis, setAnalysis] = useState({\n        fileType: null,\n        citations: 0,\n        totalWords: 0,\n        keywordDensity: {\n          quantum: { count: 0, density: 0 },\n          entanglement: { count: 0, density: 0 }\n        },\n        sectionSummaries: []\n      });\n\n      async function handleFileChange(e) {\n        const file = e.target.files && e.target.files[0];\n        if (!file) return;\n\n        const name = file.name || "";\n        const lower = name.toLowerCase();\n        const isMd = lower.endsWith(".md") || lower.endsWith(".markdown");\n        const isPdf = lower.endsWith(".pdf") || file.type === "application/pdf";\n\n        setStatus(`Loading ${name}...`);\n\n        try {\n          if (isMd) {\n            const text = await file.text();\n            const next = analyzeText({ fileType: "markdown", text });\n            setAnalysis(next);\n            setStatus(`Loaded ${name} (Markdown).`);\n          } else if (isPdf) {\n            const buf = await file.arrayBuffer();\n            const pdfText = await extractTextFromPdf(buf);\n            const next = analyzeText({ fileType: "pdf", text: pdfText });\n            setAnalysis(next);\n            setStatus(`Loaded ${name} (PDF).`);\n          } else {\n            // Still attempt to read as text for robustness.\n            const text = await file.text();\n            const next = analyzeText({ fileType: "unknown", text });\n            setAnalysis(next);\n            setStatus(`Loaded ${name} (unknown type; treated as text).`);\n          }\n        } catch (err) {\n          console.error(err);\n          setStatus(`Error: ${err && err.message ? err.message : String(err)}`);\n        }\n      }\n\n      const analysisJson = useMemo(() => {\n        // Ensure stable, valid JSON. (No functions, undefined, etc.)\n        return JSON.stringify(analysis, null, 2);\n      }, [analysis]);\n\n      return (\n        <div>\n          <div className="panel">\n            <label htmlFor="file">Upload journal file (.md, .markdown, .pdf)</label>\n            <input\n              id="file"\n              type="file"\n              accept=".md,.markdown,.pdf,application/pdf,text/markdown"\n              onChange={handleFileChange}\n            />\n            <div className="status"><span className="muted">Status:</span> {status}</div>\n          </div>\n\n          <div className="row">\n            <div className="panel col">\n              <h2 style={{ marginTop: 0 }}>Citation Frequency</h2>\n              <div className="kpi">{analysis.citations}</div>\n              <div className="kpi-sub">Bracket citations like <code>[1]</code>, <code>[42]</code></div>\n            </div>\n\n            <div className="panel col">\n              <h2 style={{ marginTop: 0 }}>Keyword Density</h2>\n              <div>\n                <div><strong>quantum</strong>: {analysis.keywordDensity.quantum.count} (density {analysis.keywordDensity.quantum.density})</div>\n                <div><strong>entanglement</strong>: {analysis.keywordDensity.entanglement.count} (density {analysis.keywordDensity.entanglement.density})</div>\n                <div className="kpi-sub">Density = count / totalWords (rounded to 3 decimals). Total words: {analysis.totalWords}</div>\n              </div>\n            </div>\n          </div>\n\n          <div className="panel">\n            <h2 style={{ marginTop: 0 }}>Section Summaries</h2>\n            {analysis.sectionSummaries && analysis.sectionSummaries.length ? (\n              <div>\n                {analysis.sectionSummaries.map((s, idx) => (\n                  <div className="summary-item" key={idx}>\n                    <div className="summary-title">{s.title}</div>\n                    <div>{s.summary || <span className="muted">(No summary found)</span>}</div>\n                  </div>\n                ))}\n              </div>\n            ) : (\n              <div className="muted">No sections detected yet.</div>\n            )}\n          </div>\n\n          <div className="panel">\n            <h3 style={{ marginTop: 0 }}>Machine-readable analysis</h3>\n            {/* CRITICAL FOR TESTS */}\n            <pre id="analysis-output">{analysisJson}</pre>\n          </div>\n        </div>\n      );\n    }\n\n    const root = ReactDOM.createRoot(document.getElementById(\'root\'));\n    root.render(<App />);\n  </script>\n</body>\n</html>\nEOF\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
