[44.728343, "i", " {\n      return (s || \"\").replace(/\\r\\n/g, \"\\n\").replace(/\\t/g, \" \");\n    }\n\n    function tokenizeWords(text) {\n      // Words: sequences of letters/numbers incl apostrophes; keeps it simple and deterministic.\n      const matches = (text || \"\").match(/[A-Za-z0-9']+/g);\n      return matches ? matches : [];\n    }\n\n    function countRegexMatches(text, re) {\n      if (!text) return 0;\n      const m = text.match(re);\n      return m ? m.length : 0;\n    }\n\n    function countKeyword(words, keywordLower) {\n      let c = 0;\n      for (const w of words) {\n        if (w.toLowerCase() === keywordLower) c++;\n      }\n      return c;\n    }\n\n    function firstSentence(text) {\n      const t = (text || \"\").trim();\n      if (!t) return \"\";\n      // First sentence split on . ! ? followed by whitespace/newline/end.\n      const m = t.match(/^[\\s\\S]*?[.!?](?:\\s|$)/);\n      if (m) return m[0].trim();\n      // Fallback: first non-empty line\n      const line = t.split(/\\n+/).map(s => s.trim()).find(Boolean);\n      return (line || t).tr"]
