[45.852936, "o", "<!doctype html>\r\n<html lang=\"en\">\r\n<head>\r\n  <meta charset=\"UTF-8\" />\r\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\r\n  <title>Journal Analyzer</title>\r\n  <style>\r\n    body { font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif; margin: 24px; color: #111; }\r\n    .container { max-width: 980px; margin: 0 auto; }\r\n    h1 { margin: 0 0 16px; font-size: 22px; }\r\n    .panel { border: 1px solid #ddd; border-radius: 10px; padding: 16px; margin: 14px 0; }\r\n    .row { display: flex; gap: 16px; flex-wrap: wrap; }\r\n    .col { flex: 1 1 280px; }\r\n    label { display: inline-block; font-weight: 600; margin-bottom: 6px; }\r\n    input[type=file] { width: 100%; }\r\n    .status { margin-top: 8px; color: #333; }\r\n    .muted { color: #666; }\r\n"]
[45.853156, "o", "    .kpi { font-size: 26px; font-weight: 700; }\r\n    .kpi-sub { font-size: 12px; color: #555; }\r\n    .summary-item { padding: 10px 0; border-bottom: 1px solid #eee; }\r\n    .summary-item:last-child { border-bottom: none; }\r\n    .summary-title { font-weight: 700; }\r\n    pre { background: #0b1020; color: #e6edf3; padding: 12px; border-radius: 10px; overflow: auto; }\r\n    code { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace; }\r\n  </style>\r\n</head>\r\n<body>\r\n  <div class=\"container\">\r\n    <h1>Client-Side Journal Analyzer</h1>\r\n    <div id=\"root\"></div>\r\n  </div>\r\n\r\n  <!-- React + Babel (no build pipeline) -->\r\n  <script crossorigin src=\"https://unpkg.com/react@18/umd/react.development.js\"></script>\r\n  <script crossorigin src=\"https://unpkg.com/react-dom@18/umd/react-dom.development.js\"></script>\r\n  <script src=\"https://unpkg.com/babel-standalone@6/babel.min.js\"></script>\r\n\r\n  <!-- PDF.js (for PDF text extraction) -->\r\n  <script src=\"https://cdnjs.clo"]
[45.853283, "o", "udflare.com/ajax/libs/pdf.js/4.2.67/pdf.min.js\"></script>\r\n\r\n  <script type=\"text/babel\">\r\n    const { useEffect, useMemo, useState } = React;\r\n\r\n    function round3(n) {\r\n      return Math.round(n * 1000) / 1000;\r\n    }\r\n\r\n    function normalizeWhitespace(s) {\r\n      return (s || \"\").replace(/\\r\\n/g, \"\\n\").replace(/\\t/g, \" \");\r\n    }\r\n\r\n    function tokenizeWords(text) {\r\n      // Words: sequences of letters/numbers incl apostrophes; keeps it simple and deterministic.\r\n      const matches = (text || \"\").match(/[A-Za-z0-9']+/g);\r\n      return matches ? matches : [];\r\n    }\r\n\r\n    function countRegexMatches(text, re) {\r\n      if (!text) return 0;\r\n      const m = text.match(re);\r\n      return m ? m.length : 0;\r\n    }\r\n\r\n    function countKeyword(words, keywordLower) {\r\n      let c = 0;\r\n      for (const w of words) {\r\n        if (w.toLowerCase() === keywordLower) c++;\r\n      }\r\n      return c;\r\n    }\r\n\r\n    function firstSentence(text) {\r\n      const t = (text || \"\").trim();\r\n      if (!t) return \"\";\r\n      //"]
[45.853438, "o", " First sentence split on . ! ? followed by whitespace/newline/end.\r\n      const m = t.match(/^[\\s\\S]*?[.!?](?:\\s|$)/);\r\n      if (m) return m[0].trim();\r\n      // Fallback: first non-empty line\r\n      const line = t.split(/\\n+/).map(s => s.trim()).find(Boolean);\r\n      return (line || t).trim();\r\n    }\r\n\r\n    function summarizeFromMarkdown(mdText) {\r\n      const text = normalizeWhitespace(mdText);\r\n      const lines = text.split(\"\\n\");\r\n\r\n      const sections = [];\r\n      let current = null;\r\n      let buffer = [];\r\n\r\n      function flush() {\r\n        if (!current) return;\r\n        const body = buffer.join(\"\\n\").trim();\r\n        const summary = firstSentence(body.replace(/\\n+/g, \"\\n\"));\r\n        sections.push({ title: current, summary: summary || \"\" });\r\n      }\r\n\r\n      for (let i = 0; i < lines.length; i++) {\r\n        const line = lines[i];\r\n        const headerMatch = line.match(/^\\s*#+\\s+(.*)\\s*$/);\r\n        if (headerMatch) {\r\n          flush();\r\n          current = headerMatch[1].trim() || \"(Untitled)\";"]
[45.853564, "o", "\r\n          buffer = [];\r\n        } else {\r\n          if (current) buffer.push(line);\r\n        }\r\n      }\r\n      flush();\r\n\r\n      // If no markdown headers exist, make a single section.\r\n      if (sections.length === 0) {\r\n        const summary = firstSentence(text);\r\n        return [{ title: \"Document\", summary: summary || \"\" }];\r\n      }\r\n      return sections;\r\n    }\r\n\r\n    function recoverHeadingsFromPdfText(rawText) {\r\n      // Heuristic: treat short ALL-CAPS lines or lines ending with ':' as headings.\r\n"]
