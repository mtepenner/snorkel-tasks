[44.728907, "i", "| \"\" }];\n      }\n      return sections;\n    }\n\n    function recoverHeadingsFromPdfText(rawText) {\n      // Heuristic: treat short ALL-CAPS lines or lines ending with ':' as headings.\n      const text = normalizeWhitespace(rawText);\n      const lines = text.split(/\\n+/).map(l => l.trim()).filter(Boolean);\n\n      const out = [];\n      let currentTitle = null;\n      let buffer = [];\n\n      function isLikelyHeading(line) {\n        if (!line) return false;\n        if (line.length > 80) return false;\n        const hasLetters = /[A-Za-z]/.test(line);\n        if (!hasLetters) return false;\n        const lettersOnly = line.replace(/[^A-Za-z]/g, \"\");\n        const upperRatio = lettersOnly ? (lettersOnly.replace(/[^A-Z]/g, \"\").length / lettersOnly.length) : 0;\n        if (upperRatio >= 0.85 && lettersOnly.length >= 4) return true;\n        if (/:$/.test(line) && line.length <= 80) return true;\n        return false;\n      }\n\n      function flush() {\n        if (!currentTitle) return;\n        const body = buffer.join(\"\\n\")"]
