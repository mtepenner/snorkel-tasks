[44.72915, "i", " loadingTask.promise;\n\n      let fullText = \"\";\n      for (let pageNum = 1; pageNum <= pdf.numPages; pageNum++) {\n        const page = await pdf.getPage(pageNum);\n        const content = await page.getTextContent();\n        const strings = content.items.map(it => (it.str || \"\").trim()).filter(Boolean);\n        // Join with spaces; add a newline per page to help heading recovery.\n        fullText += strings.join(\" \") + \"\\n\";\n      }\n      return fullText;\n    }\n\n    function analyzeText({ fileType, text }) {\n      const raw = normalizeWhitespace(text || \"\");\n\n      const citations = countRegexMatches(raw, /\\[(\\d+)\\]/g);\n\n      const words = tokenizeWords(raw);\n      const totalWords = words.length;\n\n      const quantumCount = countKeyword(words, \"quantum\");\n      const entCount = countKeyword(words, \"entanglement\");\n\n      const keywordDensity = {\n        quantum: {\n          count: quantumCount,\n          density: round3(totalWords ? quantumCount / totalWords : 0)\n        },\n        entanglement: {\n          "]
[44.72949, "i", "count: entCount,\n          density: round3(totalWords ? entCount / totalWords : 0)\n        }\n      };\n\n      let sectionSummaries = [];\n      if (fileType === \"markdown\") {\n        sectionSummaries = summarizeFromMarkdown(raw);\n      } else if (fileType === \"pdf\") {\n        sectionSummaries = recoverHeadingsFromPdfText(raw);\n      } else {\n        sectionSummaries = [{ title: \"Document\", summary: firstSentence(raw) || \"\" }];\n      }\n\n      return {\n        fileType,\n        citations,\n        totalWords,\n        keywordDensity,\n        sectionSummaries\n      };\n    }\n\n    function App() {\n      const [status, setStatus] = useState(\"No file loaded.\");\n      const [analysis, setAnalysis] = useState({\n        fileType: null,\n        citations: 0,\n        totalWords: 0,\n        keywordDensity: {\n          quantum: { count: 0, density: 0 },\n          entanglement: { count: 0, density: 0 }\n        },\n        sectionSummaries: []\n      });\n\n      async function handleFileChange(e) {\n        const file = e.target.fil"]
