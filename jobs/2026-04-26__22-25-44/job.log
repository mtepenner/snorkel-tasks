s = new Uint8Array(arrayBuffer);\n        let raw = "";\n        for (let i = 0; i < bytes.length; i++) {\n          raw += String.fromCharCode(bytes[i]);\n        }\n\n        const lines = [];\n\n        // Extract text from stream objects\n        const streamRegex = /stream\\r?\\n([\\s\\S]*?)\\r?\\nendstream/g;\n        let match;\n        while ((match = streamRegex.exec(raw)) !== null) {\n          const content = match[1];\n          // Extract text from BT...ET blocks\n          const btRegex = /BT([\\s\\S]*?)ET/g;\n          let btMatch;\n          while ((btMatch = btRegex.exec(content)) !== null) {\n            const block = btMatch[1];\n            // Extract Tj and TJ strings\n            const tjRegex = /\\(([^)]*)\\)\\s*Tj/g;\n            let tjMatch;\n            while ((tjMatch = tjRegex.exec(block)) !== null) {\n              let text = tjMatch[1];\n              // Unescape PDF string escapes\n              text = text.replace(/\\\\n/g, \'\\n\').replace(/\\\\r/g, \'\\r\').replace(/\\\\t/g, \'\\t\');\n              text = text.replace(/\\\\\\(/g, \'(\').replace(/\\\\\\)/g, \')\').replace(/\\\\\\\\/g, \'\\\\\');\n              lines.push(text);\n            }\n            // TJ arrays\n            const tjArrayRegex = /\\[([^\\]]*)\\]\\s*TJ/g;\n            let tjArrMatch;\n            while ((tjArrMatch = tjArrayRegex.exec(block)) !== null) {\n              const arr = tjArrMatch[1];\n              const strRegex = /\\(([^)]*)\\)/g;\n              let strMatch;\n              let combined = "";\n              while ((strMatch = strRegex.exec(arr)) !== null) {\n                let text = strMatch[1];\n                text = text.replace(/\\\\n/g, \'\\n\').replace(/\\\\r/g, \'\\r\').replace(/\\\\t/g, \'\\t\');\n                text = text.replace(/\\\\\\(/g, \'(\').replace(/\\\\\\)/g, \')\').replace(/\\\\\\\\/g, \'\\\\\');\n                combined += text;\n              }\n              if (combined) lines.push(combined);\n            }\n          }\n        }\n\n        return lines.join(\'\\n\');\n      } catch (e) {\n        console.error(\'PDF parse error:\', e);\n        return \'\';\n      }\n    }\n\n    function analyzeText(text, fileType) {\n      // Citation counting: bracket style [1], [42], etc.\n      const citationMatches = text.match(/\\[\\d+\\]/g);\n      const citations = citationMatches ? citationMatches.length : 0;\n\n      // Word counting using the specified regex\n      const wordMatches = text.match(/\\b[\\w\'-]+\\b/g);\n      const totalWords = wordMatches ? wordMatches.length : 0;\n\n      // Keyword density\n      const lowerText = text.toLowerCase();\n      const lowerWords = wordMatches ? wordMatches.map(w => w.toLowerCase()) : [];\n\n      const quantumCount = lowerWords.filter(w => w === \'quantum\').length;\n      const entanglementCount = lowerWords.filter(w => w === \'entanglement\').length;\n\n      const quantumDensity = totalWords > 0 ? Math.round((quantumCount / totalWords) * 1000) / 1000 : 0;\n      const entanglementDensity = totalWords > 0 ? Math.round((entanglementCount / totalWords) * 1000) / 1000 : 0;\n\n      // Section summaries\n      const sectionSummaries = extractSections(text, fileType);\n\n      return {\n        fileType,\n        citations,\n        totalWords,\n        keywordDensity: {\n          quantum: { count: quantumCount, density: quantumDensity },\n          entanglement: { count: entanglementCount, density: entanglementDensity }\n        },\n        sectionSummaries\n      };\n    }\n\n    function extractSections(text, fileType) {\n      const lines = text.split(\'\\n\');\n      const sections = [];\n      let currentTitle = null;\n      let currentBody = [];\n\n      for (const line of lines) {\n        const trimmed = line.trim();\n        // Detect headings: lines starting with #\n        const headingMatch = trimmed.match(/^(#{1,6})\\s+(.+)/);\n        if (headingMatch) {\n          // Save previous section\n          if (currentTitle !== null) {\n            sections.push({\n              title: currentTitle,\n              summary: getFirstSentence(currentBody.join(\' \'))\n            });\n          }\n          currentTitle = headingMatch[2].trim();\n          currentBody = [];\n        } else if (currentTitle !== null) {\n          if (trimmed.length > 0) {\n            currentBody.push(trimmed);\n          }\n        }\n      }\n\n      // Don\'t forget last section\n      if (currentTitle !== null) {\n        sections.push({\n          title: currentTitle,\n          summary: getFirstSentence(currentBody.join(\' \'))\n        });\n      }\n\n      // For PDF without markdown headings, try to detect headings heuristically\n      if (sections.length === 0 && fileType === \'pdf\') {\n        // Try uppercase or short lines as headings\n        let currentT = null;\n        let currentB = [];\n        for (const line of lines) {\n          const trimmed = line.trim();\n          if (trimmed.length === 0) continue;\n          // Heuristic: short lines (< 60 chars) that don\'t end with period could be headings\n          if (trimmed.length < 60 && !trimmed.endsWith(\'.\') && !trimmed.endsWith(\',\') && trimmed.length > 0) {\n            if (currentT !== null) {\n              sections.push({\n                title: currentT,\n                summary: getFirstSentence(currentB.join(\' \'))\n              });\n            }\n            currentT = trimmed;\n            currentB = [];\n          } else if (currentT !== null) {\n            currentB.push(trimmed);\n          }\n        }\n        if (currentT !== null) {\n          sections.push({\n            title: currentT,\n            summary: getFirstSentence(currentB.join(\' \'))\n          });\n        }\n      }\n\n      return sections;\n    }\n\n    function getFirstSentence(text) {\n      if (!text || text.trim().length === 0) return \'\';\n      // Match first sentence ending with . ! or ?\n      const match = text.match(/^(.*?[.!?])(?:\\s|$)/);\n      if (match) return match[1].trim();\n      return text.trim();\n    }\n\n    function App() {\n      const [analysis, setAnalysis] = React.useState(null);\n      const [status, setStatus] = React.useState(\'Please upload a journal file (.md, .markdown, or .pdf)\');\n      const [statusType, setStatusType] = React.useState(\'info\');\n\n      const handleFileChange = (e) => {\n        const file = e.target.files[0];\n        if (!file) return;\n\n        setStatus(`Analyzing "${file.name}"...`);\n        setStatusType(\'info\');\n\n        const ext = file.name.split(\'.\').pop().toLowerCase();\n        const fileType = ext === \'pdf\' ? \'pdf\' : \'markdown\';\n\n        if (fileType === \'pdf\') {\n          const reader = new FileReader();\n          reader.onload = (ev) => {\n            const text = parsePDF(ev.target.result);\n            const result = analyzeText(text, \'pdf\');\n            setAnalysis(result);\n            setStatus(`Analysis complete for "${file.name}"`);\n            setStatusType(\'success\');\n          };\n          reader.readAsArrayBuffer(file);\n        } else {\n          const reader = new FileReader();\n          reader.onload = (ev) => {\n            const text = ev.target.result;\n            const result = analyzeText(text, \'markdown\');\n            setAnalysis(result);\n            setStatus(`Analysis complete for "${file.name}"`);\n            setStatusType(\'success\');\n          };\n          reader.readAsText(file);\n        }\n      };\n\n      const defaultAnalysis = {\n        fileType: "",\n        citations: 0,\n        totalWords: 0,\n        keywordDensity: {\n          quantum: { count: 0, density: 0 },\n          entanglement: { count: 0, density: 0 }\n        },\n        sectionSummaries: []\n      };\n\n      const data = analysis || defaultAnalysis;\n\n      return (\n        <div>\n          <h1>Journal Analyzer</h1>\n\n          <div className="upload-section">\n            <h2>Upload Journal</h2>\n            <input\n              type="file"\n              accept=".md,.markdown,.pdf"\n              onChange={handleFileChange}\n            />\n            <div className={`status ${statusType}`}>{status}</div>\n          </div>\n\n          {analysis && (\n            <>\n              <div className="dashboard-section">\n                <h2>Citation Frequency</h2>\n                <table>\n                  <thead>\n                    <tr><th>Metric</th><th>Value</th></tr>\n                  </thead>\n                  <tbody>\n                    <tr><td>Total Citations</td><td>{data.citations}</td></tr>\n                  </tbody>\n                </table>\n              </div>\n\n              <div className="dashboard-section">\n                <h2>Keyword Density</h2>\n                <table>\n                  <thead>\n                    <tr><th>Keyword</th><th>Count</th><th>Density</th></tr>\n                  </thead>\n                  <tbody>\n                    <tr>\n                      <td>quantum</td>\n                      <td>{data.keywordDensity.quantum.count}</td>\n                      <td>{data.keywordDensity.quantum.density}</td>\n                    </tr>\n                    <tr>\n                      <td>entanglement</td>\n                      <td>{data.keywordDensity.entanglement.count}</td>\n                      <td>{data.keywordDensity.entanglement.density}</td>\n                    </tr>\n                  </tbody>\n                </table>\n              </div>\n\n              <div className="dashboard-section">\n                <h2>Section Summaries</h2>\n                <div className="sections">\n                  <ul>\n                    {data.sectionSummaries.map((sec, i) => (\n                      <li key={i}>\n                        <strong>{sec.title}</strong>\n                        <span>{sec.summary}</span>\n                      </li>\n                    ))}\n                  </ul>\n                </div>\n              </div>\n            </>\n          )}\n\n          <pre id="analysis-output">{JSON.stringify(data, null, 2)}</pre>\n        </div>\n      );\n    }\n\n    const root = ReactDOM.createRoot(document.getElementById(\'root\'));\n    root.render(<App />);\n  </script>\n</body>\n</html>\nHTMLEOF\n'] min_timeout_sec: 2.0 max_timeout_sec: 180.0
