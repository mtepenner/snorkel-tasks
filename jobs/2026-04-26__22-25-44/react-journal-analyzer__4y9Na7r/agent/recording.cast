[45.713525, "i", "Count, density: quantumDensity },\n          entanglement: { count: entanglementCount, density: entanglementDensity }\n        },\n        sectionSummaries\n      };\n    }\n\n    function extractSections(text, fileType) {\n      const lines = text.split('\\n');\n      const sections = [];\n      let currentTitle = null;\n      let currentBody = [];\n\n      for (const line of lines) {\n        const trimmed = line.trim();\n        // Detect headings: lines starting with #\n        const headingMatch = trimmed.match(/^(#{1,6})\\s+(.+)/);\n        if (headingMatch) {\n          // Save previous section\n          if (currentTitle !== null) {\n            sections.push({\n              title: currentTitle,\n              summary: getFirstSentence(currentBody.join(' '))\n            });\n          }\n          currentTitle = headingMatch[2].trim();\n          currentBody = [];\n        } else if (currentTitle !== null) {\n          if (trimmed.length > 0) {\n            currentBody.push(trimmed);\n          }\n        }\n      }\n\n      // Don't "]
[45.713855, "i", "forget last section\n      if (currentTitle !== null) {\n        sections.push({\n          title: currentTitle,\n          summary: getFirstSentence(currentBody.join(' '))\n        });\n      }\n\n      // For PDF without markdown headings, try to detect headings heuristically\n      if (sections.length === 0 && fileType === 'pdf') {\n        // Try uppercase or short lines as headings\n        let currentT = null;\n        let currentB = [];\n        for (const line of lines) {\n          const trimmed = line.trim();\n          if (trimmed.length === 0) continue;\n          // Heuristic: short lines (< 60 chars) that don't end with period could be headings\n          if (trimmed.length < 60 && !trimmed.endsWith('.') && !trimmed.endsWith(',') && trimmed.length > 0) {\n            if (currentT !== null) {\n              sections.push({\n                title: currentT,\n                summary: getFirstSentence(currentB.join(' '))\n              });\n            }\n            currentT = trimmed;\n            currentB = [];\n         "]
