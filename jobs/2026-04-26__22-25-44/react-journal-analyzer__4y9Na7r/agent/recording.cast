[45.714484, "i", "    const ext = file.name.split('.').pop().toLowerCase();\n        const fileType = ext === 'pdf' ? 'pdf' : 'markdown';\n\n        if (fileType === 'pdf') {\n          const reader = new FileReader();\n          reader.onload = (ev) => {\n            const text = parsePDF(ev.target.result);\n            const result = analyzeText(text, 'pdf');\n            setAnalysis(result);\n            setStatus(`Analysis complete for \"${file.name}\"`);\n            setStatusType('success');\n          };\n          reader.readAsArrayBuffer(file);\n        } else {\n          const reader = new FileReader();\n          reader.onload = (ev) => {\n            const text = ev.target.result;\n            const result = analyzeText(text, 'markdown');\n            setAnalysis(result);\n            setStatus(`Analysis complete for \"${file.name}\"`);\n            setStatusType('success');\n          };\n          reader.readAsText(file);\n        }\n      };\n\n      const defaultAnalysis = {\n        fileType: \"\",\n        citations: 0,\n        totalWords: 0"]
