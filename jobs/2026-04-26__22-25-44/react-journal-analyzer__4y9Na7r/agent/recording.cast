[45.714158, "i", " } else if (currentT !== null) {\n            currentB.push(trimmed);\n          }\n        }\n        if (currentT !== null) {\n          sections.push({\n            title: currentT,\n            summary: getFirstSentence(currentB.join(' '))\n          });\n        }\n      }\n\n      return sections;\n    }\n\n    function getFirstSentence(text) {\n      if (!text || text.trim().length === 0) return '';\n      // Match first sentence ending with . ! or ?\n      const match = text.match(/^(.*?[.!?])(?:\\s|$)/);\n      if (match) return match[1].trim();\n      return text.trim();\n    }\n\n    function App() {\n      const [analysis, setAnalysis] = React.useState(null);\n      const [status, setStatus] = React.useState('Please upload a journal file (.md, .markdown, or .pdf)');\n      const [statusType, setStatusType] = React.useState('info');\n\n      const handleFileChange = (e) => {\n        const file = e.target.files[0];\n        if (!file) return;\n\n        setStatus(`Analyzing \"${file.name}\"...`);\n        setStatusType('info');\n\n    "]
