[45.713395, "i", "\n            // TJ arrays\n            const tjArrayRegex = /\\[([^\\]]*)\\]\\s*TJ/g;\n            let tjArrMatch;\n            while ((tjArrMatch = tjArrayRegex.exec(block)) !== null) {\n              const arr = tjArrMatch[1];\n              const strRegex = /\\(([^)]*)\\)/g;\n              let strMatch;\n              let combined = \"\";\n              while ((strMatch = strRegex.exec(arr)) !== null) {\n                let text = strMatch[1];\n                text = text.replace(/\\\\n/g, '\\n').replace(/\\\\r/g, '\\r').replace(/\\\\t/g, '\\t');\n                text = text.replace(/\\\\\\(/g, '(').replace(/\\\\\\)/g, ')').replace(/\\\\\\\\/g, '\\\\');\n                combined += text;\n              }\n              if (combined) lines.push(combined);\n            }\n          }\n        }\n\n        return lines.join('\\n');\n      } catch (e) {\n        console.error('PDF parse error:', e);\n        return '';\n      }\n    }\n\n    function analyzeText(text, fileType) {\n      // Citation counting: bracket style [1], [42], etc.\n      const citationMatches "]
[45.713464, "o", "  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n\u001b[?2004l\r\u001b[?2004h>   <title>Journal Analyzer</title>\r\n\u001b[?2004l\r\u001b[?2004h>   <script src=\"https://unpkg.com/react@18/umd/react.development.js\" crossorigin></script>\r\n\u001b[?2004l\r"]
[45.713491, "i", "= text.match(/\\[\\d+\\]/g);\n      const citations = citationMatches ? citationMatches.length : 0;\n\n      // Word counting using the specified regex\n      const wordMatches = text.match(/\\b[\\w'-]+\\b/g);\n      const totalWords = wordMatches ? wordMatches.length : 0;\n\n      // Keyword density\n      const lowerText = text.toLowerCase();\n      const lowerWords = wordMatches ? wordMatches.map(w => w.toLowerCase()) : [];\n\n      const quantumCount = lowerWords.filter(w => w === 'quantum').length;\n      const entanglementCount = lowerWords.filter(w => w === 'entanglement').length;\n\n      const quantumDensity = totalWords > 0 ? Math.round((quantumCount / totalWords) * 1000) / 1000 : 0;\n      const entanglementDensity = totalWords > 0 ? Math.round((entanglementCount / totalWords) * 1000) / 1000 : 0;\n\n      // Section summaries\n      const sectionSummaries = extractSections(text, fileType);\n\n      return {\n        fileType,\n        citations,\n        totalWords,\n        keywordDensity: {\n          quantum: { count: quantum"]
