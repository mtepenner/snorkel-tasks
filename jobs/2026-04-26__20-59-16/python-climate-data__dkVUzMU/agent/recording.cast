[37.259915, "i", "cat > src/analyzer.py <<'PY'\n#!/usr/bin/env python3\n\nimport csv\nimport json\nimport os\nimport subprocess\nfrom collections import defaultdict\n\nBASE_DIR = \"/app/workspace\"\nDATA_DIR = os.path.join(BASE_DIR, \"data\")\nOUT_DIR = os.path.join(BASE_DIR, \"output\")\n\nCLIMATE_CSV = os.path.join(DATA_DIR, \"climate.csv\")\nMETADATA_JSON = os.path.join(DATA_DIR, \"metadata.json\")\n\nCLEANED_JSON = os.path.join(DATA_DIR, \"cleaned.json\")\nTRENDS_JSON = os.path.join(DATA_DIR, \"trends.json\")\n\nGRAPH_GV = os.path.join(OUT_DIR, \"climate_graph.gv\")\nGRAPH_PNG = os.path.join(OUT_DIR, \"climate_graph.png\")\n\n\ndef _load_metadata(path: str) -> dict:\n    with open(path, \"r\", encoding=\"utf-8\") as f:\n        meta = json.load(f)\n    if not isinstance(meta, dict):\n        raise TypeError(\"metadata.json must be a JSON object mapping region_id to region name\")\n    # Ensure keys are strings for robust lookup.\n    return {str(k): str(v) for k, v in meta.items()}\n\n\ndef _read_and_clean(climate_csv: str, region_map: dict) -> list:\n    cleaned = []\n    with open(climate_csv, \"r\", encoding=\"utf-8\", newline=\"\") as f:\n        reader = csv.DictReader(f)\n        required_cols = {\"region_id\", \"year\", \"temperature\"}\n        if reader.fieldnames is None or not required_cols.issubset(set(reader.fieldnames)):\n            raise ValueError(f\"climate.csv must contain columns {sorted(required_cols)}\")\n\n        for row in reader:\n            year = int(row[\"year\"])\n            if year < 2021:\n                continue  # absolutely no pre-2021 leakage\n\n            region_id = str(row[\"region_id\"])\n            region_name = region_map.get(region_id)\n            if region_name is None:\n                # Unknown region_id; skip rather than hardcoding/guessing.\n                continue\n\n            temp = float(row[\"temperature\"])\n            cleaned.append({\n                \"region\": str(region_name),\n                \"temperature\": float(temp),\n                \"year\": int(year),\n            })\n    return cleaned\n\n\ndef _compute_trends(cleaned_rows: list) -> dict:\n    sums = defaultdict(float)\n    counts = defaultdict(int)\n    for r in cleaned_rows:\n        region = r[\"region\"]\n        sums[region] += float(r[\"temperature\"])\n        counts[region] += 1\n\n    trends = {}\n    for region, total in sums.items():\n        trends[region] = float(total / counts[region])\n    return trends\n\n\ndef _write_json(path: str, obj) -> None:\n    with open(path, \"w\", encoding=\"utf-8\") as f:\n        json.dump(obj, f, ensure_ascii=False, indent=2)\n\n\ndef _write_graph(gv_path: str, png_path: str, trends: dict) -> None:\n    os.makedirs(os.path.dirname(gv_path), exist_ok=True)\n\n    # Deterministic ordering for stable output.\n    regions = sorted(trends.keys())\n\n    lines = []\n    lines.append(\"digraph climate {\")\n    lines.append(\"  rankdir=LR;\")\n\n    for region in regions:\n        mean_temp = float(trends[region])\n        mean_text = str(mean_temp)\n        # Quote numeric node id so decimals survive verbatim in DOT.\n        temp_node_id = json.dumps(mean_text)\n        region_node_id = json.dumps(region)\n\n        lines.append(f\"  {region_node_id} -> {temp_node_id};\")\n\n    lines.append(\"}\")\n\n    with open(gv_path, \"w\", encoding=\"utf-8\") as f:\n        f.write(\"\\n\".join(lines) + \"\\n\")\n\n    # Render PNG (only required extra file besides .gv)\n    try:\n        subprocess.run([\"dot\", \"-Tpng\", gv_path, \"-o\", png_path], check=True)\n    except FileNotFoundError as e:\n        raise RuntimeError(\"Graphviz 'dot' is required to generate climate_graph.png\") from e\n\n\ndef main() -> None:\n    region_map = _load_metadata(METADATA_JSON)\n    cleaned = _read_and_clean(CLIMATE_CSV, region_map)\n\n    # Phase 1\n    _write_json(CLEANED_JSON, cleaned)\n\n    # Phase 2\n    trends = _compute_trends(cleaned)\n    _write_json(TRENDS_JSON, trends)\n\n    # Phase 3\n    _write_graph(GRAPH_GV, GRAPH_PNG, trends)\n\n\nif __name__ == \"__main__\":\n    main()\nPY\n"]
