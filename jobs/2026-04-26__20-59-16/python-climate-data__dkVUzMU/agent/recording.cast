[37.269633, "o", "        f.write(\"\\n\".join(lines) + \"\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     # Render PNG (only required extra file besides .gv)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.269809, "o", "    try:\r\n\u001b[?2004l\r\u001b[?2004h>         subprocess.run([\"dot\", \"-Tpng\", gv_path, \"-o\", png_path], check=True)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.269961, "o", "    except FileNotFoundError as e:\r\n\u001b[?2004l\r\u001b[?2004h>         raise RuntimeError(\"Graphviz 'dot' is required to generate climate_graph.png\") from e\r\n\u001b[?2004l\r"]
[37.269994, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[37.270282, "o", "\u001b[?2004h> def main() -> None:\r\n\u001b[?2004l\r\u001b[?2004h>     region_map = _load_metadata(METADATA_JSON)\r\n\u001b[?2004l\r\u001b[?2004h"]
[37.270428, "o", ">     cleaned = _read_and_clean(CLIMATE_CSV, region_map)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     # Phase 1\r\n\u001b[?2004l\r\u001b[?2004h>     _write_json(CLEANED_JSON, cleaned)\r\n\u001b[?2004l\r"]
[37.270525, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     # Phase 2\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.270614, "o", "    trends = _compute_trends(cleaned)\r\n\u001b[?2004l\r\u001b[?2004h>     _write_json(TRENDS_JSON, trends)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.2707, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>     # Phase 3\r\n\u001b[?2004l\r\u001b[?2004h>     _write_graph(GRAPH_GV, GRAPH_PNG, trends)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[37.270816, "o", "\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> if __name__ == \"__main__\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.270988, "o", "    main()\r\n\u001b[?2004l\r\u001b[?2004h> PY\r\n\u001b[?2004l\r"]
