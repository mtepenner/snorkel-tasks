[40.572737, "i", "python3 - <<'PY'\nimport json\nwith open('data/cleaned.json') as f:\n    cleaned=json.load(f)\nassert all(r['year']>=2021 for r in cleaned)\nwith open('data/trends.json') as f:\n    trends=json.load(f)\nassert isinstance(trends, dict) and all(isinstance(v, float) for v in trends.values())\nprint('OK: no pre-2021 rows; trends are floats; regions:', sorted(trends.keys()))\nPY\n"]
[40.573017, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r\u001b[?2004h> import json\r\n\u001b[?2004l\r\u001b[?2004h> "]
