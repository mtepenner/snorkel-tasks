[47.057178, "o", "import os\r\nimport csv\r\nimport json\r\nimport sqlite3\r\nfrom datetime import datetime\r\nfrom flask import Flask, render_template, jsonify, send_file, Response\r\n\r\napp = Flask(__name__)\r\n\r\nDATA_DIR = os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(__file__))), 'data')\r\nINPUT_DIR = os.path.join(DATA_DIR, 'input')\r\nOUTPUT_JSON = os.path.join(DATA_DIR, 'output.json')\r\nDB_PATH = os.path.join(DATA_DIR, 'etl.db')\r\nLOG_PATH = os.path.join(DATA_DIR, 'etl.log')\r\n\r\n\r\ndef run_etl():\r\n    \"\"\"Run the ETL pipeline: read CSVs -> write output.json -> insert into DB -> append to log.\"\"\"\r\n    try:\r\n        # Read all CSV files from input directory\r\n        all_records = []\r\n        if os.path.isdir(INPUT_DIR):\r\n            for filename in sorted(os.listdir(INPUT_DIR)):\r\n                if filename.lower().endswith('.csv'):\r\n                    filepath = os.path.join(INPUT_DIR, filename)\r\n                    with open(filepath, 'r', newline='', encoding='utf-8') as f:\r\n                        reader = csv.DictReader(f)\r\n"]
[47.057361, "o", "                        for row in reader:\r\n                            # Preserve all original columns, convert all values to strings\r\n                            record = {k: str(v) for k, v in row.items()}\r\n                            all_records.append(record)\r\n\r\n        # Write output.json\r\n        with open(OUTPUT_JSON, 'w', encoding='utf-8') as f:\r\n            json.dump(all_records, f, indent=2)\r\n\r\n        # Insert into SQLite DB\r\n        conn = sqlite3.connect(DB_PATH)\r\n        cursor = conn.cursor()\r\n        cursor.execute('CREATE TABLE IF NOT EXISTS records (id INTEGER PRIMARY KEY, data TEXT)')\r\n        # Clear existing records before inserting\r\n        cursor.execute('DELETE FROM records')\r\n        for record in all_records:\r\n            cursor.execute('INSERT INTO records (data) VALUES (?)', (json.dumps(record),))\r\n        conn.commit()\r\n        conn.close()\r\n\r\n        # Append success log entry\r\n        timestamp = datetime.now().strftime('%Y-%m-%d %H:%M:%S')\r\n        log_entry = f\"[{timestamp}] "]
[47.057388, "o", "SUCCESS: ETL pipeline completed. {len(all_records)} records processed.\\n\"\r\n        with open(LOG_PATH, 'a', encoding='utf-8') as f:\r\n            f.write(log_entry)\r\n\r\n        return {'status': 'success', 'records': len(all_records)}\r\n\r\n    except Exception as e:\r\n        # Append error log entry\r\n        timestamp = datetime.now().strftime('%Y-%m-%d %H:%M:%S')\r\n        log_entry = f\"[{timestamp}] ERROR: {str(e)}\\n\"\r\n        with open(LOG_PATH, 'a', encoding='utf-8') as f:\r\n            f.write(log_entry)\r\n\r\n        return {'status': 'error', 'message': str(e)}\r\n\r\n\r\n@app.route('/')\r\ndef index():\r\n    return render_template('index.html')\r\n\r\n\r\n@app.route('/trigger', methods=['POST'])\r\ndef trigger():\r\n    result = run_etl()\r\n    return jsonify(result)\r\n\r\n\r\n@app.route('/logs')\r\ndef logs():\r\n    if os.path.exists(LOG_PATH):\r\n        with open(LOG_PATH, 'r', encoding='utf-8') as f:\r\n            content = f.read()\r\n        return Response(content, mimetype='text/plain')\r\n    return Response('', mimetype='text/plain')\r"]
[47.057397, "o", "\n\r\n\r\n@app.route('/download')\r\ndef download():\r\n    return send_file(OUTPUT_JSON, as_attachment=True)\r\n\r\n\r\nif __name__ == '__main__':\r\n    os.makedirs(INPUT_DIR, exist_ok=True)\r\n    app.run(host='0.0.0.0', port=5000)\r\n\u001b[?2004hroot@3cec0162b557:/app# "]
[47.364602, "i", "cat /app/workspace/src/templates/index.html\n"]
[47.364904, "o", "cat /app/workspace/src/templates/index.html\r\n\u001b[?2004l\r"]
[47.365798, "o", "<!DOCTYPE html>\r\n<html lang=\"en\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>ETL Dashboard</title>\r\n</head>\r\n<body>\r\n    <h1>ETL Dashboard</h1>\r\n\r\n    <button id=\"trigger-btn\" onclick=\"triggerETL()\">Run ETL Pipeline</button>\r\n\r\n    <h2>Logs</h2>\r\n    <pre id=\"logs\"></pre>\r\n\r\n    <h2>Download</h2>\r\n    <a href=\"/download\">Download output.json</a>\r\n\r\n    <script>\r\n        function triggerETL() {\r\n            var btn = document.getElementById('trigger-btn');\r\n            btn.disabled = true;\r\n            fetch('/trigger', { method: 'POST' })\r\n                .then(function(response) { return response.json(); })\r\n                .then(function(data) {\r\n                    btn.disabled = false;\r\n                    fetchLogs();\r\n                })\r\n                .catch(function(err) {\r\n                    btn.disabled = false;\r\n                    fetchLogs();\r\n                });\r\n        }\r\n\r\n        function fetchLogs() {\r\n      "]
[47.365829, "o", "      fetch('/logs')\r\n                .then(function(response) { return response.text(); })\r\n                .then(function(text) {\r\n                    document.getElementById('logs').textContent = text;\r\n                });\r\n        }\r\n\r\n        window.onload = function() {\r\n            fetchLogs();\r\n        };\r\n    </script>\r\n</body>\r\n</html>\r\n"]
