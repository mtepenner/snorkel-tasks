[42.719048, "o", "cat /app/workspace/src/app.py\r\n\u001b[?2004l\r"]
[42.719751, "o", "import os\r\nimport csv\r\nimport json\r\nimport glob\r\nimport sqlite3\r\nimport traceback\r\nfrom datetime import datetime, timezone\r\nfrom flask import Flask, render_template, jsonify, send_file, Response\r\n\r\napp = Flask(__name__)\r\n\r\nDATA_DIR = '/app/workspace/data'\r\nINPUT_DIR = os.path.join(DATA_DIR, 'input')\r\nOUTPUT_FILE = os.path.join(DATA_DIR, 'output.json')\r\nDB_FILE = os.path.join(DATA_DIR, 'etl.db')\r\nLOG_FILE = os.path.join(DATA_DIR, 'etl.log')\r\n\r\n\r\ndef run_etl():\r\n    \"\"\"Run the ETL pipeline.\"\"\"\r\n    try:\r\n        # Read all CSV files from input directory\r\n        all_records = []\r\n        csv_files = sorted(glob.glob(os.path.join(INPUT_DIR, '*.csv')))\r\n        for csv_path in csv_files:\r\n            with open(csv_path, 'r', newline='', encoding='utf-8') as f:\r\n                reader = csv.DictReader(f)\r\n                for row in reader:\r\n                    # Ensure all values are strings\r\n                    record = {k: str(v) for k, v in row.items()}\r\n                    all_records.append(record)\r\n\r\n       "]
[42.719783, "o", " # Write output.json as a flat JSON array\r\n        with open(OUTPUT_FILE, 'w', encoding='utf-8') as f:\r\n            json.dump(all_records, f, indent=2)\r\n\r\n        # Insert into SQLite database\r\n        conn = sqlite3.connect(DB_FILE)\r\n        cursor = conn.cursor()\r\n        cursor.execute('CREATE TABLE IF NOT EXISTS records (id INTEGER PRIMARY KEY, data TEXT)')\r\n        for record in all_records:\r\n            cursor.execute('INSERT INTO records (data) VALUES (?)', (json.dumps(record),))\r\n        conn.commit()\r\n        conn.close()\r\n\r\n        # Log success\r\n        timestamp = datetime.now(timezone.utc).strftime('%Y-%m-%d %H:%M:%S')\r\n        with open(LOG_FILE, 'a', encoding='utf-8') as f:\r\n            f.write(f'{timestamp} SUCCESS: ETL completed. {len(all_records)} records processed.\\n')\r\n\r\n        return {'status': 'success', 'records': len(all_records)}\r\n\r\n    except Exception as e:\r\n        # Log error\r\n        timestamp = datetime.now(timezone.utc).strftime('%Y-%m-%d %H:%M:%S')\r\n        with open(LOG_FILE"]
[42.7198, "o", ", 'a', encoding='utf-8') as f:\r\n            f.write(f'{timestamp} ERROR: {str(e)}\\n')\r\n        return {'status': 'error', 'message': str(e)}\r\n\r\n\r\n@app.route('/')\r\ndef index():\r\n    return render_template('index.html')\r\n\r\n\r\n@app.route('/trigger', methods=['POST'])\r\ndef trigger():\r\n    result = run_etl()\r\n    return jsonify(result)\r\n\r\n\r\n@app.route('/logs')\r\ndef logs():\r\n    if os.path.exists(LOG_FILE):\r\n        with open(LOG_FILE, 'r', encoding='utf-8') as f:\r\n            content = f.read()\r\n    else:\r\n        content = ''\r\n    return Response(content, mimetype='text/plain')\r\n\r\n\r\n@app.route('/download')\r\ndef download():\r\n    return send_file(OUTPUT_FILE, as_attachment=True)\r\n\r\n\r\nif __name__ == '__main__':\r\n    os.makedirs(INPUT_DIR, exist_ok=True)\r\n    app.run(host='0.0.0.0', port=5000)\r\n"]
[42.720006, "o", "\u001b[?2004h"]
[42.72004, "o", "root@812fbe5aa575:/app# "]
[43.014493, "i", "cat /app/workspace/src/templates/index.html\n"]
[43.014742, "o", "cat /app/workspace/src/templates/index.html\r\n\u001b[?2004l\r"]
[43.0156, "o", "<!DOCTYPE html>\r\n<html lang=\"en\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>ETL Dashboard</title>\r\n</head>\r\n<body>\r\n    <h1>ETL Dashboard</h1>\r\n\r\n    <button id=\"trigger-btn\" onclick=\"triggerETL()\">Run ETL</button>\r\n    <span id=\"status\"></span>\r\n\r\n    <h2>Logs</h2>\r\n    <pre id=\"logs\"></pre>\r\n\r\n    <h2>Download</h2>\r\n    <a href=\"/download\">Download output.json</a>\r\n\r\n    <script>\r\n        function triggerETL() {\r\n            var btn = document.getElementById('trigger-btn');\r\n            var status = document.getElementById('status');\r\n            btn.disabled = true;\r\n            status.textContent = 'Running...';\r\n            fetch('/trigger', { method: 'POST' })\r\n                .then(function(response) { return response.json(); })\r\n                .then(function(data) {\r\n                    status.textContent = 'ETL ' + data.status;\r\n                    fetchLogs();\r\n                })\r\n                .catch(function(err) "]
[43.015727, "o", "{\r\n                    status.textContent = 'Error: ' + err;\r\n                })\r\n                .finally(function() {\r\n                    btn.disabled = false;\r\n                });\r\n        }\r\n\r\n        function fetchLogs() {\r\n            fetch('/logs')\r\n                .then(function(response) { return response.text(); })\r\n                .then(function(text) {\r\n                    document.getElementById('logs').textContent = text;\r\n                });\r\n        }\r\n\r\n        window.onload = function() {\r\n            fetchLogs();\r\n        };\r\n    </script>\r\n</body>\r\n</html>\r\n"]
