[42.202514, "i", "cat > /app/workspace/src/templates/index.html << 'HTMLEOF'\n<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>ETL Dashboard</title>\n</head>\n<body>\n    <h1>ETL Dashboard</h1>\n\n    <button id=\"trigger-btn\" onclick=\"triggerETL()\">Run ETL</button>\n    <span id=\"status\"></span>\n\n    <h2>Logs</h2>\n    <pre id=\"logs\"></pre>\n\n    <h2>Download</h2>\n    <a href=\"/download\">Download output.json</a>\n\n    <script>\n        function triggerETL() {\n            var btn = document.getElementById('trigger-btn');\n            var status = document.getElementById('status');\n            btn.disabled = true;\n            status.textContent = 'Running...';\n            fetch('/trigger', { method: 'POST' })\n                .then(function(response) { return response.json(); })\n                .then(function(data) {\n                    status.textContent = 'ETL ' + data.status;\n                    fetchLogs();\n                })\n         "]
[42.202629, "i", "       .catch(function(err) {\n                    status.textContent = 'Error: ' + err;\n                })\n                .finally(function() {\n                    btn.disabled = false;\n                });\n        }\n\n        function fetchLogs() {\n            fetch('/logs')\n                .then(function(response) { return response.text(); })\n                .then(function(text) {\n                    document.getElementById('logs').textContent = text;\n                });\n        }\n\n        window.onload = function() {\n            fetchLogs();\n        };\n    </script>\n</body>\n</html>\nHTMLEOF\n"]
[42.202732, "o", "cat > /app/workspace/src/templates/index.html << 'HTMLEOF'\r\n\u001b[?2004l\r\u001b[?2004h> "]
