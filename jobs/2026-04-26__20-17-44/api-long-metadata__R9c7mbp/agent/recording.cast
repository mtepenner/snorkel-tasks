[41.54049, "o", "        score = c * (1.0 + min(len(w), 12) / 24.0)\r\n\u001b[?2004l\r\u001b[?2004h>         scored.append((score, w))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     scored.sort(reverse=True)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     topics: List[str] = []\r\n\u001b[?2004l\r\u001b[?2004h>     used = set()\r\n\u001b[?2004l\r\u001b[?2004h>     for _, w in scored:\r\n\u001b[?2004l\r"]
[41.540722, "o", "\u001b[?2004h>         if w in used:\r\n\u001b[?2004l\r\u001b[?2004h>             continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
