[41.385617, "i", "cat > /app/workspace/src/static/index.html <<'HTML'\n<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n    <title>PDF Extractor Manual Check</title>\n    <style>\n      body { font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif; margin: 24px; }\n      .row { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }\n      pre { background: #111; color: #eee; padding: 12px; border-radius: 8px; overflow: auto; max-height: 70vh; }\n      button { padding: 8px 12px; }\n      input[type=file] { padding: 6px; }\n      .muted { color: #666; }\n    </style>\n  </head>\n  <body>\n    <h1>PDF Extractor Manual Check</h1>\n    <div class=\"row\">\n      <input id=\"file\" type=\"file\" accept=\"application/pdf\" />\n      <button id=\"go\">Upload & Extract</button>\n      <span id=\"status\" class=\"muted\"></span>\n    </div>\n\n    <h3>Response JSON</h3>\n    <pre id=\"out\">(waiting)</pre>\n\n    <script>\n      const $file = document.getElementById('file');\n      const $go = document.getElementById('go');\n      const $out = document.getElementById('out');\n      const $status = document.getElementById('status');\n\n      function setStatus(msg) { $status.textContent = msg; }\n\n      $go.addEventListener('click', async () => {\n        if (!$file.files || !$file.files[0]) {\n          alert('Pick a PDF first');\n          return;\n        }\n        const f = $file.files[0];\n        const form = new FormData();\n        form.append('file', f, f.name);\n\n        $out.textContent = '';\n        setStatus('Uploading...');\n        try {\n          const res = await fetch('/extract', { method: 'POST', body: form });\n          const text = await res.text();\n          let obj;\n          try { obj = JSON.parse(text); } catch (e) { obj = { raw: text }; }\n          $out.textContent = JSON.stringify(obj, null, 2);\n          setStatus(`Done (HTTP ${res.status})`);\n        } catch (err) {\n          $out.textContent = String(err);\n          setStatus('Request failed');\n        }\n      });\n    </script>\n  </body>\n</html>\nHTML\n"]
