[66.417198, "o", "     1\tfrom __future__ import annotations\r\n     2\t\r\n     3\timport re\r\n     4\tfrom collections import Counter\r\n     5\tfrom typing import List\r\n     6\t\r\n     7\tfrom fastapi import FastAPI, File, UploadFile\r\n     8\tfrom fastapi.responses import JSONResponse\r\n     9\tfrom fastapi.staticfiles import StaticFiles\r\n    10\t\r\n    11\tfrom PyPDF2 import PdfReader\r\n    12\t\r\n    13\t\r\n    14\tapp = FastAPI()\r\n    15\t\r\n    16\t# Serve the manual check page\r\n    17\tapp.mount(\r\n    18\t    \"/static\",\r\n    19\t    StaticFiles(directory=\"/app/workspace/src/static\", html=False),\r\n    20\t    name=\"static\",\r\n    21\t)\r\n    22\t\r\n    23\t\r\n    24\t_STOPWORDS = {\r\n    25\t    \"a\",\"about\",\"above\",\"after\",\"again\",\"against\",\"all\",\"am\",\"an\",\"and\",\"any\",\"are\",\"as\",\"at\",\r\n    26\t    \"be\",\"because\",\"been\",\"before\",\"being\",\"below\",\"between\",\"both\",\"but\",\"by\",\r\n    27\t    \"can\",\"could\",\r\n    28\t    \"did\",\"do\",\"does\",\"doing\",\"down\",\"during\",\r\n    29\t    \"each\",\r\n    30\t    \"few\",\"for\",\"from\",\"further\",\r\n    31\t    \"had\",\"has\",\"have\",\"having\",\"he\",\"her\",\"here\",\"hers\",\"herself\",\"him\",\"himself\",\"his\",\"how\",\r\n    32\t    \"i\",\"if\",\"in\",\"into\",\"is\",\"it\",\"its\",\"itself\",\r\n    33\t    \"just\",\r\n    34\t    \"me\",\"more\",\"most\",\"my\",\"myself\",\r\n    35\t    \"no\",\"nor\",\"not\",\"now\",\r\n    36\t    \"of\",\"off\",\"on\",\"once\",\"only\",\"or\",\"other\",\"our\",\"ours\",\"ourselves\",\"out\",\"over\",\"own\",\r\n    37\t    \"s\",\"same\",\"she\",\"should\",\"so\",\"some\",\"such\",\r\n    38\t    \"t\",\"than\",\"that\",\"the\",\"their\",\"theirs\",\"them\",\"themselves\",\"then\",\"there\",\"these\",\"they\",\r\n    39\t    \"this\",\"those\",\"through\",\"to\",\"too\",\r\n    40\t    \"under\",\"until\",\"up\",\r\n    41\t    \"very\",\r\n    42\t    \"was\",\"we\",\"were\",\"what\",\"when\",\"where\",\"which\",\"while\",\"who\",\"whom\",\"why\",\"will\",\"with\",\r\n    43\t    \"you\",\"your\",\"yours\",\"yourself\",\"yourselves\",\r\n    44\t    # common PDF/boilerplate-ish\r\n    45\t    \"page\",\"pages\",\"copyright\",\"www\",\"http\",\"https\",\"com\",\"org\",\"net\",\r\n    46\t}\r\n    47\t\r\n    48\t\r\n    49\tdef _normalize_words(text: str) -> List[str]:\r\n    50\t    # Keep words with letters/numbers and internal apostrophes/hyphens, drop punctuation.\r\n    51\t    # Also exclude pure numbers and very short tokens.\r\n    52\t    raw = re.findall(r\"[A-Za-z][A-Za-z0-9'\\-]{1,}\", text)\r\n"]
[66.417401, "o", "    53\t    words: List[str] = []\r\n    54\t    for w in raw:\r\n    55\t        wl = w.lower().strip(\"-'\\\"\")\r\n    56\t        if len(wl) < 3:\r\n    57\t            continue\r\n    58\t        if wl in _STOPWORDS:\r\n    59\t            continue\r\n    60\t        if wl.isdigit():\r\n    61\t            continue\r\n    62\t        # Drop tokens that are mostly numeric like \"abc123\"? keep if has >=2 letters.\r\n    63\t        letters = sum(ch.isalpha() for ch in wl)\r\n    64\t        if letters < 2:\r\n    65\t            continue\r\n    66\t        words.append(wl)\r\n    67\t    return words\r\n"]
[66.417527, "o", "    68\t\r\n    69\t\r\n    70\tdef _extract_topics(text: str) -> List[str]:\r\n    71\t    words = _normalize_words(text)\r\n    72\t    if not words:\r\n    73\t        return []\r\n    74\t\r\n    75\t    counts = Counter(words)\r\n    76\t\r\n    77\t    # Prefer informative terms: longer words get a slight boost.\r\n    78\t    scored = []\r\n    79\t    for w, c in counts.items():\r\n    80\t        score = c * (1.0 + min(len(w), 12) / 24.0)\r\n    81\t        scored.append((score, w))\r\n    82\t\r\n    83\t    scored.sort(reverse=True)\r\n    84\t\r\n    85\t    topics: List[str] = []\r\n    86\t    used = set()\r\n    87\t    for _, w in scored:\r\n    88\t        if w in used:\r\n    89\t            continue\r\n    90\t        # avoid near-duplicates by prefix (simple heuristic)\r\n    91\t        if any(w.startswith(t) or t.startswith(w) for t in used):\r\n    92\t            continue\r\n    93\t        used.add(w)\r\n    94\t        topics.append(w)\r\n    95\t        if len(topics) >= 10:\r\n    96\t            break\r\n    97\t\r\n    98\t    # Ensure at least 3 if possible\r\n    99\t    return topics[: max(3, min(10, len(topics)))]\r\n   100\t\r\n   101\t\r\n"]
[66.417693, "o", "   102\tdef _chunk_words(words: List[str], chunk_size: int = 1000) -> int:\r\n   103\t    if not words:\r\n   104\t        return 0\r\n   105\t    return (len(words) + chunk_size - 1) // chunk_size\r\n   106\t\r\n   107\t\r\n   108\t@app.post(\"/extract\")\r\n   109\tasync def extract(file: UploadFile = File(...)):\r\n   110\t    # Read the full upload into memory; PyPDF2 expects file-like bytes.\r\n   111\t    data = await file.read()\r\n   112\t\r\n   113\t    try:\r\n   114\t        reader = PdfReader(io_bytes := __import__(\"io\").BytesIO(data))\r\n   115\t    except Exception as e:\r\n   116\t        return JSONResponse(status_code=400, content={\"detail\": f\"Invalid PDF: {e}\"})\r\n   117\t\r\n   118\t    # Metadata\r\n   119\t    author = \"Unknown Author\"\r\n   120\t    title = \"Untitled\"\r\n   121\t    try:\r\n   122\t        md = reader.metadata\r\n   123\t        if md is not None:\r\n   124\t            a = getattr(md, \"author\", None) or (md.get(\"/Author\") if hasattr(md, \"get\") else None)\r\n   125\t            t = getattr(md, \"title\", None) or (md.get(\"/Title\") if hasattr(md, \"get\") else None)\r\n   126\t            if isinstance(a, str) and a.strip():\r\n   127\t                author = a.strip()\r\n   128\t            if isinstance(t, str) and t.strip():\r\n   129\t                title = t.strip()\r\n   130\t    except Exception:\r\n   131\t        pass\r\n   132\t\r\n   133\t    # Extract text from pages.\r\n   134\t    parts: List[str] = []\r\n   135\t    for p in reader.pages:\r\n   136\t        try:\r\n   137\t            txt = p.extract_text() or \"\"\r\n   138\t        except Exception:\r\n   139\t            txt = \"\"\r\n   140\t        if txt:\r\n   141\t            parts.append(txt)\r\n   142\t\r\n   143\t    full_text = \"\\n\".join(parts).strip()\r\n   144\t\r\n   145\t    # Compute words and chunks (1000-word cap)\r\n   146\t    # We count words from extracted text; for chunking we use a conservative word regex.\r\n   147\t    word_list = re.findall(r\"\\b\\w+\\b\", full_text)\r\n   148"]
[66.417748, "o", "\t    total_words = len(word_list)\r\n   149\t    total_chunks = _chunk_words(word_list, 1000)\r\n   150\t\r\n   151\t    topics = _extract_topics(full_text)\r\n   152\t    # Guarantee 3..10 non-empty strings when possible; if no text, return empty list.\r\n   153\t    topics = [t for t in topics if isinstance(t, str) and t.strip()]\r\n   154\t    if full_text and len(topics) < 3:\r\n   155\t        # pad with next best candidates if heuristic filtered too much\r\n   156\t        topics = topics[:]\r\n   157\t\r\n   158\t    return {\r\n   159\t        \"author\": author,\r\n   160\t        \"title\": title,\r\n   161\t        \"topics\": topics[:10],\r\n   162\t        \"total_chunks\": int(total_chunks),\r\n   163\t        \"filename\": file.filename or \"\",\r\n   164\t        \"total_words\": int(total_words),\r\n   165\t    }\r\n"]
