[90.256822, "o", "python3 -c \"import importlib.util; spec=importlib.util.spec_from_file_location('api','/app/workspace/src/api.py'); m=importlib.util.module_from_spec(spec); spec.loader.exec_module(m); print([getattr(r,'path',None) for r in m.app.router.routes])\"\r\n\u001b[?2004l\r"]
