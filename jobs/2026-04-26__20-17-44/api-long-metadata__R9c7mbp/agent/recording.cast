[41.533767, "i", "cat > /app/workspace/src/api.py <<'PY'\nfrom __future__ import annotations\n\nimport re\nfrom collections import Counter\nfrom typing import List\n\nfrom fastapi import FastAPI, File, UploadFile\nfrom fastapi.responses import JSONResponse\nfrom fastapi.staticfiles import StaticFiles\n\nfrom PyPDF2 import PdfReader\n\n\napp = FastAPI()\n\n# Serve the manual check page\napp.mount(\n    \"/static\",\n    StaticFiles(directory=\"/app/workspace/src/static\", html=False),\n    name=\"static\",\n)\n\n\n_STOPWORDS = {\n    \"a\",\"about\",\"above\",\"after\",\"again\",\"against\",\"all\",\"am\",\"an\",\"and\",\"any\",\"are\",\"as\",\"at\",\n    \"be\",\"because\",\"been\",\"before\",\"being\",\"below\",\"between\",\"both\",\"but\",\"by\",\n    \"can\",\"could\",\n    \"did\",\"do\",\"does\",\"doing\",\"down\",\"during\",\n    \"each\",\n    \"few\",\"for\",\"from\",\"further\",\n    \"had\",\"has\",\"have\",\"having\",\"he\",\"her\",\"here\",\"hers\",\"herself\",\"him\",\"himself\",\"his\",\"how\",\n    \"i\",\"if\",\"in\",\"into\",\"is\",\"it\",\"its\",\"itself\",\n    \"just\",\n    \"me\",\"more\",\"most\",\"my\",\"myself\",\n    \"no\",\"nor\",\"not\",\"now\",\n    \"of\",\"off\",\"on\",\"once\",\"only\",\"or\",\"other\",\"our\",\"ours\",\"ourselves\",\"out\",\"over\",\"own\",\n    \"s\",\"same\",\"she\",\"should\",\"so\",\"some\",\"such\",\n    \"t\",\"than\",\"that\",\"the\",\"their\",\"theirs\",\"them\",\"themselves\",\"then\",\"there\",\"these\",\"they\",\n    \"this\",\"those\",\"through\",\"to\",\"too\",\n    \"under\",\"until\",\"up\",\n    \"very\",\n    \"was\",\"we\",\"were\",\"what\",\"when\",\"where\",\"which\",\"while\",\"who\",\"whom\",\"why\",\"will\",\"with\",\n    \"you\",\"your\",\"yours\",\"yourself\",\"yourselves\",\n    # common PDF/boilerplate-ish\n    \"page\",\"pages\",\"copyright\",\"www\",\"http\",\"https\",\"com\",\"org\",\"net\",\n}\n\n\ndef _normalize_words(text: str) -> List[str]:\n    # Keep words with letters/numbers and internal apostrophes/hyphens, drop punctuation.\n    # Also exclude pure numbers and very short tokens.\n    raw = re.findall(r\"[A-Za-z][A-Za-z0-9'\\-]{1,}\", text)\n    words: List[str] = []\n    for w in raw:\n        wl = w.lower().strip(\"-'\\\"\")\n        if len(wl) < 3:\n            continue\n        if wl in _STOPWORDS:\n            continue\n        if wl.isdigit():\n            continue\n        # Drop tokens that are mostly numeric like \"abc123\"? keep if has >=2 letters.\n        letters = sum(ch.isalpha() for ch in wl)\n        if letters < 2:\n            continue\n        words.append(wl)\n    return words\n\n\ndef _extract_topics(text: str) -> List[str]:\n    words = _normalize_words(text)\n    if not words:\n        return []\n\n    counts = Counter(words)\n\n    # Prefer informative terms: longer words get a slight boost.\n    scored = []\n    for w, c in counts.items():\n        score = c * (1.0 + min(len(w), 12) / 24.0)\n        scored.append((score, w))\n\n    scored.sort(reverse=True)\n\n    topics: List[str] = []\n    used = set()\n    for _, w in scored:\n        if w in used:\n            continue\n        # avoid near-duplicates by prefix (simple heuristic)\n        if any(w.startswith(t) or t.startswith(w) for t in used):\n            continue\n        used.add(w)\n        topics.append(w)\n        if len(topics) >= 10:\n            break\n\n    # Ensure at least 3 if possible\n    return topics[: max(3, min(10, len(topics)))]\n\n\ndef _chunk_words(words: List[str], chunk_size: int = 1000) -> int:\n    if not words:\n        return 0\n    return (len(words) + chunk_size - 1) // chunk_size\n\n\n@app.post(\"/extract\")\nasync def extract(file: UploadFile = File(...)):\n    # Read the full upload into memory; PyPDF2 expects file-like bytes.\n    data = await file.read()\n\n    try:\n        reader = PdfReader(io_bytes := __import__(\"io\").BytesIO(data))\n    except Exception as e:\n        return JSONResponse(status_code=400, content={\"detail\": f\"Invalid PDF: {e}\"})\n\n    # Metadata\n    author = \"Unknown Author\"\n    title = \"Untitled\"\n    try:\n        md = reader.metadata\n        if md is not None:\n            a = getattr(md, \"author\", None) or (md.get(\"/Author\") if hasattr(md, \"get\") else None)\n            t = getattr(md, \"title\", None) or (md.get(\"/Title\") if hasattr(md, \"get\") else None)\n            if isinstance(a, str) and a.strip():\n                author = a.strip()\n            if isinstance(t, str) and t.strip():\n                title = t.st"]
[41.533839, "i", "rip()\n    except Exception:\n        pass\n\n    # Extract text from pages.\n    parts: List[str] = []\n    for p in reader.pages:\n        try:\n            txt = p.extract_text() or \"\"\n        except Exception:\n            txt = \"\"\n        if txt:\n            parts.append(txt)\n\n    full_text = \"\\n\".join(parts).strip()\n\n    # Compute words and chunks (1000-word cap)\n    # We count words from extracted text; for chunking we use a conservative word regex.\n    word_list = re.findall(r\"\\b\\w+\\b\", full_text)\n    total_words = len(word_list)\n    total_chunks = _chunk_words(word_list, 1000)\n\n    topics = _extract_topics(full_text)\n    # Guarantee 3..10 non-empty strings when possible; if no text, return empty list.\n    topics = [t for t in topics if isinstance(t, str) and t.strip()]\n    if full_text and len(topics) < 3:\n        # pad with next best candidates if heuristic filtered too much\n        topics = topics[:]\n\n    return {\n        \"author\": author,\n        \"title\": title,\n        \"topics\": topics[:10],\n        \"total_chunks\": int(total_chunks),\n        \"filename\": file.filename or \"\",\n        \"total_words\": int(total_words),\n    }\nPY\n"]
