[41.54177, "o", "    return (len(words) + chunk_size - 1) // chunk_size\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> @app.post(\"/extract\")\r\n\u001b[?2004l\r\u001b[?2004h> async def extract(file: UploadFile = File(...)):\r\n\u001b[?2004l\r\u001b[?2004h> "]
