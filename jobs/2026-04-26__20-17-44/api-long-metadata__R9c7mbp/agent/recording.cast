[89.109532, "o", "        if any(w.startswith(t) or t.startswith(w) for t in used):\r\n\u001b[?2004l\r\u001b[?2004h>             continue\r\n\u001b[?2004l\r\u001b[?2004h>         used.add(w)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.109858, "o", "        topics.append(w)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.110125, "o", "        if len(topics) >= 10:\r\n\u001b[?2004l\r\u001b[?2004h>             break\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     return topics\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.110333, "o", "def _chunk_count(total_words: int, chunk_size: int = 1000) -> int:\r\n\u001b[?2004l\r"]
[89.110491, "o", "\u001b[?2004h>     if total_words <= 0:\r\n\u001b[?2004l\r"]
[89.110705, "o", "\u001b[?2004h>         return 0\r\n\u001b[?2004l\r\u001b[?2004h>     return (total_words + chunk_size - 1) // chunk_size\r\n\u001b[?2004l\r"]
[89.110909, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[89.111, "o", "> @app.post(\"/extract\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.111206, "o", "async def extract(file: UploadFile = File(...)):\r\n\u001b[?2004l\r\u001b[?2004h>     data = await file.read()\r\n\u001b[?2004l\r"]
[89.111359, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.111497, "o", "        reader = PdfReader(io.BytesIO(data))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.111726, "o", "    except Exception as e:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.112012, "o", "        return JSONResponse(status_code=400, content={\"detail\": f\"Invalid PDF: {e}\"})\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     # Metadata\r\n\u001b[?2004l\r"]
[89.112144, "o", "\u001b[?2004h>     author = \"Unknown Author\"\r\n\u001b[?2004l\r\u001b[?2004h>     title = \"Untitled\"\r\n\u001b[?2004l\r\u001b[?2004h>     try:\r\n\u001b[?2004l\r"]
[89.112323, "o", "\u001b[?2004h>         md = reader.metadata\r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.112384, "o", "        if md is not None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.112562, "o", "            a = getattr(md, \"author\", None)\r\n\u001b[?2004l\r\u001b[?2004h>             t = getattr(md, \"title\", None)\r\n\u001b[?2004l\r\u001b[?2004h>             if not a and hasattr(md, \"get\"):\r\n\u001b[?2004l\r\u001b[?2004h>                 a = md.get(\"/Author\")\r\n\u001b[?2004l\r"]
[89.112686, "o", "\u001b[?2004h> "]
[89.112845, "o", "            if not t and hasattr(md, \"get\"):\r\n\u001b[?2004l\r\u001b[?2004h>                 t = md.get(\"/Title\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.112903, "o", "            if isinstance(a, str) and a.strip():\r\n\u001b[?2004l\r\u001b[?2004h>                 author = a.strip()\r\n\u001b[?2004l\r"]
[89.113136, "o", "\u001b[?2004h>             if isinstance(t, str) and t.strip():\r\n\u001b[?2004l\r\u001b[?2004h>                 title = t.strip()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.113235, "o", "    except Exception:\r\n\u001b[?2004l\r\u001b[?2004h>         pass\r\n"]
[89.113325, "o", "\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.113422, "o", "    # Extract text\r\n\u001b[?2004l\r\u001b[?2004h>     parts: List[str] = []\r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.113464, "o", "    for p in reader.pages:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.11373, "o", "        try:\r\n\u001b[?2004l\r\u001b[?2004h>             txt = p.extract_text() or \"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.113817, "o", "        except Exception:\r\n\u001b[?2004l\r\u001b[?2004h>             txt = \"\"\r\n\u001b[?2004l\r\u001b[?2004h>         if txt:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.113916, "o", "            parts.append(txt)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.113964, "o", "    full_text = \"\\n\".join(parts).strip()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[89.114067, "o", ">     # Words / chunks\r\n\u001b[?2004l\r\u001b[?2004h"]
[89.114121, "o", "> "]
[89.114232, "o", "    word_list = re.findall(r\"\\b\\w+\\b\", full_text)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.114477, "o", "    total_words = len(word_list)\r\n\u001b[?2004l\r\u001b[?2004h>     total_chunks = _chunk_count(total_words, 1000)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.114546, "o", "    topics = [t for t in _extract_topics(full_text) if isinstance(t, str) and t.strip()]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.11466, "o", "    if full_text:\r\n\u001b[?2004l\r\u001b[?2004h>         topics = topics[:10]\r\n\u001b[?2004l\r\u001b[?2004h"]
[89.114758, "o", ">         if len(topics) < 3:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.114912, "o", "            # If text exists but signal is low, return what we have (still non-empty strings).\r\n\u001b[?2004l\r\u001b[?2004h"]
[89.115025, "o", ">             pass\r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.115116, "o", "    else:\r\n\u001b[?2004l\r\u001b[?2004h>         topics = []\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.115248, "o", "    return {\r\n\u001b[?2004l\r\u001b[?2004h>         \"author\": author,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.115373, "o", "        \"title\": title,\r\n\u001b[?2004l\r\u001b[?2004h>         \"topics\": topics,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.115453, "o", "        \"total_chunks\": int(total_chunks),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.115488, "o", "        \"filename\": file.filename or \"\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.115755, "o", "        \"total_words\": int(total_words),\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> PY\r\n\u001b[?2004l\r"]
