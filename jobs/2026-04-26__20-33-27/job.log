Sending keys: ['cat > /app/workspace/src/api.py <<\'PY\'\nfrom __future__ import annotations\n\nimport io\nfrom typing import Any, List, Optional\n\nimport numpy as np\nimport pandas as pd\nfrom flask import Flask, jsonify, request, render_template\n\napp = Flask(__name__, template_folder="templates", static_folder="static")\n\n# In-memory store of the latest processed dataset\n_PROCESSED_RECORDS: Optional[List[dict]] = None\n\n\ndef _is_blank(s: Any) -> bool:\n    return s is None or (isinstance(s, str) and s.strip() == "")\n\n\ndef _looks_numeric_string(s: Any) -> bool:\n    if s is None:\n        return False\n    if isinstance(s, (int, float, np.integer, np.floating)):\n        return True\n    if not isinstance(s, str):\n        return False\n    t = s.strip()\n    if t == "":\n        return False\n    try:\n        float(t)\n        return True\n    except Exception:\n        return False\n\n\ndef _reject_headerless_csv(header_cells: List[str]) -> bool:\n    """Return True if header row looks like data (e.g., \'1,2\') or empty."""\n    if not header_cells or all(_is_blank(x) for x in header_cells):\n        return True\n\n    # If every header cell is numeric/blank, it\'s almost certainly headerless data.\n    numeric_or_blank = [(_looks_numeric_string(x) or _is_blank(x)) for x in header_cells]\n    if all(numeric_or_blank):\n        return True\n\n    # Also reject if any header cell is an empty string.\n    if any(isinstance(x, str) and x.strip() == "" for x in header_cells):\n        return True\n\n    return False\n\n\ndef _preprocess(df: pd.DataFrame) -> pd.DataFrame:\n    if df is None or df.empty:\n        raise ValueError("empty")\n\n    df = df.copy()\n\n    # Identify numeric vs categorical columns.\n    numeric_cols = df.select_dtypes(include=["number", "bool"]).columns.tolist()\n    cat_cols = [c for c in df.columns if c not in numeric_cols]\n\n    # Numeric: impute mean, then z-score.\n    if numeric_cols:\n        for c in numeric_cols:\n            # coerce bool to float for consistent mean/std\n            df[c] = pd.to_numeric(df[c], errors="coerce")\n            mean = df[c].mean(skipna=True)\n            if pd.isna(mean):\n                mean = 0.0\n            df[c] = df[c].fillna(mean)\n            std = df[c].std(ddof=0)\n            if pd.isna(std) or std == 0:\n                df[c] = df[c] - df[c].mean()\n            else:\n                df[c] = (df[c] - df[c].mean()) / std\n\n    # Categorical: fill missing, one-hot encode, drop originals.\n    if cat_cols:\n        for c in cat_cols:\n            df[c] = df[c].astype("string")\n            df[c] = df[c].fillna("missing")\n        dummies = pd.get_dummies(df[cat_cols], prefix=cat_cols, dummy_na=False)\n        df = pd.concat([df.drop(columns=cat_cols), dummies], axis=1)\n\n    # Replace any remaining NaN with None for JSON.\n    df = df.replace({np.nan: None})\n    return df\n\n\n@app.get("/")\ndef index():\n    return render_template("index.html")\n\n\n@app.post("/api/v1/data/upload")\ndef upload_data():\n    global _PROCESSED_RECORDS\n\n    content_type = (request.content_type or "").split(";")[0].strip().lower()\n\n    try:\n        # Shape 1: JSON array of objects\n        if content_type == "application/json":\n            payload = request.get_json(silent=True)\n            if not isinstance(payload, list) or len(payload) == 0:\n                return jsonify({"error": "malformed or empty input"}), 400\n            if not all(isinstance(x, dict) for x in payload):\n                return jsonify({"error": "malformed or empty input"}), 400\n\n            df = pd.DataFrame(payload)\n\n        # Shape 2: raw CSV text with a real header row\n        elif content_type in {"text/csv", "text/plain"}:\n            raw = request.get_data(as_text=True)\n            if raw is None or raw.strip() == "":\n                return jsonify({"error": "malformed or empty input"}), 400\n\n            # Check first line for header validity before letting pandas treat it as headers.\n            first_line = raw.splitlines()[0] if raw.splitlines() else ""\n            header_cells = [c.strip() for c in first_line.split(",")]\n            if _reject_headerless_csv(header_cells):\n                return jsonify({"error": "CSV must include a header row"}), 400\n\n            # Now parse with pandas; keep_default_na so blanks become NaN.\n            try:\n                df = pd.read_csv(io.StringIO(raw))\n            except Exception:\n                return jsonify({"error": "malformed or empty input"}), 400\n\n            if df.empty:\n                return jsonify({"error": "malformed or empty input"}), 400\n\n        else:\n            return jsonify({"error": "unsupported content type"}), 415\n\n        processed = _preprocess(df)\n        _PROCESSED_RECORDS = processed.to_dict(orient="records")\n        return jsonify({"status": "ok"}), 200\n\n    except ValueError:\n        return jsonify({"error": "malformed or empty input"}), 400\n    except Exception:\n        # Bad input must never bubble into a 500\n        return jsonify({"error": "malformed or empty input"}), 400\n\n\n@app.get("/api/v1/data/processed")\ndef get_processed():\n    if _PROCESSED_RECORDS is None:\n        return jsonify({"error": "no processed data"}), 400\n    return jsonify(_PROCESSED_RECORDS), 200\n\n\n@app.post("/api/v1/predict")\ndef predict():\n    content_type = (request.content_type or "").split(";")[0].strip().lower()\n    if content_type != "application/json":\n        return jsonify({"error": "unsupported content type"}), 415\n\n    data = request.get_json(silent=True)\n    if not isinstance(data, dict) or "features" not in data:\n        return jsonify({"error": "malformed or empty input"}), 400\n\n    feats = data.get("features")\n    if not isinstance(feats, list) or len(feats) == 0:\n        return jsonify({"error": "malformed or empty input"}), 400\n\n    try:\n        arr = np.array(feats, dtype=float)\n    except Exception:\n        return jsonify({"error": "malformed or empty input"}), 400\n\n    # Deterministic prediction derived from features.\n    pred = float(arr.sum())\n    return jsonify({"prediction": pred}), 200\n\n\nif __name__ == "__main__":\n    app.run(host="0.0.0.0", port=5000)\nPY\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
Sending keys: ['cat > /app/workspace/src/templates/index.html <<\'HTML\'\n<!doctype html>\n<html lang="en">\n<head>\n  <meta charset="utf-8" />\n  <meta name="viewport" content="width=device-width, initial-scale=1" />\n  <title>ML Dashboard</title>\n  <style>\n    :root { --bg:#0b1220; --panel:#111b2e; --text:#e7eefc; --muted:#a8b3cf; --accent:#6aa6ff; }\n    body { margin:0; font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif; background:var(--bg); color:var(--text); }\n    .layout { display:flex; min-height:100vh; }\n    aside { width:240px; background:var(--panel); padding:16px; box-sizing:border-box; }\n    main { flex:1; padding:16px; box-sizing:border-box; }\n    nav a { display:block; color:var(--text); text-decoration:none; padding:10px 8px; border-radius:8px; }\n    nav a:hover { background:rgba(255,255,255,0.06); }\n    .card { background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:12px; padding:14px; margin-bottom:16px; }\n    label { display:block; font-size:14px; color:var(--muted); margin:10px 0 6px; }\n    input[type="text"], select { width:100%; padding:10px; border-radius:10px; border:1px solid rgba(255,255,255,0.12); background:#0c162a; color:var(--text); box-sizing:border-box; }\n    input[type="range"] { width:100%; }\n    button { padding:10px 12px; border-radius:10px; border:0; background:var(--accent); color:#081225; font-weight:600; cursor:pointer; }\n    .row { display:grid; grid-template-columns: 1fr 1fr; gap:12px; }\n    .meta { font-size:13px; color:var(--muted); }\n    #loading { display:none; margin-left:10px; color:var(--muted); }\n    #error { color:#ffb4b4; white-space:pre-wrap; }\n    @media (max-width: 800px) {\n      .layout { flex-direction:column; }\n      aside { width:100%; }\n      .row { grid-template-columns: 1fr; }\n    }\n  </style>\n</head>\n<body>\n  <div class="layout">\n    <aside>\n      <div class="card">\n        <div class="meta">Navigation</div>\n        <nav>\n          <a href="#data">data</a>\n          <a href="#model">model</a>\n          <a href="#inference">inference</a>\n        </nav>\n      </div>\n    </aside>\n\n    <main>\n      <section id="model" class="card">\n        <h2 style="margin:0 0 6px;">Model configuration</h2>\n        <div class="meta">Submit features to get a prediction.</div>\n\n        <form id="modelForm">\n          <div class="row">\n            <div>\n              <label for="modelType">Model type</label>\n              <select id="modelType" name="modelType">\n                <option value="linear">Linear</option>\n                <option value="tree">Tree</option>\n              </select>\n            </div>\n            <div>\n              <label for="hp">Hyperparameter</label>\n              <input id="hp" name="hp" type="range" min="0" max="100" value="50" />\n              <div class="meta">Value: <span id="hpVal">50</span></div>\n            </div>\n          </div>\n\n          <label for="features">Features (comma-separated numbers)</label>\n          <input id="features" name="features" type="text" value="1,2,3" />\n\n          <div style="margin-top:12px; display:flex; align-items:center; gap:10px;">\n            <button type="submit">Predict</button>\n            <div id="loading">loading</div>\n          </div>\n        </form>\n\n        <div style="margin-top:12px;">\n          <div class="meta">Prediction:</div>\n          <div id="prediction" style="font-size:22px; font-weight:700;">-</div>\n          <div id="error"></div>\n        </div>\n      </section>\n\n      <section id="data" class="card">\n        <h2 style="margin:0 0 6px;">Data</h2>\n        <div class="meta">Use the API: POST /api/v1/data/upload then GET /api/v1/data/processed</div>\n      </section>\n\n      <section id="inference" class="card">\n        <h2 style="margin:0 0 6px;">Inference chart</h2>\n        <div class="meta">Chart area (canvas)</div>\n        <canvas id="chart" width="800" height="240" style="width:100%; height:240px; background:#0c162a; border-radius:12px; border:1px solid rgba(255,255,255,0.12);"></canvas>\n      </section>\n\n      <script src="/static/js/app.js"></script>\n    </main>\n  </div>\n</body>\n</html>\nHTML\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
Sending keys: ["cat > /app/workspace/src/static/js/app.js <<'JS'\n(function () {\n  const form = document.getElementById('modelForm');\n  const featuresEl = document.getElementById('features');\n  const predictionEl = document.getElementById('prediction');\n  const errorEl = document.getElementById('error');\n  const loadingEl = document.getElementById('loading');\n  const hp = document.getElementById('hp');\n  const hpVal = document.getElementById('hpVal');\n\n  if (hp && hpVal) {\n    hpVal.textContent = hp.value;\n    hp.addEventListener('input', () => { hpVal.textContent = hp.value; });\n  }\n\n  function setLoading(isLoading) {\n    loadingEl.style.display = isLoading ? 'inline' : 'none';\n  }\n\n  function parseFeatures(str) {\n    return str\n      .split(',')\n      .map(s => s.trim())\n      .filter(s => s.length > 0)\n      .map(s => Number(s));\n  }\n\n  form.addEventListener('submit', (e) => {\n    e.preventDefault();\n\n    errorEl.textContent = '';\n    predictionEl.textContent = '-';\n\n    const feats = parseFeatures(featuresEl.value);\n\n    setLoading(true);\n\n    fetch('/api/v1/predict', {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ features: feats })\n    })\n      .then((resp) => {\n        if (!resp.ok) return resp.json().then(j => { throw new Error(j.error || ('HTTP ' + resp.status)); });\n        return resp.json();\n      })\n      .then((data) => {\n        predictionEl.textContent = String(data.prediction);\n      })\n      .catch((err) => {\n        errorEl.textContent = String(err && err.message ? err.message : err);\n      })\n      .finally(() => {\n        setLoading(false);\n      });\n  });\n})();\nJS\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
