[103.360183, "i", "python3 - <<'PY'\nimport json\nimport urllib.request\nimport urllib.error\n\nBASE = 'http://127.0.0.1:5000'\n\ndef req(method, path, body=None, headers=None):\n    url = BASE + path\n    data = None\n    if body is not None:\n        if isinstance(body, (dict, list)):\n            data = json.dumps(body).encode('utf-8')\n        elif isinstance(body, str):\n            data = body.encode('utf-8')\n        else:\n            data = body\n    h = headers or {}\n    r = urllib.request.Request(url, data=data, headers=h, method=method)\n    try:\n        with urllib.request.urlopen(r, timeout=5) as resp:\n            b = resp.read().decode('utf-8', errors='replace')\n            return resp.status, b\n    except urllib.error.HTTPError as e:\n        b = e.read().decode('utf-8', errors='replace')\n        return e.code, b\n\ncases = []\ncases.append((\"predict ok\", req('POST','/api/v1/predict', {'features':[1,2,3]}, {'Content-Type':'application/json'})))\ncases.append((\"predict 415\", req('POST','/api/v1/predict', 'x', {'Content-Type':'text/plain'})))\n\ncases.append((\"upload json ok\", req('POST','/api/v1/data/upload', [{'A':1,'B':None,'C':'x'},{'A':2,'B':4,'C':'y'}], {'Content-Type':'application/json'})))\ncases.append((\"processed after json\", req('GET','/api/v1/data/processed')))\n\ncases.append((\"upload csv ok\", req('POST','/api/v1/data/upload', 'A,B\\n1,2\\n3,4\\n', {'Content-Type':'text/csv'})))\ncases.append((\"upload csv headerless 400\", req('POST','/api/v1/data/upload', '1,2\\n3,4\\n', {'Content-Type':'text/csv'})))\n\ncases.append((\"upload 415\", req('POST','/api/v1/data/upload', b'abc', {'Content-Type':'application/octet-stream'})))\ncases.append((\"upload empty 400\", req('POST','/api/v1/data/upload', '', {'Content-Type':'text/plain'})))\n\nfor name, (status, body) in cases:\n    print('\\n==', name)\n    print('status:', status)\n    print('body:', body[:300])\nPY\n"]
