[55.887622, "o", "\u001b[?2004hroot@93bccacddc27:/app/workspace# "]
[56.017168, "i", "cat > /app/workspace/src/templates/index.html <<'HTML'\n<!doctype html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>ML Dashboard</title>\n  <style>\n    :root { --bg:#0b1220; --panel:#111b2e; --text:#e7eefc; --muted:#a8b3cf; --accent:#6aa6ff; }\n    body { margin:0; font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif; background:var(--bg); color:var(--text); }\n    .layout { display:flex; min-height:100vh; }\n    aside { width:240px; background:var(--panel); padding:16px; box-sizing:border-box; }\n    main { flex:1; padding:16px; box-sizing:border-box; }\n    nav a { display:block; color:var(--text); text-decoration:none; padding:10px 8px; border-radius:8px; }\n    nav a:hover { background:rgba(255,255,255,0.06); }\n    .card { background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:12px; padding:14px; margin-bottom:16px; }\n    label { display:block; font-size:14px; color:var(--muted); margin:10px 0 6px; }\n    input[type=\"text\"], select { width:100%; padding:10px; border-radius:10px; border:1px solid rgba(255,255,255,0.12); background:#0c162a; color:var(--text); box-sizing:border-box; }\n    input[type=\"range\"] { width:100%; }\n    button { padding:10px 12px; border-radius:10px; border:0; background:var(--accent); color:#081225; font-weight:600; cursor:pointer; }\n    .row { display:grid; grid-template-columns: 1fr 1fr; gap:12px; }\n    .meta { font-size:13px; color:var(--muted); }\n    #loading { display:none; margin-left:10px; color:var(--muted); }\n    #error { color:#ffb4b4; white-space:pre-wrap; }\n    @media (max-width: 800px) {\n      .layout { flex-direction:column; }\n      aside { width:100%; }\n      .row { grid-template-columns: 1fr; }\n    }\n  </style>\n</head>\n<body>\n  <div class=\"layout\">\n    <aside>\n      <div class=\"card\">\n        <div class=\"meta\">Navigation</div>\n        <nav>\n          <a href=\"#data\">data</a>\n          <a href=\"#model\">model</a>\n          <a href=\"#inference\">inference</a>\n        </nav>\n      </div>\n    </aside>\n\n    <main>\n      <section id=\"model\" class=\"card\">\n        <h2 style=\"margin:0 0 6px;\">Model configuration</h2>\n        <div class=\"meta\">Submit features to get a prediction.</div>\n\n        <form id=\"modelForm\">\n          <div class=\"row\">\n            <div>\n              <label for=\"modelType\">Model type</label>\n              <select id=\"modelType\" name=\"modelType\">\n                <option value=\"linear\">Linear</option>\n                <option value=\"tree\">Tree</option>\n              </select>\n            </div>\n            <div>\n              <label for=\"hp\">Hyperparameter</label>\n              <input id=\"hp\" name=\"hp\" type=\"range\" min=\"0\" max=\"100\" value=\"50\" />\n              <div class=\"meta\">Value: <span id=\"hpVal\">50</span></div>\n            </div>\n          </div>\n\n          <label for=\"features\">Features (comma-separated numbers)</label>\n          <input id=\"features\" name=\"features\" type=\"text\" value=\"1,2,3\" />\n\n          <div style=\"margin-top:12px; display:flex; align-items:center; gap:10px;\">\n            <button type=\"submit\">Predict</button>\n            <div id=\"loading\">loading</div>\n          </div>\n        </form>\n\n        <div style=\"margin-top:12px;\">\n          <div class=\"meta\">Prediction:</div>\n          <div id=\"prediction\" style=\"font-size:22px; font-weight:700;\">-</div>\n          <div id=\"error\"></div>\n        </div>\n      </section>\n\n      <section id=\"data\" class=\"card\">\n        <h2 style=\"margin:0 0 6px;\">Data</h2>\n        <div class=\"meta\">Use the API: POST /api/v1/data/upload then GET /api/v1/data/processed</div>\n      </section>\n\n      <section id=\"inference\" class=\"card\">\n        <h2 style=\"margin:0 0 6px;\">Inference chart</h2>\n        <div class=\"meta\">Chart area (canvas)</div>\n        <canvas id=\"chart\" width=\"800\" height=\"240\" style=\"width:100%; height:240px; background:#0c162a; border-radius:12px; border:1px solid rgba(255,255,255,0.12);\"></canvas>\n      </section>\n\n      <script src=\"/static/js/app.js\"></script>\n    <"]
[56.017258, "i", "/main>\n  </div>\n</body>\n</html>\nHTML\n"]
