[56.159073, "i", "cat > /app/workspace/src/static/js/app.js <<'JS'\n(function () {\n  const form = document.getElementById('modelForm');\n  const featuresEl = document.getElementById('features');\n  const predictionEl = document.getElementById('prediction');\n  const errorEl = document.getElementById('error');\n  const loadingEl = document.getElementById('loading');\n  const hp = document.getElementById('hp');\n  const hpVal = document.getElementById('hpVal');\n\n  if (hp && hpVal) {\n    hpVal.textContent = hp.value;\n    hp.addEventListener('input', () => { hpVal.textContent = hp.value; });\n  }\n\n  function setLoading(isLoading) {\n    loadingEl.style.display = isLoading ? 'inline' : 'none';\n  }\n\n  function parseFeatures(str) {\n    return str\n      .split(',')\n      .map(s => s.trim())\n      .filter(s => s.length > 0)\n      .map(s => Number(s));\n  }\n\n  form.addEventListener('submit', (e) => {\n    e.preventDefault();\n\n    errorEl.textContent = '';\n    predictionEl.textContent = '-';\n\n    const feats = parseFeatures(featuresEl.value);\n\n    setLoading(true);\n\n    fetch('/api/v1/predict', {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ features: feats })\n    })\n      .then((resp) => {\n        if (!resp.ok) return resp.json().then(j => { throw new Error(j.error || ('HTTP ' + resp.status)); });\n        return resp.json();\n      })\n      .then((data) => {\n        predictionEl.textContent = String(data.prediction);\n      })\n      .catch((err) => {\n        errorEl.textContent = String(err && err.message ? err.message : err);\n      })\n      .finally(() => {\n        setLoading(false);\n      });\n  });\n})();\nJS\n"]
