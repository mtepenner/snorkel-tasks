[56.029009, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>       <section id=\"data\" class=\"card\">\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.029048, "o", "        <h2 style=\"margin:0 0 6px;\">Data</h2>\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.029435, "o", "        <div class=\"meta\">Use the API: POST /api/v1/data/upload then GET /api/v1/data/processed</div>\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.029587, "o", "      </section>\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
