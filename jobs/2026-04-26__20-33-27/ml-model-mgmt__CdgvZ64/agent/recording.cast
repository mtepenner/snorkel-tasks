[55.879909, "o", "        # Shape 2: raw CSV text with a real header row\r\n\u001b[?2004l\r"]
[55.880145, "o", "\u001b[?2004h>         elif content_type in {\"text/csv\", \"text/plain\"}:\r\n\u001b[?2004l\r\u001b[?2004h>             raw = request.get_data(as_text=True)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.880188, "o", "            if raw is None or raw.strip() == \"\":\r\n\u001b[?2004l\r\u001b[?2004h>                 return jsonify({\"error\": \"malformed or empty input\"}), 400\r\n\u001b[?2004l\r"]
[55.880352, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.880455, "o", "            # Check first line for header validity before letting pandas treat it as headers.\r\n\u001b[?2004l\r"]
[55.880642, "o", "\u001b[?2004h>             first_line = raw.splitlines()[0] if raw.splitlines() else \"\"\r\n\u001b[?2004l\r\u001b[?2004h>             header_cells = [c.strip() for c in first_line.split(\",\")]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.880686, "o", "            if _reject_headerless_csv(header_cells):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.880844, "o", "                return jsonify({\"error\": \"CSV must include a header row\"}), 400\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[55.880951, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[55.881048, "o", "            # Now parse with pandas; keep_default_na so blanks become NaN.\r\n\u001b[?2004l\r\u001b[?2004h>             try:\r\n\u001b[?2004l\r"]
[55.881137, "o", "\u001b[?2004h> "]
[55.881206, "o", "                df = pd.read_csv(io.StringIO(raw))\r\n\u001b[?2004l\r\u001b[?2004h>             except Exception:\r\n\u001b[?2004l\r"]
[55.881291, "o", "\u001b[?2004h> "]
[55.881382, "o", "                return jsonify({\"error\": \"malformed or empty input\"}), 400\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[55.881511, "o", "\u001b[?2004h> "]
[55.881651, "o", "            if df.empty:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.881694, "o", "                return jsonify({\"error\": \"malformed or empty input\"}), 400\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r"]
[55.881736, "o", "\u001b[?2004h> "]
[55.881977, "o", "            return jsonify({\"error\": \"unsupported content type\"}), 415\r\n\u001b[?2004l\r"]
[55.882125, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>         processed = _preprocess(df)\r\n\u001b[?2004l\r\u001b[?2004h>         _PROCESSED_RECORDS = processed.to_dict(orient=\"records\")\r\n\u001b[?2004l\r"]
[55.882218, "o", "\u001b[?2004h>         return jsonify({\"status\": \"ok\"}), 200\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.88234, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h>     except ValueError:\r\n\u001b[?2004l\r"]
[55.882491, "o", "\u001b[?2004h>         return jsonify({\"error\": \"malformed or empty input\"}), 400\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.882598, "o", ">     except Exception:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.88263, "o", "        # Bad input must never bubble into a 500\r\n\u001b[?2004l\r\u001b[?2004h>         return jsonify({\"error\": \"malformed or empty input\"}), 400\r\n\u001b[?2004l\r"]
[55.882742, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.882912, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.883022, "o", "@app.get(\"/api/v1/data/processed\")\r\n\u001b[?2004l\r\u001b[?2004h> def get_processed():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.883163, "o", "    if _PROCESSED_RECORDS is None:\r\n\u001b[?2004l\r\u001b[?2004h>         return jsonify({\"error\": \"no processed data\"}), 400\r\n\u001b[?2004l\r\u001b[?2004h>     return jsonify(_PROCESSED_RECORDS), 200\r\n\u001b[?2004l\r"]
[55.883281, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[55.88331, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> @app.post(\"/api/v1/predict\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.883425, "o", "def predict():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.883535, "o", "    content_type = (request.content_type or \"\").split(\";\")[0].strip().lower()\r\n\u001b[?2004l\r\u001b[?2004h>     if content_type != \"application/json\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.883665, "o", "        return jsonify({\"error\": \"unsupported content type\"}), 415\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.883715, "o", "    data = request.get_json(silent=True)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.883926, "o", "    if not isinstance(data, dict) or \"features\" not in data:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.88417, "o", "        return jsonify({\"error\": \"malformed or empty input\"}), 400\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     feats = data.get(\"features\")\r\n\u001b[?2004l\r"]
[55.884348, "o", "\u001b[?2004h>     if not isinstance(feats, list) or len(feats) == 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.884441, "o", "        return jsonify({\"error\": \"malformed or empty input\"}), 400\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[55.884518, "o", "\u001b[?2004h>     try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.884685, "o", "        arr = np.array(feats, dtype=float)\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.884765, "o", ">     except Exception:\r\n\u001b[?2004l\r"]
[55.884929, "o", "\u001b[?2004h> "]
[55.885124, "o", "        return jsonify({\"error\": \"malformed or empty input\"}), 400\r\n\u001b[?2004l\r"]
[55.885283, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[55.885353, "o", "\u001b[?2004h> "]
[55.885497, "o", "    # Deterministic prediction derived from features.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.885656, "o", "    pred = float(arr.sum())\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.885717, "o", "    return jsonify({\"prediction\": pred}), 200\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[55.885873, "o", "\u001b[?2004h> "]
[55.88592, "o", "if __name__ == \"__main__\":\r\n\u001b[?2004l\r\u001b[?2004h>     app.run(host=\"0.0.0.0\", port=5000)\r\n\u001b[?2004l\r"]
[55.886024, "o", "\u001b[?2004h> "]
