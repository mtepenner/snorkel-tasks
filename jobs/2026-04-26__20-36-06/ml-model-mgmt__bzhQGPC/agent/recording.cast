[68.976951, "o", "      <p>Use the API endpoint <code>POST /api/v1/data/upload</code> to upload data.</p>\r\n\u001b[?2004l\r\u001b[?2004h>     </div>\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[68.977031, "o", "    <div class=\"card\" id=\"model\">\r\n\u001b[?2004l\r\u001b[?2004h>       <h3>Model Configuration</h3>\r\n\u001b[?2004l\r"]
[68.977132, "o", "\u001b[?2004h> "]
[68.977237, "o", "      <form id=\"predict-form\">\r\n\u001b[?2004l\r\u001b[?2004h>         <label for=\"model-select\">Algorithm</label>\r\n\u001b[?2004l\r\u001b[?2004h> "]
[68.977442, "o", "        <select id=\"model-select\" name=\"algorithm\">\r\n\u001b[?2004l\r\u001b[?2004h>           <option value=\"linear_regression\">Linear Regression</option>\r\n\u001b[?2004l\r"]
[68.977582, "o", "\u001b[?2004h>           <option value=\"random_forest\">Random Forest</option>\r\n\u001b[?2004l\r\u001b[?2004h"]
[68.977769, "o", ">           <option value=\"gradient_boosting\">Gradient Boosting</option>\r\n\u001b[?2004l\r\u001b[?2004h>         </select>\r\n"]
[68.978011, "o", "\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>         <label for=\"hyperparam-range\">Learning Rate: <span id=\"range-display\">0.50</span></label>\r\n\u001b[?2004l\r\u001b[?2004h> "]
[68.978177, "o", "        <input type=\"range\" id=\"hyperparam-range\" name=\"learning_rate\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[68.978234, "o", "               min=\"0\" max=\"1\" step=\"0.01\" value=\"0.50\">\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[68.978416, "o", "        <label for=\"features-input\">Features (comma-separated numbers)</label>\r\n\u001b[?2004l\r\u001b[?2004h> "]
[68.978507, "o", "        <input type=\"text\" id=\"features-input\" name=\"features\" placeholder=\"e.g. 1, 2, 3\">\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>         <button type=\"submit\">Predict</button>\r\n\u001b[?2004l\r\u001b[?2004h> "]
[68.978649, "o", "        <span class=\"spinner\" id=\"spinner\"></span>\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>         <div id=\"prediction-result\"></div>\r\n\u001b[?2004l\r"]
[68.978749, "o", "\u001b[?2004h>         <div id=\"error-msg\"></div>\r\n\u001b[?2004l\r\u001b[?2004h> "]
[68.978893, "o", "      </form>\r\n\u001b[?2004l\r\u001b[?2004h>     </div>\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     <div class=\"card\" id=\"inference\">\r\n\u001b[?2004l\r"]
[68.978929, "o", "\u001b[?2004h> "]
[68.979082, "o", "      <h3>Visualization</h3>\r\n\u001b[?2004l\r\u001b[?2004h>       <div class=\"chart-area\">\r\n\u001b[?2004l\r\u001b[?2004h> "]
[68.97912, "o", "        <canvas id=\"chart-canvas\" width=\"580\" height=\"280\"></canvas>\r\n\u001b[?2004l\r\u001b[?2004h> "]
[68.97936, "o", "      </div>\r\n\u001b[?2004l\r\u001b[?2004h>     </div>\r\n\u001b[?2004l\r\u001b[?2004h> "]
[68.979467, "o", "  </div>\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>   <script src=\"/static/js/app.js\"></script>\r\n\u001b[?2004l\r\u001b[?2004h> </body>\r\n\u001b[?2004l\r\u001b[?2004h> </html>\r\n\u001b[?2004l\r\u001b[?2004h> HTMLEOF\r\n\u001b[?2004l\r"]
