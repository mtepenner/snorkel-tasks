[68.471415, "i", "cat > /app/workspace/src/api.py << 'PYEOF'\nimport math\nimport io\nimport csv\nfrom flask import Flask, request, jsonify, render_template\nimport pandas as pd\nimport numpy as np\n\napp = Flask(__name__)\n\n# In-memory store for processed data\n_processed_df = None\n\n\ndef _is_headerless_csv(first_row_values):\n    \"\"\"Return True if every cell in the first row looks numeric (i.e. no real header).\"\"\"\n    for v in first_row_values:\n        v = v.strip()\n        if not v:\n            # empty cell in header is suspicious but let's treat as non-numeric\n            return False\n        try:\n            float(v)\n        except ValueError:\n            return False\n    return True\n\n\ndef _preprocess(df):\n    \"\"\"Impute, z-score normalize numerics, one-hot encode categoricals.\"\"\"\n    df = df.copy()\n\n    # Identify numeric and categorical columns\n    numeric_cols = df.select_dtypes(include=[np.number]).columns.tolist()\n    categorical_cols = df.select_dtypes(include=['object', 'category']).columns.tolist()\n\n    # Impute missing numeric values with column mean\n    for col in numeric_cols:\n        col_mean = df[col].mean()\n        if pd.isna(col_mean):\n            col_mean = 0.0\n        df[col] = df[col].fillna(col_mean)\n\n    # Z-score normalize numeric columns\n    for col in numeric_cols:\n        std = df[col].std(ddof=0)\n        mean = df[col].mean()\n        if std == 0 or pd.isna(std):\n            df[col] = 0.0\n        else:\n            df[col] = (df[col] - mean) / std\n\n    # One-hot encode categorical columns\n    if categorical_cols:\n        df = pd.get_dummies(df, columns=categorical_cols)\n        # Ensure all one-hot columns are numeric (they should be bool/int)\n        for col in df.columns:\n            if df[col].dtype == bool:\n                df[col] = df[col].astype(int)\n\n    return df\n\n\n@app.route('/')\ndef index():\n    return render_template('index.html')\n\n\n@app.route('/api/v1/data/upload', methods=['POST'])\ndef upload_data():\n    global _processed_df\n\n    content_type = request.content_type or ''\n\n    try:\n        if 'application/json' in content_type:\n            # JSON array of objects\n            try:\n                data = request.get_json(force=False, silent=False)\n            except Exception:\n                return jsonify({\"error\": \"Malformed JSON\"}), 400\n\n            if data is None:\n                return jsonify({\"error\": \"Malformed or empty JSON\"}), 400\n\n            if not isinstance(data, list):\n                return jsonify({\"error\": \"Expected a JSON array of objects\"}), 400\n\n            if len(data) == 0:\n                return jsonify({\"error\": \"Empty dataset\"}), 400\n\n            # Each element should be a dict\n            for item in data:\n                if not isinstance(item, dict):\n                    return jsonify({\"error\": \"Each element must be a JSON object\"}), 400\n\n            df = pd.DataFrame(data)\n\n        elif 'text/csv' in content_type:\n            raw = request.get_data(as_text=True)\n            if not raw or not raw.strip():\n                return jsonify({\"error\": \"Empty CSV\"}), 400\n\n            # Check if first row is headerless (all numeric)\n            lines = raw.strip().split('\\n')\n            if len(lines) < 1:\n                return jsonify({\"error\": \"Empty CSV\"}), 400\n\n            # Parse first row\n            reader = csv.reader(io.StringIO(lines[0]))\n            first_row = next(reader, None)\n            if first_row is None or len(first_row) == 0:\n                return jsonify({\"error\": \"Empty CSV\"}), 400\n\n            if _is_headerless_csv(first_row):\n                return jsonify({\"error\": \"CSV appears to have no header row\"}), 400\n\n            # Need at least a header + one data row\n            if len(lines) < 2:\n                return jsonify({\"error\": \"CSV has header but no data rows\"}), 400\n\n            df = pd.read_csv(io.StringIO(raw))\n\n            if df.empty:\n                return jsonify({\"error\": \"Empty dataset after parsing\"}), 400\n\n        else:\n            return jsonify({\"error\": \"Unsupported content type\"}), 415\n\n        # Preprocess\n        _processed_df = _preprocess(df"]
[68.47148, "i", ")\n\n        return jsonify({\n            \"message\": \"Data uploaded and processed successfully\",\n            \"rows\": len(_processed_df),\n            \"columns\": list(_processed_df.columns)\n        }), 200\n\n    except Exception as e:\n        return jsonify({\"error\": \"Bad input: \" + str(e)}), 400\n\n\n@app.route('/api/v1/data/processed', methods=['GET'])\ndef get_processed():\n    if _processed_df is None:\n        return jsonify({\"error\": \"No data uploaded yet\"}), 404\n\n    result = _processed_df.to_dict(orient='records')\n    return jsonify(result), 200\n\n\n@app.route('/api/v1/predict', methods=['POST'])\ndef predict():\n    try:\n        data = request.get_json(force=False, silent=False)\n    except Exception:\n        return jsonify({\"error\": \"Malformed JSON\"}), 400\n\n    if data is None:\n        return jsonify({\"error\": \"Missing JSON body\"}), 400\n\n    if \"features\" not in data:\n        return jsonify({\"error\": \"Missing 'features' key\"}), 400\n\n    features = data[\"features\"]\n    if not isinstance(features, list):\n        return jsonify({\"error\": \"'features' must be a list\"}), 400\n\n    # Deterministic prediction: weighted sum with index-based weights + nonlinearity\n    prediction = 0.0\n    for i, val in enumerate(features):\n        try:\n            v = float(val)\n        except (TypeError, ValueError):\n            return jsonify({\"error\": f\"Feature at index {i} is not numeric\"}), 400\n        prediction += (i + 1) * v\n\n    # Apply a deterministic nonlinearity (tanh scaled)\n    prediction = round(math.tanh(prediction / 100.0) * 100.0, 4)\n\n    return jsonify({\"prediction\": prediction}), 200\n\n\nif __name__ == '__main__':\n    app.run(host='0.0.0.0', port=5000)\nPYEOF\n"]
