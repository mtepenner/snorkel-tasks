[8.881073, "o", "from flask import Flask\r\r\n\r\r\napp = Flask(__name__)\r\r\n\r\r\n# TODO: Implement Milestone 1, 2, and 3 endpoints here.\r\r\n\r\r\nif __name__ == '__main__':\r\r\n    app.run(host='0.0.0.0', port=5000)\r\r\n"]
