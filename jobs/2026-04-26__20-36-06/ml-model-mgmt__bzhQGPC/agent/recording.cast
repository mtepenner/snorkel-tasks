[69.473407, "i", "cat > /app/workspace/src/static/js/app.js << 'JSEOF'\n(function () {\n  'use strict';\n\n  // Range slider display\n  var rangeInput = document.getElementById('hyperparam-range');\n  var rangeDisplay = document.getElementById('range-display');\n  if (rangeInput && rangeDisplay) {\n    rangeInput.addEventListener('input', function () {\n      rangeDisplay.textContent = parseFloat(this.value).toFixed(2);\n    });\n  }\n\n  // Prediction form\n  var form = document.getElementById('predict-form');\n  var spinner = document.getElementById('spinner');\n  var resultDiv = document.getElementById('prediction-result');\n  var errorDiv = document.getElementById('error-msg');\n\n  form.addEventListener('submit', function (e) {\n    e.preventDefault();\n\n    // Clear previous results\n    resultDiv.textContent = '';\n    errorDiv.textContent = '';\n\n    // Parse features\n    var raw = document.getElementById('features-input').value.trim();\n    if (!raw) {\n      errorDiv.textContent = 'Please enter features.';\n      return;\n    }\n    var features = raw.split(',').map(function (s) {\n      return parseFloat(s.trim());\n    });\n\n    for (var i = 0; i < features.length; i++) {\n      if (isNaN(features[i])) {\n        errorDiv.textContent = 'All features must be valid numbers.';\n        return;\n      }\n    }\n\n    // Show spinner\n    spinner.classList.add('loading');\n\n    fetch('/api/v1/predict', {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ features: features })\n    })\n    .then(function (response) {\n      if (!response.ok) {\n        return response.json().then(function (d) {\n          throw new Error(d.error || 'Request failed');\n        });\n      }\n      return response.json();\n    })\n    .then(function (data) {\n      spinner.classList.remove('loading');\n      resultDiv.textContent = 'Prediction: ' + data.prediction;\n    })\n    .catch(function (err) {\n      spinner.classList.remove('loading');\n      errorDiv.textContent = 'Error: ' + err.message;\n    });\n  });\n\n  // Simple chart drawing on canvas\n  var canvas = document.getElementById('chart-canvas');\n  if (canvas && canvas.getContext) {\n    var ctx = canvas.getContext('2d');\n    var w = canvas.width;\n    var h = canvas.height;\n    // Draw axes\n    ctx.strokeStyle = '#64748b';\n    ctx.lineWidth = 1.5;\n    ctx.beginPath();\n    ctx.moveTo(40, 10);\n    ctx.lineTo(40, h - 30);\n    ctx.lineTo(w - 10, h - 30);\n    ctx.stroke();\n    // Draw sample bars\n    var bars = [60, 120, 90, 150, 80, 130];\n    var barW = (w - 80) / bars.length - 8;\n    var colors = ['#2563eb', '#10b981', '#f59e0b', '#ef4444', '#8b5cf6', '#06b6d4'];\n    for (var b = 0; b < bars.length; b++) {\n      ctx.fillStyle = colors[b % colors.length];\n      var x = 50 + b * (barW + 8);\n      var barH = bars[b];\n      ctx.fillRect(x, h - 30 - barH, barW, barH);\n    }\n  }\n})();\nJSEOF\n"]
