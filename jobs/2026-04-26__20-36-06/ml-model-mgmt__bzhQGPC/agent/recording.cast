[85.030985, "i", "cd /app/workspace/src && python3 -c \"\nimport json\nfrom api import app\n\nclient = app.test_client()\n\n# Test 1: JSON upload\nprint('=== Test 1: JSON Upload ===')\nresp = client.post('/api/v1/data/upload',\n    data=json.dumps([{'A': 1, 'B': None}, {'A': 2, 'B': 4}]),\n    content_type='application/json')\nprint(f'Status: {resp.status_code}')\nprint(f'Body: {resp.get_json()}')\n\n# Test 2: Get processed data\nprint('\\n=== Test 2: Get Processed ===')\nresp = client.get('/api/v1/data/processed')\nprint(f'Status: {resp.status_code}')\nprint(f'Body: {resp.get_json()}')\n\n# Test 3: CSV upload with valid header\nprint('\\n=== Test 3: CSV Upload (valid) ===')\nresp = client.post('/api/v1/data/upload',\n    data='name,age\\nalice,30\\nbob,25\\n',\n    content_type='text/csv')\nprint(f'Status: {resp.status_code}')\nprint(f'Body: {resp.get_json()}')\n\n# Test 4: CSV with no header (should 400)\nprint('\\n=== Test 4: CSV Upload (no header) ===')\nresp = client.post('/api/v1/data/upload',\n    data='1,2\\n3,4\\n',\n    content_type='text/csv')\nprint(f'Status: {resp.status_code}')\nprint(f'Body: {resp.get_json()}')\n\n# Test 5: Unsupported content type (415)\nprint('\\n=== Test 5: Unsupported content type ===')\nresp = client.post('/api/v1/data/upload',\n    data='hello',\n    content_type='text/plain')\nprint(f'Status: {resp.status_code}')\nprint(f'Body: {resp.get_json()}')\n\n# Test 6: Predict\nprint('\\n=== Test 6: Predict ===')\nresp = client.post('/api/v1/predict',\n    data=json.dumps({'features': [1, 2, 3]}),\n    content_type='application/json')\nprint(f'Status: {resp.status_code}')\nprint(f'Body: {resp.get_json()}')\n\n# Test 7: Predict determinism\nprint('\\n=== Test 7: Predict determinism ===')\nresp2 = client.post('/api/v1/predict',\n    data=json.dumps({'features': [1, 2, 3]}),\n    content_type='application/json')\nprint(f'Same result: {resp.get_json() == resp2.get_json()}')\n\n# Test 8: Empty JSON (400)\nprint('\\n=== Test 8: Empty JSON ===')\nresp = client.post('/api/v1/data/upload',\n    data=json.dumps([]),\n    content_type='application/json')\nprint(f'Status: {resp.status_code}')\nprint(f'Body: {resp.get_json()}')\n\nprint('\\nAll tests passed!')\n\"\n"]
