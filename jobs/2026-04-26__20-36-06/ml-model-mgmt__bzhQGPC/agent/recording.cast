[68.976552, "o", "    <h2>ML Platform</h2>\r\n\u001b[?2004l\r\u001b[?2004h>     <a href=\"#data\">data</a>\r\n\u001b[?2004l\r\u001b[?2004h>     <a href=\"#model\">model</a>\r\n\u001b[?2004l\r"]
