 {\n      // Bracket style citations: [1], [42]\n      const m = text.match(/\\[(\\d+)\\]/g);\n      return m ? m.length : 0;\n    }\n\n    function countKeyword(text, keyword) {\n      const re = new RegExp(`\\\\b${keyword}\\\\b`, \'gi\');\n      const m = text.match(re);\n      return m ? m.length : 0;\n    }\n\n    function firstNonEmptySentence(textBlock) {\n      const t = (textBlock || \'\').replace(/\\s+/g, \' \').trim();\n      if (!t) return \'\';\n      // Simple sentence split: first chunk ending with . ! ? (or whole line if none)\n      const m = t.match(/^(.+?[.!?])(\\s|$)/);\n      return m ? m[1].trim() : t;\n    }\n\n    function summarizeMarkdown(mdText) {\n      const lines = (mdText || \'\').split(/\\r?\\n/);\n      const summaries = [];\n      let currentTitle = null;\n      let currentBody = [];\n\n      function flush() {\n        if (currentTitle == null) return;\n        const body = currentBody.join(\'\\n\');\n        const summary = firstNonEmptySentence(body);\n        summaries.push({ title: currentTitle, summary });\n      }\n\n      for (let i = 0; i < lines.length; i++) {\n        const line = lines[i];\n        const headerMatch = line.match(/^\\s*#+\\s*(.+?)\\s*$/);\n        if (headerMatch) {\n          flush();\n          currentTitle = headerMatch[1];\n          currentBody = [];\n        } else {\n          // Keep all lines; summary function will find first non-empty sentence.\n          if (currentTitle != null) currentBody.push(line);\n        }\n      }\n      flush();\n\n      // If there are no markdown headers, treat entire doc as one section.\n      if (summaries.length === 0) {\n        const summary = firstNonEmptySentence(mdText);\n        return [{ title: \'Document\', summary }];\n      }\n\n      return summaries;\n    }\n\n    function summarizeByHeadingsLoose(text) {\n      // For PDFs: attempt to recover headings in a lightweight way.\n      // Heuristics: lines that look like headings (ALL CAPS, or Title Case, or short lines)\n      const lines = (text || \'\').split(/\\r?\\n/).map(l => l.trim());\n      const isHeading = (l) => {\n        if (!l) return false;\n        if (l.length > 80) return false;\n        // If line ends with punctuation typical of sentences, less likely heading\n        if (/[.!?]$/.test(l)) return false;\n        // Contains many letters; avoid pure numbers\n        if (!/[A-Za-z]/.test(l)) return false;\n        const alpha = (l.match(/[A-Za-z]/g) || []).length;\n        if (alpha < 3) return false;\n        // ALL CAPS headings\n        if (l === l.toUpperCase() && /[A-Z]/.test(l)) return true;\n        // Title-ish: not too many words\n        const wc = (l.match(/\\b[\\w\'-]+\\b/g) || []).length;\n        if (wc <= 10) return true;\n        return false;\n      };\n\n      const sections = [];\n      let currentTitle = null;\n      let body = [];\n\n      function flush() {\n        if (currentTitle == null) return;\n        const summary = firstNonEmptySentence(body.join(\' \'));\n        sections.push({ title: currentTitle, summary });\n      }\n\n      for (let i = 0; i < lines.length; i++) {\n        const l = lines[i];\n        if (isHeading(l)) {\n          flush();\n          currentTitle = l;\n          body = [];\n        } else {\n          if (currentTitle != null && l) body.push(l);\n        }\n      }\n      flush();\n\n      if (sections.length === 0) {\n        return [{ title: \'Document\', summary: firstNonEmptySentence(text) }];\n      }\n      return sections;\n    }\n\n    function decodePdfLikeText(arrayBuffer) {\n      // Lightweight extraction suitable for simple text-based PDF fixtures.\n      // Strategy: decode bytes as latin1 to preserve 1:1 mapping, then\n      // extract strings inside parentheses that appear in text-show operators.\n      // This is not a full PDF parser.\n      const bytes = new Uint8Array(arrayBuffer);\n      let raw = \'\';\n      for (let i = 0; i < bytes.length; i++) raw += String.fromCharCode(bytes[i]);\n\n      // Extract literal strings (...) while handling escaped \\( \\) \\\\ and \\n\\r\\t\n      const out = [];\n      for (let i = 0; i < raw.length; i++) {\n        if (raw[i] === \'(\') {\n          let j = i + 1;\n          let s = \'\';\n          let depth = 1;\n          while (j < raw.length && depth > 0) {\n            const ch = raw[j];\n            if (ch === \'\\\\\') {\n              const next = raw[j + 1];\n              if (next === \'n\') { s += \'\\n\'; j += 2; continue; }\n              if (next === \'r\') { s += \'\\r\'; j += 2; continue; }\n              if (next === \'t\') { s += \'\\t\'; j += 2; continue; }\n              if (next === \'(\' || next === \')\' || next === \'\\\\\') { s += next; j += 2; continue; }\n              // Octal escapes (e.g., \\053)\n              const oct = raw.slice(j + 1, j + 4);\n              if (/^[0-7]{3}$/.test(oct)) {\n                s += String.fromCharCode(parseInt(oct, 8));\n                j += 4;\n                continue;\n              }\n              // Fallback: keep next char\n              if (typeof next === \'string\') { s += next; j += 2; continue; }\n            }\n            if (ch === \'(\') { depth++; s += ch; j++; continue; }\n            if (ch === \')\') {\n              depth--;\n              if (depth === 0) { j++; break; }\n              s += ch; j++; continue;\n            }\n            s += ch;\n            j++;\n          }\n          // Heuristic: keep only reasonably texty strings\n          const cleaned = s.replace(/\\u0000/g, \'\').trim();\n          if (cleaned && /[A-Za-z0-9]/.test(cleaned)) out.push(cleaned);\n          i = j - 1;\n        }\n      }\n\n      // Join with newlines; also normalize multiple spaces.\n      const joined = out.join(\'\\n\').replace(/\\r\\n/g, \'\\n\');\n      return joined;\n    }\n\n    function analyzeText(text, fileType) {\n      const totalWords = countWordsDeterministic(text);\n      const citations = countCitations(text);\n      const quantumCount = countKeyword(text, \'quantum\');\n      const entanglementCount = countKeyword(text, \'entanglement\');\n\n      const keywordDensity = {\n        quantum: {\n          count: quantumCount,\n          density: round3(totalWords ? (quantumCount / totalWords) : 0)\n        },\n        entanglement: {\n          count: entanglementCount,\n          density: round3(totalWords ? (entanglementCount / totalWords) : 0)\n        }\n      };\n\n      const sectionSummaries = (fileType === \'markdown\')\n        ? summarizeMarkdown(text)\n        : summarizeByHeadingsLoose(text);\n\n      return {\n        fileType,\n        citations,\n        totalWords,\n        keywordDensity,\n        sectionSummaries\n      };\n    }\n\n    function App() {\n      const empty = useMemo(() => ({\n        fileType: null,\n        citations: 0,\n        totalWords: 0,\n        keywordDensity: {\n          quantum: { count: 0, density: 0 },\n          entanglement: { count: 0, density: 0 }\n        },\n        sectionSummaries: []\n      }), []);\n\n      const [status, setStatus] = useState(\'No file loaded.\');\n      const [analysis, setAnalysis] = useState(empty);\n\n      async function handleFile(file) {\n        if (!file) return;\n        const name = file.name || \'\';\n        const ext = name.toLowerCase().split(\'.\').pop();\n\n        try {\n          setStatus(`Loading: ${name}`);\n\n          if (ext === \'md\' || ext === \'markdown\') {\n            const text = await file.text();\n            const next = analyzeText(text, \'markdown\');\n            setAnalysis(next);\n            setStatus(`Loaded ${name} (${next.totalWords} words)`);\n            return;\n          }\n\n          if (ext === \'pdf\') {\n            const buf = await file.arrayBuffer();\n            const text = decodePdfLikeText(buf);\n            const next = analyzeText(text, \'pdf\');\n            setAnalysis(next);\n            setStatus(`Loaded ${name} (${next.totalWords} words)`);\n            return;\n          }\n\n          setStatus(\'Unsupported file type. Please upload .md, .markdown, or .pdf\');\n        } catch (e) {\n          console.error(e);\n          setStatus(\'Error reading file.\');\n        }\n      }\n\n      return (\n        <div>\n          <h1>Journal Analyzer</h1>\n\n          <div className="card">\n            <label htmlFor="file">Upload Journal File</label>\n            <div className="muted">Accepted: .md, .markdown, .pdf</div>\n            <input\n              id="file"\n              type="file"\n              accept=".md,.markdown,.pdf,application/pdf,text/markdown"\n              onChange={(e) => handleFile(e.target.files && e.target.files[0])}\n            />\n          </div>\n\n          <div className="status" aria-live="polite">{status}</div>\n\n          <div className="row">\n            <div className="card">\n              <h2>Citation Frequency</h2>\n              <div><strong>Total citations:</strong> {analysis.citations}</div>\n            </div>\n\n            <div className="card">\n              <h2>Keyword Density</h2>\n              <div><strong>Total words:</strong> {analysis.totalWords}</div>\n              <div style={{ marginTop: 8 }}>\n                <div><strong>quantum</strong>: {analysis.keywordDensity.quantum.count} (density: {analysis.keywordDensity.quantum.density})</div>\n                <div><strong>entanglement</strong>: {analysis.keywordDensity.entanglement.count} (density: {analysis.keywordDensity.entanglement.density})</div>\n              </div>\n            </div>\n\n            <div className="card sections">\n              <h2>Section Summaries</h2>\n              {analysis.sectionSummaries.length === 0 ? (\n                <div className="muted">No sections detected yet.</div>\n              ) : (\n                <ul>\n                  {analysis.sectionSummaries.map((s, idx) => (\n                    <li key={idx}>\n                      <strong>{s.title}</strong>\n                      <div className="muted">{s.summary || \'(No summary found)\'}</div>\n                    </li>\n                  ))}\n                </ul>\n              )}\n            </div>\n          </div>\n\n          <h2 style={{ marginTop: 18 }}>Analysis JSON</h2>\n          <pre id="analysis-output">{JSON.stringify(analysis, null, 2)}</pre>\n        </div>\n      );\n    }\n\n    ReactDOM.createRoot(document.getElementById(\'root\')).render(<App />);\n  </script>\n</body>\n</html>\nHTML\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
