[84.967541, "i", "ngth; i++) {\n        const l = lines[i];\n        if (isHeading(l)) {\n          flush();\n          currentTitle = l;\n          body = [];\n        } else {\n          if (currentTitle != null && l) body.push(l);\n        }\n      }\n      flush();\n\n      if (sections.length === 0) {\n        return [{ title: 'Document', summary: firstNonEmptySentence(text) }];\n      }\n      return sections;\n    }\n\n    function decodePdfLikeText(arrayBuffer) {\n      // Lightweight PDF text extraction for simple fixtures.\n      const bytes = new Uint8Array(arrayBuffer);\n      let raw = '';\n      for (let i = 0; i < bytes.length; i++) raw += String.fromCharCode(bytes[i]);\n\n      const out = [];\n      for (let i = 0; i < raw.length; i++) {\n        if (raw[i] !== '(') continue;\n        let j = i + 1;\n        let s = '';\n        let depth = 1;\n        while (j < raw.length && depth > 0) {\n          const ch = raw[j];\n          if (ch === '\\\\') {\n            const next = raw[j + 1];\n            if (next === 'n') { s += '\\n'; j += 2; contin"]
