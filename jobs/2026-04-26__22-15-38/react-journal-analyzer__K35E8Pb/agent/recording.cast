[84.967301, "i", "\n      return m ? m.length : 0;\n    }\n\n    function firstNonEmptySentence(textBlock) {\n      const t = (textBlock || '').replace(/\\s+/g, ' ').trim();\n      if (!t) return '';\n      const m = t.match(/^(.+?[.!?])(\\s|$)/);\n      return m ? m[1].trim() : t;\n    }\n\n    function summarizeMarkdown(mdText) {\n      const lines = (mdText || '').split(/\\r?\\n/);\n      const summaries = [];\n      let currentTitle = null;\n      let currentBody = [];\n\n      function flush() {\n        if (currentTitle == null) return;\n        const body = currentBody.join('\\n');\n        const summary = firstNonEmptySentence(body);\n        summaries.push({ title: currentTitle, summary });\n      }\n\n      for (let i = 0; i < lines.length; i++) {\n        const line = lines[i];\n        const headerMatch = line.match(/^\\s*#+\\s*(.+?)\\s*$/);\n        if (headerMatch) {\n          flush();\n          currentTitle = headerMatch[1];\n          currentBody = [];\n        } else {\n          if (currentTitle != null) currentBody.push(line);\n        }\n      }\n"]
[84.967372, "o", "  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\r\n\u001b[?2004l\r\u001b[?2004h>   <title>Client-Side Journal Analyzer</title>\r\n\u001b[?2004l\r\u001b[?2004h> "]
[84.967441, "i", "      flush();\n\n      if (summaries.length === 0) {\n        return [{ title: 'Document', summary: firstNonEmptySentence(mdText) }];\n      }\n      return summaries;\n    }\n\n    function summarizeByHeadingsLoose(text) {\n      const lines = (text || '').split(/\\r?\\n/).map(l => l.trim());\n\n      const isHeading = (l) => {\n        if (!l) return false;\n        if (l.length > 80) return false;\n        if (/[.!?]$/.test(l)) return false;\n        if (!/[A-Za-z]/.test(l)) return false;\n        const alpha = (l.match(/[A-Za-z]/g) || []).length;\n        if (alpha < 3) return false;\n        if (l === l.toUpperCase() && /[A-Z]/.test(l)) return true;\n        const wc = (l.match(/\\b[\\w'-]+\\b/g) || []).length;\n        return wc <= 10;\n      };\n\n      const sections = [];\n      let currentTitle = null;\n      let body = [];\n\n      function flush() {\n        if (currentTitle == null) return;\n        sections.push({ title: currentTitle, summary: firstNonEmptySentence(body.join(' ')) });\n      }\n\n      for (let i = 0; i < lines.le"]
