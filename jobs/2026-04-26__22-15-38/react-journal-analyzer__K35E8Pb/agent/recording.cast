[84.967645, "i", "ue; }\n            if (next === 'r') { s += '\\r'; j += 2; continue; }\n            if (next === 't') { s += '\\t'; j += 2; continue; }\n            if (next === '(' || next === ')' || next === '\\\\') { s += next; j += 2; continue; }\n            const oct = raw.slice(j + 1, j + 4);\n            if (/^[0-7]{3}$/.test(oct)) {\n              s += String.fromCharCode(parseInt(oct, 8));\n              j += 4;\n              continue;\n            }\n            if (typeof next === 'string') { s += next; j += 2; continue; }\n          }\n          if (ch === '(') { depth++; s += ch; j++; continue; }\n          if (ch === ')') {\n            depth--;\n            if (depth === 0) { j++; break; }\n            s += ch; j++; continue;\n          }\n          s += ch;\n          j++;\n        }\n        const cleaned = s.replace(/\\u0000/g, '').trim();\n        if (cleaned && /[A-Za-z0-9]/.test(cleaned)) out.push(cleaned);\n        i = j - 1;\n      }\n\n      return out.join('\\n').replace(/\\r\\n/g, '\\n');\n    }\n\n    function analyzeText(text, fileT"]
