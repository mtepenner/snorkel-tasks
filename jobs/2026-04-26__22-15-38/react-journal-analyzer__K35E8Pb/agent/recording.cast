[47.297098, "i", "\n    }\n\n    function countKeyword(text, keyword) {\n      const re = new RegExp(`\\\\b${keyword}\\\\b`, 'gi');\n      const m = text.match(re);\n      return m ? m.length : 0;\n    }\n\n    function firstNonEmptySentence(textBlock) {\n      const t = (textBlock || '').replace(/\\s+/g, ' ').trim();\n      if (!t) return '';\n      // Simple sentence split: first chunk ending with . ! ? (or whole line if none)\n      const m = t.match(/^(.+?[.!?])(\\s|$)/);\n      return m ? m[1].trim() : t;\n    }\n\n    function summarizeMarkdown(mdText) {\n      const lines = (mdText || '').split(/\\r?\\n/);\n      const summaries = [];\n      let currentTitle = null;\n      let currentBody = [];\n\n      function flush() {\n        if (currentTitle == null) return;\n        const body = currentBody.join('\\n');\n        const summary = firstNonEmptySentence(body);\n        summaries.push({ title: currentTitle, summary });\n      }\n\n      for (let i = 0; i < lines.length; i++) {\n        const line = lines[i];\n        const headerMatch = line.match(/^\\s*#+\\s*"]
