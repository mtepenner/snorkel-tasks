[84.966804, "i", "cat > /app/index.html <<'HTML'\n<!doctype html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>Client-Side Journal Analyzer</title>\n  <style>\n    body { font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif; margin: 24px; color: #111; }\n    .row { display: flex; gap: 18px; flex-wrap: wrap; align-items: flex-start; }\n    .card { border: 1px solid #ddd; border-radius: 10px; padding: 14px 16px; min-width: 280px; flex: 1; }\n    h1 { margin: 0 0 12px; font-size: 20px; }\n    h2 { margin: 0 0 10px; font-size: 16px; }\n    .muted { color: #555; font-size: 13px; }\n    .status { margin: 10px 0 18px; padding: 10px 12px; border-radius: 8px; background: #f7f7f7; border: 1px solid #e5e5e5; }\n    .sections ul { margin: 8px 0 0; padding-left: 18px; }\n    .sections li { margin: 6px 0; }\n    pre { background: #0b1020; color: #e6edf3; padding: 12px; border-radius: 10px; overflow: auto; border: 1px solid #1f2a44; }\n    labe"]
[84.967104, "i", "l { font-weight: 600; }\n    input[type=\"file\"] { margin-top: 8px; }\n  </style>\n</head>\n<body>\n  <div id=\"root\"></div>\n\n  <!-- React + ReactDOM + Babel (no build pipeline) -->\n  <script crossorigin src=\"https://unpkg.com/react@18/umd/react.development.js\"></script>\n  <script crossorigin src=\"https://unpkg.com/react-dom@18/umd/react-dom.development.js\"></script>\n  <script src=\"https://unpkg.com/@babel/standalone/babel.min.js\"></script>\n\n  <script type=\"text/babel\">\n    const { useMemo, useState } = React;\n\n    function round3(n) {\n      const x = Number.isFinite(n) ? n : 0;\n      return Math.round(x * 1000) / 1000;\n    }\n\n    function countWordsDeterministic(text) {\n      const m = (text || '').match(/\\b[\\w'-]+\\b/g);\n      return m ? m.length : 0;\n    }\n\n    function countCitations(text) {\n      const m = (text || '').match(/\\[(\\d+)\\]/g);\n      return m ? m.length : 0;\n    }\n\n    function countKeyword(text, keyword) {\n      const re = new RegExp(`\\\\b${keyword}\\\\b`, 'gi');\n      const m = (text || '').match(re);"]
