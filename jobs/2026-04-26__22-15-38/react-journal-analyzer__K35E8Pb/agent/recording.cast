[47.298141, "i", " keep only reasonably texty strings\n          const cleaned = s.replace(/\\u0000/g, '').trim();\n          if (cleaned && /[A-Za-z0-9]/.test(cleaned)) out.push(cleaned);\n          i = j - 1;\n        }\n      }\n\n      // Join with newlines; also normalize multiple spaces.\n      const joined = out.join('\\n').replace(/\\r\\n/g, '\\n');\n      return joined;\n    }\n\n    function analyzeText(text, fileType) {\n      const totalWords = countWordsDeterministic(text);\n      const citations = countCitations(text);\n      const quantumCount = countKeyword(text, 'quantum');\n      const entanglementCount = countKeyword(text, 'entanglement');\n\n      const keywordDensity = {\n        quantum: {\n          count: quantumCount,\n          density: round3(totalWords ? (quantumCount / totalWords) : 0)\n        },\n        entanglement: {\n          count: entanglementCount,\n          density: round3(totalWords ? (entanglementCount / totalWords) : 0)\n        }\n      };\n\n      const sectionSummaries = (fileType === 'markdown')\n        ? summari"]
