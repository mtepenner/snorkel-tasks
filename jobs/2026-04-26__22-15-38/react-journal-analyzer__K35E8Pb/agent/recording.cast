[47.298564, "i", "         setStatus(`Loaded ${name} (${next.totalWords} words)`);\n            return;\n          }\n\n          if (ext === 'pdf') {\n            const buf = await file.arrayBuffer();\n            const text = decodePdfLikeText(buf);\n            const next = analyzeText(text, 'pdf');\n            setAnalysis(next);\n            setStatus(`Loaded ${name} (${next.totalWords} words)`);\n            return;\n          }\n\n          setStatus('Unsupported file type. Please upload .md, .markdown, or .pdf');\n        } catch (e) {\n          console.error(e);\n          setStatus('Error reading file.');\n        }\n      }\n\n      return (\n        <div>\n          <h1>Journal Analyzer</h1>\n\n          <div className=\"card\">\n            <label htmlFor=\"file\">Upload Journal File</label>\n            <div className=\"muted\">Accepted: .md, .markdown, .pdf</div>\n            <input\n              id=\"file\"\n              type=\"file\"\n              accept=\".md,.markdown,.pdf,application/pdf,text/markdown\"\n              onChange={(e) => handleFile"]
