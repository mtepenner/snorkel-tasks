[?2004l [?2004h>     function analyzeText(text, fileType) {
[?2004l[?2004h>       const totalWords = countWordsDeterministic(text);
[?2004l[?2004h>       const citations = countCitations(text);
[?2004l[?2004h> 
[?2004l[?2004h>       const quantumCount = countKeyword(text, 'quantum');
[?2004l[?2004h>       const entanglementCount = countKeyword(text, 'entanglement');
[?2004l[?2004h> 
[?2004l[?2004h>       const keywordDensity = {
[?2004l[?2004h>         quantum: {
