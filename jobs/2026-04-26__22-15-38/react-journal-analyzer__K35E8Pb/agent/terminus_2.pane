[?2004l[?2004h>           density: round3(totalWords ? (quantumCount / totalWords) : 0)
[?2004l[?2004h>         },
[?2004l[?2004h>         entanglement: {
[?2004l[?2004h>           count: entanglementCount,
[?2004l[?2004h>           density: round3(totalWords ? (entanglementCount / totalWords) : 0)
[?2004l[?2004h>         }
[?2004l[?2004h>       };
[?2004l[?2004h> 
[?2004l[?2004h>       const sectionSummaries = (fileType === 'markdown')
[?2004l[?2004h>         ? summarizeMarkdown(text)
[?2004l[?2004h>         : summarizeByHeadingsLoose(text);
[?2004l[?2004h> 
[?2004l[?2004h>       return { fileType, citations, totalWords, keywordDensity, sectionSummaries };
[?2004l[?2004h>     }
