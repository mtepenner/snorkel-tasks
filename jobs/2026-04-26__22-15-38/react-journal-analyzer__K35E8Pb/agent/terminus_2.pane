[?2004l[?2004h> 
[?2004l[?2004h>       const keywordDensity = {
[?2004l[?2004h>         quantum: {
[?2004l[?2004h>           count: quantumCount,
[?2004l[?2004h>           density: round3(totalWords ? (quantumCount / totalWords) : 0)
[?2004l[?2004h>         },
[?2004l[?2004h>         entanglement: {
[?2004l[?2004h>           count: entanglementCount,
[?2004l[?2004h>           density: round3(totalWords ? (entanglementCount / totalWords) : 0)
[?2004l[?2004h>         }
[?2004l[?2004h>       };
