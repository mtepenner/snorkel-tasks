[?2004l[?2004h> 
[?2004l[?2004h>       const [status, setStatus] = useState('No file loaded.');
[?2004l[?2004h>       const [analysis, setAnalysis] = useState(empty);
[?2004l[?2004h> 
[?2004l[?2004h>       async function handleFile(file) {
[?2004l[?2004h>         if (!file) return;
[?2004l[?2004h>         const name = file.name || '';
[?2004l[?2004h>         const ext = name.toLowerCase().split('.').pop();
[?2004l[?2004h> 
[?2004l[?2004h>         try {
[?2004l[?2004h>           setStatus(`Loading: ${name}`);
[?2004l[?2004h> 
[?2004l[?2004h>           if (ext === 'md' || ext === 'markdown') {
[?2004l[?2004h>             const text = await file.text();
[?2004l[?2004h>             const next = analyzeText(text, 'markdown');
[?2004l[?2004h>             setAnalysis(next);
[?2004l[?2004h>             setStatus(`Loaded ${name} (${next.totalWords} words)`);
[?2004l[?2004h>             return;
[?2004l[?2004h>           }
[?2004l[?2004h> 
[?2004l[?2004h>           if (ext === 'pdf') {
[?2004l[?2004h>             const buf = await file.arrayBuffer();
[?2004l[?2004h>             const text = decodePdfLikeText(buf);
[?2004l[?2004h>             const next = analyzeText(text, 'pdf');
[?2004l[?2004h>             setAnalysis(next);
[?2004l[?2004h>             setStatus(`Loaded ${name} (${next.totalWords} words)`);
[?2004l[?2004h>             return;
[?2004l[?2004h>           }
[?2004l[?2004h> 
[?2004l[?2004h>           setStatus('Unsupported file type. Please upload .md, .markdown, or .pdf');
[?2004l[?2004h>         } catch (e) {
[?2004l[?2004h>           console.error(e);
[?2004l[?2004h>           setStatus('Error reading file.');
[?2004l[?2004h>         }
[?2004l[?2004h>       }
[?2004l[?2004h> 
[?2004l[?2004h>       return (
[?2004l[?2004h>         <div>
[?2004l[?2004h>           <h1>Journal Analyzer</h1>
[?2004l[?2004h> 
[?2004l[?2004h>           <div className="card">
[?2004l[?2004h>             <label htmlFor="file">Upload Journal File</label>
[?2004l[?2004h>             <div className="muted">Accepted: .md, .markdown, .pdf</div>
[?2004l[?2004h>             <input
[?2004l[?2004h>               id="file"
[?2004l[?2004h>               type="file"
[?2004l[?2004h>               accept=".md,.markdown,.pdf,application/pdf,text/markdown"
[?2004l[?2004h>               onChange={(e) => handleFile(e.target.files && e.target.files[0])}
[?2004l[?2004h>             />
[?2004l[?2004h>           </div>
[?2004l[?2004h> 
[?2004l[?2004h>           <div className="status" aria-live="polite">{status}</div>
[?2004l[?2004h> 
[?2004l[?2004h>           <div className="row">
[?2004l[?2004h>             <div className="card">
[?2004l[?2004h>               <h2>Citation Frequency</h2>
[?2004l[?2004h>               <div><strong>Total citations:</strong> {analysis.citations}</div>
[?2004l[?2004h>             </div>
[?2004l[?2004h> 
[?2004l[?2004h>             <div className="card">
[?2004l[?2004h>               <h2>Keyword Density</h2>
[?2004l[?2004h>               <div><strong>Total words:</strong> {analysis.totalWords}</div>
[?2004l[?2004h>               <div style={{ marginTop: 8 }}>
[?2004l[?2004h>                 <div><strong>quantum</strong>: {analysis.keywordDensity.quantum.count} (density: {analysis.keywordDensity.quantum.density})</div>
