[?2004l[?2004h>                       <div className="muted">{s.summary || '(No summary found)'}</div>
[?2004l[?2004h>                     </li>
[?2004l[?2004h>                   ))}
[?2004l[?2004h>                 </ul>
[?2004l[?2004h>               )}
[?2004l[?2004h>             </div>
[?2004l[?2004h>           </div>
[?2004l[?2004h> 
[?2004l[?2004h>           <h2 style={{ marginTop: 18 }}>Analysis JSON</h2>
