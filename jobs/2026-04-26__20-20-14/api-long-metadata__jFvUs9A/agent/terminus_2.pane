[?2004l[?2004h> def extract_topics(text: str, min_topics: int = 3, max_topics: int = 10) -> list:
[?2004l[?2004h>     """Extract meaningful keyword topics from text via frequency analysis."""
[?2004l[?2004h>     words = re.findall(r"[a-zA-Z]+", text.lower())
[?2004l[?2004h>     # Filter: not a stop word, length >= 4
[?2004l[?2004h>     filtered = [w for w in words if w not in STOP_WORDS and len(w) >= 4]
[?2004l[?2004h>     if not filtered:
[?2004l[?2004h>         # fallback: relax length constraint
[?2004l[?2004h>         filtered = [w for w in words if w not in STOP_WORDS and len(w) >= 3]
[?2004l[?2004h>     counts = Counter(filtered)
[?2004l[?2004h>     # Take the most common, capped at max_topics
[?2004l[?2004h>     top = counts.most_common(max_topics * 3)
[?2004l[?2004h>     # Deduplicate stems loosely: if one word starts with another shorter word, keep the shorter
[?2004l[?2004h>     selected = []
[?2004l[?2004h>     seen_stems = set()
[?2004l[?2004h>     for word, freq in top:
[?2004l[?2004h>         stem = word[:6]
[?2004l[?2004h>         if stem not in seen_stems:
[?2004l[?2004h>             seen_stems.add(stem)
[?2004l[?2004h>             selected.append(word)
[?2004l[?2004h>         if len(selected) >= max_topics:
[?2004l[?2004h>             break
[?2004l[?2004h>     # Ensure minimum
[?2004l[?2004h>     if len(selected) < min_topics:
[?2004l[?2004h>         # Pad from remaining words
[?2004l[?2004h>         for word, freq in top:
[?2004l[?2004h>             if word not in selected:
[?2004l[?2004h>                 selected.append(word)
[?2004l[?2004h>             if len(selected) >= min_topics:
[?2004l[?2004h>                 break
[?2004l[?2004h>     return selected[:max_topics]
[?2004l[?2004h> 
