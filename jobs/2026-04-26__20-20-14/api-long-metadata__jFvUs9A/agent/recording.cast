[72.023957, "i", "cat > /app/workspace/src/api.py << 'PYEOF'\nimport re\nfrom collections import Counter\nfrom fastapi import FastAPI, File, UploadFile\nfrom fastapi.staticfiles import StaticFiles\nfrom PyPDF2 import PdfReader\nimport io\nimport os\n\napp = FastAPI()\n\n# Mount static files\napp.mount(\"/static\", StaticFiles(directory=os.path.join(os.path.dirname(__file__), \"static\")), name=\"static\")\n\nSTOP_WORDS = {\n    \"the\", \"be\", \"to\", \"of\", \"and\", \"a\", \"in\", \"that\", \"have\", \"i\",\n    \"it\", \"for\", \"not\", \"on\", \"with\", \"he\", \"as\", \"you\", \"do\", \"at\",\n    \"this\", \"but\", \"his\", \"by\", \"from\", \"they\", \"we\", \"say\", \"her\",\n    \"she\", \"or\", \"an\", \"will\", \"my\", \"one\", \"all\", \"would\", \"there\",\n    \"their\", \"what\", \"so\", \"up\", \"out\", \"if\", \"about\", \"who\", \"get\",\n    \"which\", \"go\", \"me\", \"when\", \"make\", \"can\", \"like\", \"time\", \"no\",\n    \"just\", \"him\", \"know\", \"take\", \"people\", \"into\", \"year\", \"your\",\n    \"good\", \"some\", \"could\", \"them\", \"see\", \"other\", \"than\", \"then\",\n    \"now\", \"look\", \"only\", \"come\", \"its\", \"over\", \"think\", \"also\",\n    \"back\", \"after\", \"use\", \"two\", \"how\", \"our\", \"work\", \"first\",\n    \"well\", \"way\", \"even\", \"new\", \"want\", \"because\", \"any\", \"these\",\n    \"give\", \"day\", \"most\", \"us\", \"is\", \"are\", \"was\", \"were\", \"been\",\n    \"being\", \"has\", \"had\", \"did\", \"does\", \"doing\", \"am\", \"may\", \"might\",\n    \"shall\", \"should\", \"must\", \"need\", \"ought\", \"dare\", \"used\",\n    \"such\", \"very\", \"much\", \"more\", \"many\", \"each\", \"every\", \"own\",\n    \"same\", \"both\", \"few\", \"still\", \"those\", \"through\", \"between\",\n    \"where\", \"here\", \"while\", \"during\", \"before\", \"since\", \"until\",\n    \"too\", \"quite\", \"rather\", \"already\", \"yet\", \"again\", \"often\",\n    \"never\", \"always\", \"sometimes\", \"however\", \"therefore\", \"thus\",\n    \"hence\", \"also\", \"else\", \"further\", \"then\", \"once\", \"twice\",\n    \"per\", \"via\", \"etc\", \"ie\", \"eg\", \"page\", \"de\", \"le\", \"la\",\n    \"et\", \"en\", \"un\", \"une\", \"les\", \"des\", \"du\", \"au\", \"se\", \"ce\",\n    \"est\", \"il\", \"pas\", \"ne\", \"que\", \"qui\", \"dans\", \"pour\", \"sur\",\n    \"son\", \"sa\", \"ses\", \"avec\", \"plus\", \"tout\", \"fait\", \"mais\",\n    \"been\", \"being\", \"below\", \"above\", \"down\", \"off\", \"don\", \"doesn\",\n    \"didn\", \"won\", \"wouldn\", \"shouldn\", \"couldn\", \"wasn\", \"weren\",\n    \"hasn\", \"hadn\", \"isn\", \"aren\", \"ain\", \"nor\", \"couldn\", \"didn\",\n    \"doesn\", \"hadn\", \"hasn\", \"haven\", \"isn\", \"ll\", \"re\", \"ve\",\n    \"wasn\", \"weren\", \"won\", \"wouldn\", \"shouldn\", \"mustn\", \"needn\",\n    \"shan\", \"aren\", \"don\", \"let\", \"may\", \"said\", \"also\", \"upon\",\n    \"using\", \"without\", \"within\", \"among\", \"along\", \"across\",\n    \"around\", \"though\", \"although\", \"whether\", \"another\", \"man\",\n    \"set\", \"put\", \"end\", \"got\", \"made\", \"went\", \"going\", \"thing\",\n    \"things\", \"something\", \"nothing\", \"everything\", \"anything\",\n    \"able\", \"cannot\", \"really\", \"right\", \"left\", \"part\", \"number\",\n    \"long\", \"great\", \"little\", \"old\", \"big\", \"small\", \"high\", \"low\",\n    \"large\", \"called\", \"came\", \"under\", \"next\", \"last\", \"keep\",\n    \"found\", \"hand\", \"place\", \"point\", \"away\", \"turn\", \"might\",\n    \"world\", \"home\", \"still\", \"kind\", \"head\", \"began\", \"far\",\n    \"near\", \"state\", \"three\", \"four\", \"five\", \"six\", \"seven\",\n    \"eight\", \"nine\", \"ten\", \"hundred\", \"thousand\", \"million\",\n    \"become\", \"became\", \"taken\", \"given\", \"known\", \"seen\", \"done\",\n    \"gone\", \"told\", \"ask\", \"asked\", \"tell\", \"find\", \"run\", \"help\",\n    \"show\", \"try\", \"start\", \"began\", \"begin\", \"began\", \"seem\",\n    \"seemed\", \"move\", \"live\", \"play\", \"read\", \"write\", \"written\",\n    \"include\", \"including\", \"included\", \"based\", \"form\", \"case\",\n    \"second\", \"third\", \"general\", \"particular\", \"open\", \"close\",\n    \"different\", \"important\", \"possible\", \"certain\", \"others\",\n    \"example\", \"information\", \"following\", \"according\", \"often\",\n    \"order\", \"line\", \"name\", \"area\", \"group\", \"may\", \"shall\",\n}\n\n\ndef extract_topics(text: str, min_topics: int = 3, max_topics: int = 10) -> list:\n    \"\"\"Extract meaningful keyword topics from text via frequency analysis.\"\"\"\n    words = re.findall(r\"[a-zA-Z]+\", text.lower())\n    # Filter: not a stop word, length >= 4\n    filtered = [w for w in words if w not in STOP_WORDS and len(w) >= 4]\n    if not filtered:\n        # fallback: relax length constraint"]
[72.02406, "i", "\n        filtered = [w for w in words if w not in STOP_WORDS and len(w) >= 3]\n    counts = Counter(filtered)\n    # Take the most common, capped at max_topics\n    top = counts.most_common(max_topics * 3)\n    # Deduplicate stems loosely: if one word starts with another shorter word, keep the shorter\n    selected = []\n    seen_stems = set()\n    for word, freq in top:\n        stem = word[:6]\n        if stem not in seen_stems:\n            seen_stems.add(stem)\n            selected.append(word)\n        if len(selected) >= max_topics:\n            break\n    # Ensure minimum\n    if len(selected) < min_topics:\n        # Pad from remaining words\n        for word, freq in top:\n            if word not in selected:\n                selected.append(word)\n            if len(selected) >= min_topics:\n                break\n    return selected[:max_topics]\n\n\n@app.post(\"/extract\")\nasync def extract(file: UploadFile = File(...)):\n    contents = await file.read()\n    reader = PdfReader(io.BytesIO(contents))\n\n    # Metadata\n    meta = reader.metadata\n    author = \"Unknown Author\"\n    title = \"Untitled\"\n    if meta:\n        if meta.author and str(meta.author).strip():\n            author = str(meta.author).strip()\n        if meta.title and str(meta.title).strip():\n            title = str(meta.title).strip()\n\n    # Extract all text\n    full_text = \"\"\n    for page in reader.pages:\n        page_text = page.extract_text()\n        if page_text:\n            full_text += page_text + \" \"\n\n    # Split into words and chunk\n    words = full_text.split()\n    total_words = len(words)\n    chunk_size = 1000\n    chunks = []\n    for i in range(0, max(total_words, 1), chunk_size):\n        chunk = words[i:i + chunk_size]\n        if chunk:\n            chunks.append(\" \".join(chunk))\n    total_chunks = len(chunks) if chunks else 1\n\n    # Topics\n    topics = extract_topics(full_text)\n\n    return {\n        \"author\": author,\n        \"title\": title,\n        \"topics\": topics,\n        \"total_chunks\": total_chunks,\n        \"filename\": file.filename,\n        \"total_words\": total_words,\n    }\nPYEOF\n"]
