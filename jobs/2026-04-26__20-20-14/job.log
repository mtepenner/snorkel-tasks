chunk))\n    total_chunks = len(chunks) if chunks else 1\n\n    # Topics\n    topics = extract_topics(full_text)\n\n    return {\n        "author": author,\n        "title": title,\n        "topics": topics,\n        "total_chunks": total_chunks,\n        "filename": file.filename,\n        "total_words": total_words,\n    }\nPYEOF\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
